#!/usr/bin/env bash
set -Eeuo pipefail

readonly SECRET_LIKE_REASON_PATTERN='(?i)(-----BEGIN [A-Z0-9 ]*PRIVATE KEY-----|(?:password|passwd|pwd|secret|token|api[_ -]?key|private[_ -]?key|authorization|credential)\s*[:=]\s*\S+|bearer\s+[A-Za-z0-9._~+/=-]{8,}|(?:postgres(?:ql)?|jdbc:postgresql|mysql|https?)://[^\s/:]+:[^\s/@]+@|(?:gh[pousr]_[A-Za-z0-9]{20,}|github_pat_[A-Za-z0-9_]{20,}|sk-[A-Za-z0-9_-]{20,}))'
readonly MAIN_REF="${DEPLOY_RESOLVER_MAIN_REF:-origin/main}"
readonly INVENTORY_PATH="scripts/deploy/deploy-schema-sensitive-paths-v1.txt"

fail_resolve() {
  echo "::error::$*" >&2
  exit 1
}

if [[ "${DEPLOY_RESOLVER_FETCH_MAIN:-true}" == true ]]; then
  git fetch --no-tags origin +refs/heads/main:refs/remotes/origin/main
fi

deploy_sha="${INPUT_IMAGE_SHA:-${GITHUB_SHA:-}}"
[[ "${deploy_sha}" =~ ^[0-9a-fA-F]{40}$ ]] || fail_resolve "image_sha must be a 40-character commit SHA"
deploy_sha="$(printf '%s' "${deploy_sha}" | tr 'A-F' 'a-f')"

git cat-file -e "${deploy_sha}^{commit}"
git merge-base --is-ancestor "${deploy_sha}" "${MAIN_REF}"
git checkout --detach "${deploy_sha}" >/dev/null

main_tip="$(git rev-parse "${MAIN_REF}")"
operator_reason="$(jq -nr --arg value "${INPUT_ROLLBACK_REASON:-}" '$value | gsub("^\\s+|\\s+$"; "")')"
migration_rollback_mode="${INPUT_MIGRATION_ROLLBACK_MODE:-AUTO_IMAGE_ROLLBACK}"
case "${migration_rollback_mode}" in
  AUTO_IMAGE_ROLLBACK|BACKWARD_COMPATIBLE|ROLL_FORWARD_ONLY) ;;
  *) fail_resolve "invalid migration_rollback_mode" ;;
esac

jq -en \
  --arg reason "${operator_reason}" \
  --arg secretPattern "${SECRET_LIKE_REASON_PATTERN}" '
    ($reason | length) <= 240 and
    ($reason | test("[\u0000-\u001f\u007f]") | not) and
    ($reason | test($secretPattern) | not)
  ' >/dev/null || \
  fail_resolve "rollback_reason contains a control character, secret-like value, or exceeds 240 characters"

case "${GITHUB_EVENT_NAME:-}" in
  push)
    [[ "${deploy_sha}" == "${GITHUB_SHA:-}" ]] || fail_resolve "push deploy target must equal the event SHA"
    [[ -z "${operator_reason}" && "${migration_rollback_mode}" == "AUTO_IMAGE_ROLLBACK" ]] || \
      fail_resolve "push may issue only FORWARD with AUTO_IMAGE_ROLLBACK and an empty reason"
    deploy_intent=FORWARD
    ;;
  workflow_dispatch)
    if [[ "${deploy_sha}" == "${main_tip}" ]]; then
      deploy_intent=FORWARD
    else
      deploy_intent=AUTHORIZED_ROLLBACK
      [[ -n "${operator_reason}" ]] || fail_resolve "a historical target requires rollback_reason"
    fi

    if [[ "${migration_rollback_mode}" == "AUTO_IMAGE_ROLLBACK" ]]; then
      [[ "${deploy_intent}" == "AUTHORIZED_ROLLBACK" || -z "${operator_reason}" ]] || \
        fail_resolve "latest-main AUTO_IMAGE_ROLLBACK does not accept rollback_reason"
    else
      [[ -n "${operator_reason}" ]] || fail_resolve "an explicit migration rollback mode requires rollback_reason"
    fi
    ;;
  *) fail_resolve "unsupported workflow event" ;;
esac

git cat-file -e "${main_tip}:${INVENTORY_PATH}" || fail_resolve "schema-sensitive path inventory is missing"
schema_sensitive_paths_sha256="$(git show "${main_tip}:${INVENTORY_PATH}" | sha256sum | awk '{print $1}')"
schema_sensitive_paths=()
while IFS= read -r schema_sensitive_path; do
  schema_sensitive_paths[${#schema_sensitive_paths[@]}]="${schema_sensitive_path}"
done < <(git show "${main_tip}:${INVENTORY_PATH}" | awk 'NF && $1 !~ /^#/')
[[ "${#schema_sensitive_paths[@]}" -gt 0 ]] || fail_resolve "schema-sensitive path inventory is empty"

zero_sha=0000000000000000000000000000000000000000
if [[ "${GITHUB_EVENT_NAME:-}" == push && "${GITHUB_EVENT_BEFORE:-}" =~ ^[0-9a-f]{40}$ &&
      "${GITHUB_EVENT_BEFORE}" != "${zero_sha}" ]] &&
   git cat-file -e "${GITHUB_EVENT_BEFORE}^{commit}" 2>/dev/null &&
   git merge-base --is-ancestor "${GITHUB_EVENT_BEFORE}" "${deploy_sha}"; then
  if git diff --quiet "${GITHUB_EVENT_BEFORE}" "${deploy_sha}" -- "${schema_sensitive_paths[@]}"; then
    :
  else
    diff_status=$?
    if [[ "${diff_status}" == 1 ]]; then
      fail_resolve "SCHEMA_SENSITIVE_AUTOMATIC_DEPLOY_REQUIRES_MANUAL_REVIEW"
    fi
    echo "::warning::schema-sensitive early classification was unavailable; root admission remains authoritative" >&2
  fi
fi

{
  echo "deploy_sha=${deploy_sha}"
  echo "foundation_sha=${main_tip}"
  echo "workflow_event=${GITHUB_EVENT_NAME}"
  echo "deploy_intent=${deploy_intent}"
  echo "operator_reason=${operator_reason}"
  echo "migration_rollback_mode=${migration_rollback_mode}"
  echo "schema_sensitive_paths_sha256=${schema_sensitive_paths_sha256}"
} >> "${GITHUB_OUTPUT:?GITHUB_OUTPUT is required}"
