#!/usr/bin/env bash
set -Eeuo pipefail

readonly CONTRACT_VERSION=2
readonly DEPLOY_ROOT="${FUKUROU_DEPLOY_ROOT:-/srv/fukurou}"
readonly REPO_DIR="${DEPLOY_ROOT}/repo"
readonly ENV_FILE="${DEPLOY_ROOT}/.env"
readonly STATE_ROOT="${DEPLOY_ROOT}/deploy-state"
readonly FENCE_ROOT="${DEPLOY_ROOT}/runtime/launch-fence"
readonly LOCK_FILE="${FUKUROU_DEPLOY_LOCK:-/var/lock/fukurou-deploy.lock}"
readonly COMPOSE_FILE="${REPO_DIR}/docker-compose.prod.yml"
readonly MAIN_REF="${FUKUROU_MAIN_REF:-origin/main}"
readonly IMAGE_REPOSITORY="${FUKUROU_IMAGE_REPOSITORY:-ghcr.io/matsumo0922/fukurou}"
readonly PUBLIC_KEY="${FUKUROU_DEPLOY_PUBLIC_KEY:-/usr/local/share/fukurou/deploy-public-key.pem}"
readonly INSTALLED_CATALOG="${FUKUROU_DEPLOY_CATALOG:-/usr/local/share/fukurou/deploy-capability-catalog-v1.json}"
readonly INSTALLED_SCHEMA_SENSITIVE_PATHS="${FUKUROU_DEPLOY_SCHEMA_SENSITIVE_PATHS:-/usr/local/share/fukurou/deploy-schema-sensitive-paths-v1.txt}"
readonly CATALOG_LEDGER="${FUKUROU_DEPLOY_CATALOG_LEDGER:-${DEPLOY_ROOT}/deploy-catalog-ledger}"
readonly DB_HELPER="${FUKUROU_DEPLOY_DB_HELPER:-/usr/local/libexec/fukurou-deploy-db}"
readonly SUPERVISOR_BINARY="/usr/local/libexec/fukurou-runtime-supervisor"
readonly FOUNDATION_HARNESS="${FUKUROU_FOUNDATION_HARNESS:-/usr/local/libexec/fukurou-mcp-credential-isolation-check}"
readonly FOUNDATION_HARNESS_SQL="${FUKUROU_FOUNDATION_HARNESS_SQL:-/usr/local/share/fukurou/mcp-role.sql}"
readonly CANARY_PRIVATE_KEY="${DEPLOY_ROOT}/secrets/llm-launch-ed25519"
readonly CANARY_PUBLIC_KEY="${DEPLOY_ROOT}/secrets/llm-launch-ed25519.pub"
readonly IMAGE_RETENTION_COUNT="${FUKUROU_IMAGE_RETENTION_COUNT:-10}"
readonly APPLICATION_HEALTH_TIMEOUT="${FUKUROU_DEPLOY_HEALTH_TIMEOUT:-120}"
readonly APPLICATION_UID=10001
readonly APPLICATION_GID=10001

fail() {
  echo "deploy-fukurou: stage=${DEPLOY_STAGE:-PRECHECK} reason=$*" >&2
  return 1
}

cleanup_pending_state() {
  [[ -n "${PENDING_STATE_DIR:-}" ]] || return 0
  case "${PENDING_STATE_DIR}" in
    "${STATE_ROOT}"/.*.tmp.*) rm -rf -- "${PENDING_STATE_DIR}" ;;
    *) fail "REFUSING_UNSAFE_PENDING_STATE_CLEANUP:${PENDING_STATE_DIR}"; return 1 ;;
  esac
  PENDING_STATE_DIR=""
}

cleanup_stale_pending_states() {
  local stale_state
  while IFS= read -r -d '' stale_state; do
    rm -rf -- "${stale_state}"
  done < <(find "${STATE_ROOT}" -xdev -mindepth 1 -maxdepth 1 -type d -name '.*.tmp.*' -print0)
}

boottime_seconds() {
  local uptime
  IFS=' ' read -r uptime _ < /proc/uptime || fail "CLOCK_BOOTTIME_UNAVAILABLE"
  printf '%s\n' "${uptime%%.*}"
}

on_signal() {
  local signal_name="$1" code="$2"
  SIGNAL_NAME="${signal_name}"
  terminate_active_external_process_group
  if [[ -z "${ROLLBACK_STATE_DIR:-}" || ! -f "${ROLLBACK_STATE_DIR}/journal.jsonl" ]]; then
    cleanup_pending_state || true
    echo "deploy-fukurou: stage=${DEPLOY_STAGE:-UNKNOWN} reason=SIGNAL_BEFORE_ROLLBACK_CAPTURE:${signal_name}" >&2
    exit "${code}"
  fi
  journal_state SIGNAL_RECEIVED "{\"signal\":\"${signal_name}\"}" 2>/dev/null || true
  (exit "${code}")
  rollback_on_error
}

terminate_active_external_process_group() {
  [[ -n "${ACTIVE_EXTERNAL_PGID:-}" ]] || return 0
  kill -TERM -- "-${ACTIVE_EXTERNAL_PGID}" 2>/dev/null || true
  local deadline=$(( $(boottime_seconds) + 5 ))
  while kill -0 "${ACTIVE_EXTERNAL_PGID}" 2>/dev/null && (( $(boottime_seconds) < deadline )); do sleep 1; done
  kill -KILL -- "-${ACTIVE_EXTERNAL_PGID}" 2>/dev/null || true
}

check_forward_deadline() {
  [[ "$(boottime_seconds)" -lt "${FORWARD_DEADLINE_BOOTTIME}" ]] || fail "FORWARD_DEADLINE_EXCEEDED"
}

stop_forward_deadline_watchdog() {
  [[ -n "${DEADLINE_WATCHDOG_PID:-}" ]] || return 0
  kill -TERM "${DEADLINE_WATCHDOG_PID}" 2>/dev/null || true
  wait "${DEADLINE_WATCHDOG_PID}" 2>/dev/null || true
  DEADLINE_WATCHDOG_PID=""
}

start_forward_deadline_watchdog() {
  stop_forward_deadline_watchdog
  local remaining=$((FORWARD_DEADLINE_BOOTTIME - $(boottime_seconds)))
  (( remaining > 0 )) || fail "FORWARD_DEADLINE_EXCEEDED"
  (
    exec 9>&-
    trap - ERR
    local watchdog_sleep_pid=""
    cleanup_watchdog_sleep() {
      [[ -n "${watchdog_sleep_pid}" ]] || return 0
      kill -TERM "${watchdog_sleep_pid}" 2>/dev/null || true
      wait "${watchdog_sleep_pid}" 2>/dev/null || true
      watchdog_sleep_pid=""
    }
    trap cleanup_watchdog_sleep TERM INT HUP EXIT
    sleep "${remaining}" &
    watchdog_sleep_pid="$!"
    wait "${watchdog_sleep_pid}" || exit 0
    watchdog_sleep_pid=""
    trap - TERM INT HUP EXIT
    kill -USR1 "$$" 2>/dev/null || true
  ) &
  DEADLINE_WATCHDOG_PID="$!"
}

timeout() {
  local requested="$1"
  shift
  local deadline="${RECOVERY_DEADLINE_BOOTTIME:-${FORWARD_DEADLINE_BOOTTIME:-}}"
  if [[ -n "${deadline}" ]]; then
    local remaining=$((deadline - $(boottime_seconds)))
    (( remaining > 0 )) || return 124
    (( requested <= remaining )) || requested="${remaining}"
  fi
  command timeout --signal=TERM --kill-after=5 "${requested}" "$@" &
  ACTIVE_EXTERNAL_PGID="$!"
  local status=0
  wait "${ACTIVE_EXTERNAL_PGID}" || status="$?"
  ACTIVE_EXTERNAL_PGID=""
  return "${status}"
}

usage() {
  echo "Usage: deploy-fukurou --bundle <path> --signature <path> <40-character commit sha>" >&2
}

require_root() {
  [[ "$(id -u)" == "0" ]] || fail "this script must run as root via sudo"
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || fail "required command is unavailable: $1"
}

normalize_sha() {
  [[ "$1" =~ ^[0-9a-fA-F]{40}$ ]] || fail "commit sha must be a 40-character hexadecimal string"
  printf '%s' "$1" | tr 'A-F' 'a-f'
}

parse_arguments() {
  [[ "${1:-}" == "--bundle" && -n "${2:-}" && "${3:-}" == "--signature" && -n "${4:-}" && -n "${5:-}" && -z "${6:-}" ]] || {
    usage
    exit 2
  }
  BUNDLE_PATH="$2"
  SIGNATURE_PATH="$4"
  DEPLOY_SHA="$(normalize_sha "$5")"
}

validate_typed_operation_set() {
  local bundle_json="$1" catalog_json="$2"
  validate_catalog_dispatchability "${catalog_json}" || return 1
  jq -e --argjson catalog "${catalog_json}" '
    def contains_all($actual; $required): all($required[]; . as $item | $actual | index($item) != null);
    def unique_items($items): ($items | unique | length) == ($items | length);
    def baseline_operations: [
      {"capability":"CREATE_DIR_V1","operationId":"LAUNCH_FENCE_ROOT"},
      {"capability":"INSTALL_SECRET_REF_V1","operationId":"LLM_LAUNCH_SIGNING_KEY_V1"},
      {"capability":"DB_MIGRATION_V1","operationId":"INSTALL_FOUNDATION_V1"},
      {"capability":"DB_MAINTENANCE_V1","operationId":"SET_LAUNCH_MAINTENANCE"},
      {"capability":"DB_MAINTENANCE_V1","operationId":"OPEN_INFRASTRUCTURE_GAP"},
      {"capability":"SMOKE_HOOK_V1","operationId":"FOUNDATION_PREFLIGHT_V1"},
      {"capability":"RUN_COMPOSE_PROJECT_V1","operationId":"PRODUCTION"},
      {"capability":"DB_MAINTENANCE_V1","operationId":"CLOSE_INFRASTRUCTURE_GAP"},
      {"capability":"DB_MAINTENANCE_V1","operationId":"CLEAR_LAUNCH_MAINTENANCE"}
    ];
    def baseline_capabilities: [
      "CREATE_DIR_V1", "DB_MAINTENANCE_V1", "DB_MIGRATION_V1",
      "INSTALL_SECRET_REF_V1", "RUN_COMPOSE_PROJECT_V1", "SMOKE_HOOK_V1"
    ];
    . as $bundle |
    .minimumContractVersion == 2 and
    unique_items(.requiredCapabilities) and unique_items(.requiredHooks) and
    unique_items([.operations[].operationId]) and
    contains_all(.requiredCapabilities; baseline_capabilities) and
    contains_all(.requiredHooks; ["FOUNDATION_PREFLIGHT_V1"]) and
    contains_all(.operations; baseline_operations) and
    all(.requiredCapabilities[]; . as $capability | any($catalog.builtInCapabilities[]; .capabilityId == $capability)) and
    all(.requiredHooks[]; . as $hook | any($catalog.hooks[]; .hookId == $hook)) and
    all(.requiredHooks[]; . as $hook | any($bundle.operations[]; .operationId == $hook and .capability == "SMOKE_HOOK_V1")) and
    all(.operations[]; . as $operation |
      any($catalog.operations[];
        .operationId == $operation.operationId and .capabilityId == $operation.capability))
  ' <<<"${bundle_json}" >/dev/null
}

validate_catalog_dispatchability() {
  local catalog_json="$1"
  jq -e --argjson catalog "${catalog_json}" '
    def unique_by($items; $field): ($items | map(.[$field]) | unique | length) == ($items | length);
    def supported_schema: IN(
      "CREATE_DIR_FOUNDATION_V1", "DB_MAINTENANCE_FOUNDATION_V1", "DB_MIGRATION_FOUNDATION_V1",
      "SECRET_REF_FOUNDATION_V1", "COMPOSE_PROJECT_FOUNDATION_V1", "SMOKE_HOOK_FOUNDATION_V1"
    );
    def executor_entry: IN(
      "LAUNCH_FENCE_ROOT", "LLM_LAUNCH_SIGNING_KEY_V1", "INSTALL_FOUNDATION_V1",
      "SET_LAUNCH_MAINTENANCE", "OPEN_INFRASTRUCTURE_GAP", "PRODUCTION",
      "CLOSE_INFRASTRUCTURE_GAP", "CLEAR_LAUNCH_MAINTENANCE"
    );
    unique_by(.builtInCapabilities; "capabilityId") and
    unique_by(.hooks; "hookId") and unique_by(.operations; "operationId") and
    all(.builtInCapabilities[]; .parameterSchemaId | supported_schema) and
    all(.hooks[];
      .profile == "CANDIDATE_HOOK_V1" and (.entrypoint | type == "array" and length == 2) and
      .entrypoint[0] == "--canary-preflight" and (.entrypoint[1] | test("^[a-z0-9-]{1,48}$"))) and
    all(.operations[]; . as $operation |
      (.parameterSchemaId | supported_schema) and
      if .profile == "EXECUTOR_STAGE_V1" then
        (.entrypoint | type == "array" and length == 1) and
        (.entrypoint[0] | executor_entry) and .entrypoint[0] == .operationId
      elif .profile == "CANDIDATE_HOOK_V1" then
        .capabilityId == "SMOKE_HOOK_V1" and
        any($catalog.hooks[]; .hookId == $operation.operationId and
          .profile == $operation.profile and .entrypoint == $operation.entrypoint)
      else false end
    )
  ' <<<"${catalog_json}" >/dev/null
}

required_operation_plan() {
  local profile="$1"
  jq -c --arg profile "${profile}" --argjson catalog "${CANDIDATE_CATALOG}" '
    .operations[] as $required |
    $catalog.operations[] |
    select(.operationId == $required.operationId and .capabilityId == $required.capability and .profile == $profile)
  ' <<<"${SIGNED_BUNDLE_JSON}"
}

record_operation_dispatch() {
  local operation_id="$1"
  [[ "${DISPATCHED_OPERATION_IDS:-}" != *$'\n'"${operation_id}"$'\n'* ]] || {
    fail "DUPLICATE_OPERATION_DISPATCH:${operation_id}"
    return 1
  }
  DISPATCHED_OPERATION_IDS="${DISPATCHED_OPERATION_IDS:-}"$'\n'"${operation_id}"$'\n'
  local target="${ROLLBACK_STATE_DIR}/operation-dispatch.jsonl" sequence=0 previous_hash="" entry payload payload_hash
  if [[ -f "${target}" ]]; then
    sequence="$(tail -n 1 "${target}" | jq -er '.sequence')"
    previous_hash="$(tail -n 1 "${target}" | jq -er '.payloadHash')"
  fi
  payload="$(jq -cS -n --arg operationId "${operation_id}" --arg previousHash "${previous_hash}" \
    --argjson sequence "$((sequence + 1))" '{version:1,sequence:$sequence,previousHash:$previousHash,operationId:$operationId}')"
  payload_hash="$(printf '%s' "${payload}" | sha256sum | awk '{print $1}')"
  entry="${target}.entry.$$"
  jq -cS --arg payloadHash "${payload_hash}" '. + {payloadHash:$payloadHash}' <<<"${payload}" > "${entry}"
  chmod 0600 "${entry}"; sync -f "${entry}"
  if [[ -f "${target}" ]]; then
    command cat "${target}" "${entry}" > "${target}.tmp.$$"
  else
    command cat "${entry}" > "${target}.tmp.$$"
  fi
  chmod 0600 "${target}.tmp.$$"; sync -f "${target}.tmp.$$"
  mv "${target}.tmp.$$" "${target}"; rm -f "${entry}"; sync -f "${ROLLBACK_STATE_DIR}"
}

verify_required_operations_dispatched() {
  local operation_id
  while IFS= read -r operation_id; do
    [[ -n "${operation_id}" ]] || continue
    [[ "${DISPATCHED_OPERATION_IDS:-}" == *$'\n'"${operation_id}"$'\n'* ]] || fail "REQUIRED_OPERATION_NOT_DISPATCHED:${operation_id}"
  done < <(jq -r '.operations[].operationId' <<<"${SIGNED_BUNDLE_JSON}")
}

validate_catalog_extension() {
  local installed_canonical="$1" candidate_catalog="$2" installed_hash="$3"
  local parent_hash candidate_version installed_version
  validate_catalog_dispatchability "${candidate_catalog}" || return 1
  parent_hash="$(jq -er '.parentCatalogHash // ""' <<<"${candidate_catalog}")"
  candidate_version="$(jq -er '.catalogVersion' <<<"${candidate_catalog}")"
  installed_version="$(jq -er '.catalogVersion' <<<"${installed_canonical}")"
  [[ "${parent_hash}" == "${installed_hash}" && "${candidate_version}" -gt "${installed_version}" ]] || return 1
  jq -e --argjson old "${installed_canonical}" '
    def by_id($array; $field): reduce $array[] as $item ({}; .[$item[$field]] = $item);
    (by_id(.builtInCapabilities; "capabilityId")) as $newCapabilities |
    (by_id(.operations; "operationId")) as $newOperations |
    (by_id(.hooks; "hookId")) as $newHooks |
    all($old.builtInCapabilities[]; $newCapabilities[.capabilityId] == .) and
    all($old.operations[]; $newOperations[.operationId] == .) and
    all($old.hooks[]; $newHooks[.hookId] == .) and
    all(.builtInCapabilities[]; .capabilityId | IN("CREATE_DIR_V1","DB_MAINTENANCE_V1","DB_MIGRATION_V1","INSTALL_SECRET_REF_V1","RUN_COMPOSE_PROJECT_V1","SMOKE_HOOK_V1"))
  ' <<<"${candidate_catalog}" >/dev/null
}

validate_foundation_harness_hash() {
  local expected_hash="$1"
  [[ -x "${FOUNDATION_HARNESS}" && ! -L "${FOUNDATION_HARNESS}" ]] || fail "INSTALLED_FOUNDATION_HARNESS_MISSING"
  [[ -f "${FOUNDATION_HARNESS_SQL}" && ! -L "${FOUNDATION_HARNESS_SQL}" ]] || fail "INSTALLED_FOUNDATION_HARNESS_SQL_MISSING"
  local actual_hash
  actual_hash="$(sha256sum "${FOUNDATION_HARNESS}" "${FOUNDATION_HARNESS_SQL}" | awk '{print $1}' | sha256sum | awk '{print $1}')"
  [[ "${actual_hash}" == "${expected_hash}" ]] || \
    fail "INSTALLED_FOUNDATION_HARNESS_HASH_MISMATCH"
}

verify_bundle_signature() {
  local bundle_path="$1" signature_path="$2" public_key="${3:-${PUBLIC_KEY}}"
  openssl pkeyutl -verify -pubin -inkey "${public_key}" -rawin \
    -in "${bundle_path}" -sigfile "${signature_path}" >/dev/null 2>&1
}

validate_schema_sensitive_inventory() {
  local inventory="$1" require_installed_metadata="${2:-false}"
  [[ -f "${inventory}" && ! -L "${inventory}" ]] || {
    fail "SCHEMA_SENSITIVE_PATHS_MISSING:${inventory}"
    return 1
  }
  [[ "$(wc -c < "${inventory}" | tr -d ' ')" -le 16384 ]] || {
    fail "SCHEMA_SENSITIVE_PATHS_TOO_LARGE"
    return 1
  }
  if [[ "${require_installed_metadata}" == true ]]; then
    [[ "$(stat -c '%u:%g:%a' "${inventory}")" == "0:0:444" ]] || {
      fail "INSTALLED_SCHEMA_SENSITIVE_PATHS_METADATA_MISMATCH"
      return 1
    }
  fi
  awk '
    /^[[:space:]]*($|#)/ { next }
    !/^[A-Za-z0-9_.\/-]+$/ || /^\// || /(^|\/)\.\.($|\/)/ || /^-/ { exit 1 }
    { count++ }
    END { if (count == 0) exit 1 }
  ' "${inventory}" || {
    fail "INVALID_SCHEMA_SENSITIVE_PATHS_INVENTORY"
    return 1
  }
}

schema_sensitive_inventory_hash() {
  sha256sum "$1" | awk '{print $1}'
}

validate_schema_sensitive_inventory_agreement() {
  local expected_hash="$1" repository_inventory="$2" installed_inventory="$3"
  local require_installed_metadata="${4:-true}" repository_hash installed_hash
  validate_schema_sensitive_inventory "${repository_inventory}" || return 1
  validate_schema_sensitive_inventory "${installed_inventory}" "${require_installed_metadata}" || return 1
  repository_hash="$(schema_sensitive_inventory_hash "${repository_inventory}")"
  installed_hash="$(schema_sensitive_inventory_hash "${installed_inventory}")"
  [[ "${expected_hash}" == "${repository_hash}" && "${expected_hash}" == "${installed_hash}" ]] || {
    fail "SCHEMA_SENSITIVE_PATHS_HASH_MISMATCH"
    return 1
  }
}

validate_deploy_intent_fields() {
  local bundle_json="$1"
  jq -e '
    (keys | sort) == ([
      "bundleSchemaVersion", "candidateImageDigest", "candidateSha", "capabilityCatalog",
      "capabilityCatalogHash", "deploymentId", "deployIntent", "executorSha256",
      "foundationHarnessSha256", "migrationRollbackMode", "minimumContractVersion",
      "operations", "operatorReason", "publicKeySha256", "requiredCapabilities",
      "requiredHooks", "schemaSensitivePathsSha256", "workflowEvent"
    ] | sort) and
    .bundleSchemaVersion == 2 and .minimumContractVersion == 2 and
    (.workflowEvent | IN("push", "workflow_dispatch")) and
    (.deployIntent | IN("FORWARD", "AUTHORIZED_ROLLBACK")) and
    (.migrationRollbackMode | IN("AUTO_IMAGE_ROLLBACK", "BACKWARD_COMPATIBLE", "ROLL_FORWARD_ONLY")) and
    (.operatorReason | type == "string" and length <= 240 and
      (test("[\u0000-\u001f\u007f]") | not) and
      (test("(?i)(-----BEGIN [A-Z0-9 ]*PRIVATE KEY-----|(?:password|passwd|pwd|secret|token|api[_ -]?key|private[_ -]?key|authorization|credential)\\s*[:=]\\s*\\S+|bearer\\s+[A-Za-z0-9._~+/=-]{8,}|(?:postgres(?:ql)?|jdbc:postgresql|mysql|https?)://[^\\s/:]+:[^\\s/@]+@|(?:gh[pousr]_[A-Za-z0-9]{20,}|github_pat_[A-Za-z0-9_]{20,}|sk-[A-Za-z0-9_-]{20,}))") | not)) and
    .operatorReason == (.operatorReason | gsub("^\\s+|\\s+$"; "")) and
    (.schemaSensitivePathsSha256 | type == "string" and test("^[0-9a-f]{64}$")) and
    (
      (.workflowEvent == "push" and .deployIntent == "FORWARD" and .operatorReason == "" and
        .migrationRollbackMode == "AUTO_IMAGE_ROLLBACK") or
      (.workflowEvent == "workflow_dispatch" and .deployIntent == "AUTHORIZED_ROLLBACK" and
        (.operatorReason | length > 0)) or
      (.workflowEvent == "workflow_dispatch" and .deployIntent == "FORWARD" and
        ((.migrationRollbackMode == "AUTO_IMAGE_ROLLBACK" and .operatorReason == "") or
         (.migrationRollbackMode != "AUTO_IMAGE_ROLLBACK" and (.operatorReason | length > 0))))
    )
  ' <<<"${bundle_json}" >/dev/null || fail "INVALID_DEPLOY_INTENT_FIELDS"
}

validate_signed_bundle() {
  [[ -f "${BUNDLE_PATH}" && -f "${SIGNATURE_PATH}" ]] || fail "bundle or signature is missing"
  [[ -f "${PUBLIC_KEY}" ]] || fail "installed deploy public key is missing"
  [[ ! -L "${BUNDLE_PATH}" && ! -L "${SIGNATURE_PATH}" ]] || fail "bundle inputs must not be symlinks"
  [[ "$(stat -c '%s' "${BUNDLE_PATH}")" -le 65536 && "$(stat -c '%s' "${SIGNATURE_PATH}")" -le 1024 ]] || \
    fail "bundle inputs exceed size limit"

  local bundle_json snapshot_dir snapshot_bundle snapshot_signature snapshot_bundle_size snapshot_signature_size
  snapshot_dir="$(mktemp -d)" || {
    fail "BUNDLE_SNAPSHOT_CREATE_FAILED"
    return 1
  }
  if ! chmod 0700 "${snapshot_dir}"; then
    rm -rf -- "${snapshot_dir}" || true
    fail "BUNDLE_SNAPSHOT_CREATE_FAILED"
    return 1
  fi
  snapshot_bundle="${snapshot_dir}/deploy-bundle.json"
  snapshot_signature="${snapshot_dir}/deploy-bundle.sig"
  if ! command cp --no-dereference -- "${BUNDLE_PATH}" "${snapshot_bundle}" ||
    ! command cp --no-dereference -- "${SIGNATURE_PATH}" "${snapshot_signature}"; then
    rm -rf -- "${snapshot_dir}" || true
    fail "BUNDLE_SNAPSHOT_CREATE_FAILED"
    return 1
  fi
  if [[ ! -f "${snapshot_bundle}" || -L "${snapshot_bundle}" ||
    ! -f "${snapshot_signature}" || -L "${snapshot_signature}" ]]; then
    rm -rf -- "${snapshot_dir}" || true
    fail "BUNDLE_SNAPSHOT_INVALID"
    return 1
  fi
  if ! chmod 0600 "${snapshot_bundle}" "${snapshot_signature}" ||
    ! snapshot_bundle_size="$(stat -c '%s' "${snapshot_bundle}")" ||
    ! snapshot_signature_size="$(stat -c '%s' "${snapshot_signature}")"; then
    rm -rf -- "${snapshot_dir}" || true
    fail "BUNDLE_SNAPSHOT_INVALID"
    return 1
  fi
  if [[ "${snapshot_bundle_size}" -gt 65536 || "${snapshot_signature_size}" -gt 1024 ]]; then
    rm -rf -- "${snapshot_dir}" || true
    fail "bundle inputs exceed size limit"
    return 1
  fi

  if ! bundle_json="$(cat "${snapshot_bundle}"; cat_status=$?; printf x; exit "${cat_status}")"; then
    rm -rf -- "${snapshot_dir}" || true
    fail "BUNDLE_SNAPSHOT_INVALID"
    return 1
  fi
  bundle_json="${bundle_json%x}"
  if ! verify_bundle_signature "${snapshot_bundle}" "${snapshot_signature}"; then
    rm -rf -- "${snapshot_dir}" || true
    fail "INVALID_BUNDLE_SIGNATURE"
    return 1
  fi
  if ! rm -rf -- "${snapshot_dir}"; then
    fail "BUNDLE_SNAPSHOT_CLEANUP_FAILED"
    return 1
  fi
  SIGNED_BUNDLE_JSON="${bundle_json}"

  validate_deploy_intent_fields "${bundle_json}" || return 1

  local candidate_sha minimum_version executor_hash public_key_hash harness_hash self_hash installed_key_hash
  candidate_sha="$(jq -er '.candidateSha' <<<"${bundle_json}")"
  minimum_version="$(jq -er '.minimumContractVersion' <<<"${bundle_json}")"
  CANDIDATE_CATALOG="$(jq -cS '.capabilityCatalog' <<<"${bundle_json}")"
  CANDIDATE_CATALOG_HASH="$(jq -er '.capabilityCatalogHash' <<<"${bundle_json}")"
  executor_hash="$(jq -er '.executorSha256' <<<"${bundle_json}")"
  public_key_hash="$(jq -er '.publicKeySha256' <<<"${bundle_json}")"
  harness_hash="$(jq -er '.foundationHarnessSha256' <<<"${bundle_json}")"
  DEPLOYMENT_ID="$(jq -er '.deploymentId' <<<"${bundle_json}")"
  CANDIDATE_DIGEST="$(jq -er '.candidateImageDigest' <<<"${bundle_json}")"
  WORKFLOW_EVENT="$(jq -er '.workflowEvent' <<<"${bundle_json}")"
  DEPLOY_INTENT="$(jq -er '.deployIntent' <<<"${bundle_json}")"
  OPERATOR_REASON="$(jq -er '.operatorReason' <<<"${bundle_json}")"
  MIGRATION_ROLLBACK_MODE="$(jq -er '.migrationRollbackMode' <<<"${bundle_json}")"
  SIGNED_SCHEMA_SENSITIVE_PATHS_SHA256="$(jq -er '.schemaSensitivePathsSha256' <<<"${bundle_json}")"

  [[ "${candidate_sha}" == "${DEPLOY_SHA}" ]] || fail "BUNDLE_SHA_MISMATCH"
  [[ "${minimum_version}" == "${CONTRACT_VERSION}" ]] || fail "CONTRACT_VERSION_MISMATCH"
  [[ "$(printf '%s' "${CANDIDATE_CATALOG}" | sha256sum | awk '{print $1}')" == "${CANDIDATE_CATALOG_HASH}" ]] || fail "CAPABILITY_CATALOG_HASH_MISMATCH"
  [[ "${DEPLOYMENT_ID}" =~ ^[a-zA-Z0-9._-]{1,96}$ ]] || fail "INVALID_DEPLOYMENT_ID"
  [[ "${CANDIDATE_DIGEST}" =~ ^sha256:[0-9a-f]{64}$ ]] || fail "INVALID_CANDIDATE_DIGEST"

  self_hash="$(sha256sum "$(readlink -f "$0")" | awk '{print $1}')"
  installed_key_hash="$(sha256sum "${PUBLIC_KEY}" | awk '{print $1}')"
  [[ "${executor_hash}" == "${self_hash}" ]] || fail "INSTALLED_EXECUTOR_HASH_MISMATCH"
  [[ "${public_key_hash}" == "${installed_key_hash}" ]] || fail "INSTALLED_PUBLIC_KEY_HASH_MISMATCH"
  validate_foundation_harness_hash "${harness_hash}" || return 1

  local repository_schema_sensitive_paths
  repository_schema_sensitive_paths="$(dirname -- "${BUNDLE_PATH}")/deploy-schema-sensitive-paths-v1.txt"
  validate_schema_sensitive_inventory_agreement \
    "${SIGNED_SCHEMA_SENSITIVE_PATHS_SHA256}" \
    "${repository_schema_sensitive_paths}" \
    "${INSTALLED_SCHEMA_SENSITIVE_PATHS}" || return 1

  validate_typed_operation_set "${bundle_json}" "${CANDIDATE_CATALOG}" || fail "INVALID_TYPED_OPERATION_SET"
  REQUIRED_HOOKS_JSON="$(jq -cS '.requiredHooks' <<<"${bundle_json}")"

  [[ -f "${INSTALLED_CATALOG}" && ! -L "${INSTALLED_CATALOG}" ]] || fail "INSTALLED_CAPABILITY_CATALOG_MISSING"
  local installed_canonical installed_hash
  installed_canonical="$(jq -cS . "${INSTALLED_CATALOG}")"
  installed_hash="$(printf '%s' "${installed_canonical}" | sha256sum | awk '{print $1}')"
  if [[ "${CANDIDATE_CATALOG_HASH}" != "${installed_hash}" ]]; then
    validate_catalog_extension "${installed_canonical}" "${CANDIDATE_CATALOG}" "${installed_hash}" || \
      fail "CAPABILITY_CATALOG_REDEFINITION_OR_FORK"
  fi
}

probe_candidate_operations() {
  local image_reference="${IMAGE_REPOSITORY}@${CANDIDATE_DIGEST}" resolved operation operation_id schema profile slug
  timeout 180 docker pull "${image_reference}" >/dev/null
  resolved="$(timeout 10 docker image inspect --format '{{join .RepoDigests "|"}}' "${image_reference}")"
  [[ "${resolved}" == *"${image_reference}"* ]] || fail "CANDIDATE_DIGEST_MISMATCH"
  while IFS= read -r operation; do
    [[ -n "${operation}" ]] || continue
    operation_id="$(jq -er '.operationId' <<<"${operation}")"
    schema="$(jq -er '.parameterSchemaId' <<<"${operation}")"
    profile="$(jq -er '.profile' <<<"${operation}")"
    slug="$(jq -er '.entrypoint[1]' <<<"${operation}")"
    timeout 30 docker run --rm --network none --read-only --cap-drop ALL --security-opt no-new-privileges=true \
      "${image_reference}" --deploy-operation-probe "${CANDIDATE_CATALOG_HASH}" "${operation_id}" "${schema}" "${profile}" "${slug}" >/dev/null || \
      fail "CANDIDATE_OPERATION_UNSUPPORTED:${operation_id}"
  done < <(required_operation_plan CANDIDATE_HOOK_V1)
}

snapshot_compose_at_revision() {
  local revision="$1" target="$2"
  [[ "${revision}" =~ ^[0-9a-f]{40}$ ]] || return 1
  timeout 30 git -C "${REPO_DIR}" show "${revision}:docker-compose.prod.yml" > "${target}" || return 1
  [[ -s "${target}" ]]
}

validate_production_compose() {
  local candidate_compose
  candidate_compose="$(mktemp)" || fail "CANDIDATE_COMPOSE_SNAPSHOT_FAILED"
  snapshot_compose_at_revision "${DEPLOY_SHA}" "${candidate_compose}" || {
    rm -f "${candidate_compose}"
    fail "CANDIDATE_COMPOSE_SNAPSHOT_FAILED"
    return 1
  }
  bind_image_reference "${IMAGE_REPOSITORY}@${CANDIDATE_DIGEST}"
  if ! timeout 30 docker compose --project-directory "${REPO_DIR}" --env-file "${ENV_FILE}" \
    -f "${candidate_compose}" config --quiet; then
    rm -f "${candidate_compose}"
    fail "PRODUCTION_COMPOSE_DERIVATION_FAILED"
    return 1
  fi
  rm -f "${candidate_compose}"
}

bind_image_reference() {
  local reference="$1"
  export FUKUROU_IMAGE_REFERENCE="${reference}"
  # A saved pre-cutover compose can still read this legacy variable during rollback.
  export FUKUROU_IMAGE_TAG="${reference}"
}

bind_recovery_image_reference() {
  local reference digest_reference
  reference="$(jq -er '.runningContainer.configuredImageReference' "${ROLLBACK_STATE_DIR}/state.json")" || return 1
  if [[ ! "${reference}" =~ ^${IMAGE_REPOSITORY}@sha256:[0-9a-f]{64}$ ]]; then
    digest_reference="$(jq -er --arg prefix "${IMAGE_REPOSITORY}@sha256:" '
      [.runningContainer.repoDigests[]? |
        select(startswith($prefix)) |
        select(.[($prefix | length):] | test("^[0-9a-f]{64}$"))] |
      unique | select(length == 1) | .[0]
    ' "${ROLLBACK_STATE_DIR}/state.json")" || digest_reference=""
    if [[ -n "${digest_reference}" ]]; then
      reference="${digest_reference}"
    elif [[ -z "${reference}" ]]; then
      reference="${IMAGE_REPOSITORY}@${CANDIDATE_DIGEST}"
    else
      return 1
    fi
  fi
  [[ "${reference}" =~ ^${IMAGE_REPOSITORY}@sha256:[0-9a-f]{64}$ ]] || return 1
  bind_image_reference "${reference}"
}

validate_runtime_snapshot() {
  jq -e '
    (.installKind | type == "string") and
    (.captureDbTimestamp | type == "string") and
    (.runtimeConfigVersion | type == "string") and
    (.runtimeConfigHash | type == "string") and
    (.preFilterActive | type == "string") and
    (.foundationCatalogFingerprint | type == "string") and
    (.maintenance | type == "object") and
    (.maintenance.generation | type == "number" and floor == . and . >= 0) and
    (.maintenance.enabled | type == "boolean") and
    (.maintenance.deploymentId | type == "string") and
    (.pidRegistrations | type == "object") and
    (.pidRegistrations.active | type == "number" and floor == . and . >= 0) and
    (.pidRegistrations.total | type == "number" and floor == . and . >= 0)
  ' <<<"$1" >/dev/null
}

read_maintenance_enabled() {
  jq -er '.maintenance.enabled | if type == "boolean" then tostring else error("maintenance.enabled must be boolean") end' <<<"$1"
}

require_initial_state() {
  [[ -d "${REPO_DIR}/.git" ]] || fail "repository checkout is missing"
  [[ -f "${ENV_FILE}" ]] || fail "production environment file is missing"
  [[ -d "${STATE_ROOT}" ]] || fail "deploy state root must be provisioned before executor installation"
  [[ -x "${DB_HELPER}" ]] || fail "installed DB helper is missing"
  [[ -x "${SUPERVISOR_BINARY}" ]] || fail "installed canonical fence codec is missing"
}

load_schema_sensitive_paths() {
  SCHEMA_SENSITIVE_PATHS=()
  local schema_sensitive_path
  while IFS= read -r schema_sensitive_path; do
    [[ -n "${schema_sensitive_path}" ]] || continue
    SCHEMA_SENSITIVE_PATHS[${#SCHEMA_SENSITIVE_PATHS[@]}]="${schema_sensitive_path}"
  done < <(awk 'NF && $1 !~ /^#/' "${INSTALLED_SCHEMA_SENSITIVE_PATHS}")
  [[ "${#SCHEMA_SENSITIVE_PATHS[@]}" -gt 0 ]] || fail "SCHEMA_SENSITIVE_PATHS_EMPTY"
}

classify_actual_schema_sensitive_diff() {
  ACTUAL_SCHEMA_SENSITIVE=false
  [[ "${OBSERVED_FRESH_INSTALL}" == false && "${OBSERVED_CURRENT_REVISION}" != "${DEPLOY_SHA}" ]] || return 0

  load_schema_sensitive_paths || return 1
  if timeout 30 git -C "${REPO_DIR}" diff --quiet \
    "${OBSERVED_CURRENT_REVISION}" "${DEPLOY_SHA}" -- "${SCHEMA_SENSITIVE_PATHS[@]}"; then
    ACTUAL_SCHEMA_SENSITIVE=false
  else
    local diff_status="$?"
    [[ "${diff_status}" == 1 ]] || {
      fail "SCHEMA_SENSITIVE_DIFF_UNAVAILABLE"
      return 1
    }
    ACTUAL_SCHEMA_SENSITIVE=true
  fi
}

validate_migration_rollback_mode() {
  if [[ "${ACTUAL_SCHEMA_SENSITIVE}" == true ]]; then
    case "${MIGRATION_ROLLBACK_MODE}" in
      BACKWARD_COMPATIBLE|ROLL_FORWARD_ONLY) return 0 ;;
      *) fail "SCHEMA_SENSITIVE_MODE_MISMATCH:AUTO_IMAGE_ROLLBACK"; return 1 ;;
    esac
  else
    [[ "${MIGRATION_ROLLBACK_MODE}" == "AUTO_IMAGE_ROLLBACK" ]] || {
      fail "SCHEMA_SENSITIVE_MODE_MISMATCH:NON_SENSITIVE_EXPLICIT_MODE"
      return 1
    }
  fi
}

observe_and_admit_deploy() {
  timeout 180 git -C "${REPO_DIR}" fetch --prune origin +refs/heads/main:refs/remotes/origin/main || {
    fail "REVISION_AUTHORITY_FETCH_FAILED"
    return 1
  }
  timeout 30 git -C "${REPO_DIR}" cat-file -e "${DEPLOY_SHA}^{commit}" || {
    fail "TARGET_REVISION_UNAVAILABLE"
    return 1
  }
  timeout 30 git -C "${REPO_DIR}" merge-base --is-ancestor "${DEPLOY_SHA}" "${MAIN_REF}" || {
    fail "TARGET_REVISION_NOT_ON_MAIN"
    return 1
  }

  local container_id runtime_snapshot install_kind published_state
  container_id="$(inspect_optional_application '{{.Id}}')" || return 1
  OBSERVED_FRESH_INSTALL=false
  OBSERVED_CURRENT_REVISION=""
  if [[ -z "${container_id}" ]]; then
    runtime_snapshot="$(timeout 30 "${DB_HELPER}" snapshot)" || {
      fail "CURRENT_REVISION_DB_EVIDENCE_UNAVAILABLE"
      return 1
    }
    validate_runtime_snapshot "${runtime_snapshot}" || {
      fail "INVALID_RUNTIME_SNAPSHOT"
      return 1
    }
    install_kind="$(jq -er '.installKind' <<<"${runtime_snapshot}")" || {
      fail "INVALID_RUNTIME_SNAPSHOT"
      return 1
    }
    published_state="$(find "${STATE_ROOT}" -xdev -mindepth 1 -maxdepth 1 -type d ! -name '.*' -print -quit)" || {
      fail "DEPLOYMENT_HISTORY_OBSERVATION_FAILED"
      return 1
    }
    if [[ "${install_kind}" == "PRE_FOUNDATION" && -z "${published_state}" ]]; then
      OBSERVED_FRESH_INSTALL=true
    else
      fail "UNKNOWN_CURRENT_REVISION:CONTAINER_MISSING_WITH_PRIOR_INSTALLATION"
      return 1
    fi
  else
    OBSERVED_CURRENT_REVISION="$(inspect_optional_application '{{range .Config.Env}}{{println .}}{{end}}' | \
      awk -F= '$1=="FUKUROU_REVISION"{sub(/^[^=]*=/,"");print;exit}')" || return 1
    [[ "${OBSERVED_CURRENT_REVISION}" =~ ^[0-9a-f]{40}$ ]] || {
      fail "UNKNOWN_CURRENT_REVISION:MALFORMED"
      return 1
    }
    timeout 30 git -C "${REPO_DIR}" cat-file -e "${OBSERVED_CURRENT_REVISION}^{commit}" || {
      fail "UNKNOWN_CURRENT_REVISION:COMMIT_UNAVAILABLE"
      return 1
    }
    timeout 30 git -C "${REPO_DIR}" merge-base --is-ancestor "${OBSERVED_CURRENT_REVISION}" "${MAIN_REF}" || {
      fail "UNKNOWN_CURRENT_REVISION:NOT_ON_MAIN"
      return 1
    }
  fi

  case "${DEPLOY_INTENT}" in
    FORWARD)
      if [[ "${OBSERVED_FRESH_INSTALL}" == false && "${OBSERVED_CURRENT_REVISION}" != "${DEPLOY_SHA}" ]]; then
        timeout 30 git -C "${REPO_DIR}" merge-base --is-ancestor \
          "${OBSERVED_CURRENT_REVISION}" "${DEPLOY_SHA}" || {
          if timeout 30 git -C "${REPO_DIR}" merge-base --is-ancestor "${DEPLOY_SHA}" "${OBSERVED_CURRENT_REVISION}"; then
            fail "FORWARD_REVISION_REGRESSION:current=${OBSERVED_CURRENT_REVISION}:target=${DEPLOY_SHA}"
            return 1
          else
            fail "REVISION_HISTORY_DIVERGED:current=${OBSERVED_CURRENT_REVISION}:target=${DEPLOY_SHA}"
            return 1
          fi
        }
      fi
      ;;
    AUTHORIZED_ROLLBACK)
      [[ "${WORKFLOW_EVENT}" == "workflow_dispatch" && -n "${OPERATOR_REASON}" ]] || {
        fail "INVALID_AUTHORIZED_ROLLBACK_SOURCE"
        return 1
      }
      [[ "${OBSERVED_FRESH_INSTALL}" == false && "${OBSERVED_CURRENT_REVISION}" != "${DEPLOY_SHA}" ]] || {
        fail "AUTHORIZED_ROLLBACK_TARGET_NOT_OLDER"
        return 1
      }
      timeout 30 git -C "${REPO_DIR}" merge-base --is-ancestor \
        "${DEPLOY_SHA}" "${OBSERVED_CURRENT_REVISION}" || {
        fail "AUTHORIZED_ROLLBACK_TARGET_NOT_OLDER"
        return 1
      }
      ;;
    *) fail "INVALID_DEPLOY_INTENT"; return 1 ;;
  esac

  classify_actual_schema_sensitive_diff || return 1
  validate_migration_rollback_mode || return 1
  ACCEPTED_CURRENT_REVISION="${OBSERVED_CURRENT_REVISION}"
  ACCEPTED_TARGET_REVISION="${DEPLOY_SHA}"
}

inspect_optional_application() {
  local format="$1" inspection existing_names
  if inspection="$(timeout 10 docker inspect --format "${format}" fukurou-ktor 2>/dev/null)"; then
    printf '%s\n' "${inspection}"
    return 0
  fi
  existing_names="$(timeout 10 docker container ls -a --format '{{.Names}}')" || {
    fail "APPLICATION_CONTAINER_OBSERVATION_FAILED"
    return 1
  }
  ! grep -Fxq "fukurou-ktor" <<<"${existing_names}" || {
    fail "APPLICATION_CONTAINER_INSPECTION_FAILED"
    return 1
  }
}

capture_rollback_state() {
  local state_dir="${STATE_ROOT}/${DEPLOYMENT_ID}"
  local temporary_dir="${STATE_ROOT}/.${DEPLOYMENT_ID}.tmp.$$"
  [[ ! -e "${state_dir}" && ! -e "${temporary_dir}" ]] || fail "deployment state already exists"

  install -d -o root -g root -m 0700 "${temporary_dir}"
  PENDING_STATE_DIR="${temporary_dir}"

  local previous_sha compose_hash runtime_snapshot install_kind configured_image image_id image_digest revision
  local fence_hash="" fence_bytes="" executor_hash public_key_hash installed_catalog_hash installed_inventory_hash
  if [[ -n "${ACCEPTED_CURRENT_REVISION}" ]]; then
    previous_sha="${ACCEPTED_CURRENT_REVISION}"
  else
    previous_sha="$(timeout 30 git -C "${REPO_DIR}" rev-parse HEAD)"
  fi
  configured_image="$(inspect_optional_application '{{.Config.Image}}')"
  image_id="$(inspect_optional_application '{{.Image}}')"
  image_digest=""
  [[ -z "${image_id}" ]] || image_digest="$(timeout 10 docker image inspect --format '{{join .RepoDigests "|"}}' "${image_id}")"
  revision="$(inspect_optional_application '{{range .Config.Env}}{{println .}}{{end}}' | awk -F= '$1=="FUKUROU_REVISION"{sub(/^[^=]*=/,"");print;exit}')"
  if [[ -n "${ACCEPTED_CURRENT_REVISION}" ]]; then
    [[ "${revision}" == "${ACCEPTED_CURRENT_REVISION}" ]] || fail "CURRENT_REVISION_CHANGED_AFTER_ADMISSION"
  else
    [[ -z "${configured_image}" ]] || fail "CURRENT_REVISION_CHANGED_AFTER_ADMISSION"
  fi
  snapshot_compose_at_revision "${previous_sha}" "${temporary_dir}/docker-compose.prod.yml" || \
    fail "ROLLBACK_COMPOSE_SNAPSHOT_FAILED"
  chown root:root "${temporary_dir}/docker-compose.prod.yml"
  chmod 0600 "${temporary_dir}/docker-compose.prod.yml"
  compose_hash="$(sha256sum "${temporary_dir}/docker-compose.prod.yml" | awk '{print $1}')"
  runtime_snapshot="$(timeout 30 "${DB_HELPER}" snapshot)"
  validate_runtime_snapshot "${runtime_snapshot}" || fail "INVALID_RUNTIME_SNAPSHOT"
  install_kind="$(jq -er '.installKind' <<<"${runtime_snapshot}")"
  [[ "${install_kind}" == "PRE_FOUNDATION" && -z "${configured_image}" ]] && install_kind="FRESH"
  RUNTIME_CONFIG_VERSION="$(jq -er '.runtimeConfigVersion' <<<"${runtime_snapshot}")"
  RUNTIME_CONFIG_HASH="$(jq -er '.runtimeConfigHash' <<<"${runtime_snapshot}")"
  PREFILTER_ACTIVE="$(jq -er '.preFilterActive' <<<"${runtime_snapshot}")"
  FENCE_GENERATION="$(jq -er '.maintenance.generation' <<<"${runtime_snapshot}")"
  MAINTENANCE_ACTIVE="$(read_maintenance_enabled "${runtime_snapshot}")"
  MAINTENANCE_DEPLOYMENT_ID="$(jq -er '.maintenance.deploymentId' <<<"${runtime_snapshot}")"
  TARGET_GENERATION="$((FENCE_GENERATION + 1))"
  [[ "${TARGET_GENERATION}" -le 9223372036854775807 ]] || fail "FENCE_GENERATION_OVERFLOW"
  PREVIOUS_REPO_SHA="${previous_sha}"
  PREVIOUS_IMAGE_DIGEST="${image_digest}"
  INSTALL_KIND="${install_kind}"
  if [[ -f "${FENCE_ROOT}/fence-v1" ]]; then
    fence_bytes="$(base64 -w0 "${FENCE_ROOT}/fence-v1")"
    fence_hash="$(sha256sum "${FENCE_ROOT}/fence-v1" | awk '{print $1}')"
  fi
  executor_hash="$(sha256sum "$(readlink -f "$0")" | awk '{print $1}')"
  public_key_hash="$(sha256sum "${PUBLIC_KEY}" | awk '{print $1}')"
  installed_catalog_hash="$(jq -cS . "${INSTALLED_CATALOG}" | tr -d '\n' | sha256sum | awk '{print $1}')"
  installed_inventory_hash="$(schema_sensitive_inventory_hash "${INSTALLED_SCHEMA_SENSITIVE_PATHS}")"

  jq -n \
    --arg deploymentId "${DEPLOYMENT_ID}" \
    --arg installKind "${install_kind}" \
    --arg captureDbTimestamp "$(jq -er '.captureDbTimestamp' <<<"${runtime_snapshot}")" \
    --arg previousRepoSha "${previous_sha}" \
    --arg composeSourceCommit "${previous_sha}" \
    --arg composeSha256 "${compose_hash}" \
    --arg configuredImageReference "${configured_image}" \
    --arg imageId "${image_id}" \
    --arg imageRepoDigests "${image_digest}" \
    --arg revision "${revision}" \
    --arg runtimeConfigVersion "${RUNTIME_CONFIG_VERSION}" \
    --arg runtimeConfigHash "${RUNTIME_CONFIG_HASH}" \
    --arg preFilterActive "${PREFILTER_ACTIVE}" \
    --argjson generation "${FENCE_GENERATION}" \
    --argjson maintenanceActive "${MAINTENANCE_ACTIVE}" \
    --arg maintenanceDeploymentId "${MAINTENANCE_DEPLOYMENT_ID}" \
    --arg fenceBytesBase64 "${fence_bytes}" \
    --arg fenceSha256 "${fence_hash}" \
    --arg foundationCatalogFingerprint "$(jq -er '.foundationCatalogFingerprint' <<<"${runtime_snapshot}")" \
    --arg executorSha256 "${executor_hash}" \
    --arg publicKeySha256 "${public_key_hash}" \
    --arg capabilityCatalogHash "${installed_catalog_hash}" \
    --arg acceptedCurrentRevision "${ACCEPTED_CURRENT_REVISION}" \
    --arg acceptedTargetRevision "${ACCEPTED_TARGET_REVISION}" \
    --arg candidateImageDigest "${CANDIDATE_DIGEST}" \
    --arg deployIntent "${DEPLOY_INTENT}" \
    --arg operatorReason "${OPERATOR_REASON}" \
    --arg migrationRollbackMode "${MIGRATION_ROLLBACK_MODE}" \
    --arg schemaSensitivePathsSha256 "${installed_inventory_hash}" \
    --argjson schemaSensitive "${ACTUAL_SCHEMA_SENSITIVE}" \
    --argjson pidRegistrations "$(jq -c '.pidRegistrations' <<<"${runtime_snapshot}")" \
    '{stateVersion:2,deploymentId:$deploymentId,installKind:$installKind,captureDbTimestamp:$captureDbTimestamp,previousRepoSha:$previousRepoSha,
      composeSourceCommit:$composeSourceCommit,composeSources:{"docker-compose.prod.yml":$composeSha256},
      runningContainer:{configuredImageReference:$configuredImageReference,imageId:$imageId,repoDigests:($imageRepoDigests|split("|")|map(select(length>0))),revision:$revision},runtimeConfigVersion:$runtimeConfigVersion,
      runtimeConfigHash:$runtimeConfigHash,preFilterActive:$preFilterActive,
      launchMaintenance:{generation:$generation,enabled:$maintenanceActive,deploymentId:$maintenanceDeploymentId},
      launchFence:{bytesBase64:$fenceBytesBase64,sha256:$fenceSha256},foundationCatalogFingerprint:$foundationCatalogFingerprint,
      acceptedDeploy:{currentRevision:$acceptedCurrentRevision,targetRevision:$acceptedTargetRevision,intent:$deployIntent,
        operatorReason:$operatorReason,migrationRollbackMode:$migrationRollbackMode,
        schemaSensitivePathsSha256:$schemaSensitivePathsSha256,schemaSensitive:$schemaSensitive,
        candidateImageDigest:$candidateImageDigest},
      pidRegistrations:$pidRegistrations,installed:{executorSha256:$executorSha256,publicKeySha256:$publicKeySha256,
        capabilityCatalogHash:$capabilityCatalogHash,schemaSensitivePathsSha256:$schemaSensitivePathsSha256}}' \
    > "${temporary_dir}/state.json"
  chmod 0600 "${temporary_dir}/state.json"

  sync -f "${temporary_dir}/docker-compose.prod.yml"
  sync -f "${temporary_dir}/state.json"
  ROLLBACK_STATE_DIR="${temporary_dir}"
  local prepared_details
  prepared_details="$(jq -cS -n \
    --arg currentRevision "${ACCEPTED_CURRENT_REVISION}" \
    --arg targetRevision "${ACCEPTED_TARGET_REVISION}" \
    --arg candidateImageDigest "${CANDIDATE_DIGEST}" \
    --arg intent "${DEPLOY_INTENT}" \
    --arg operatorReason "${OPERATOR_REASON}" \
    --arg migrationRollbackMode "${MIGRATION_ROLLBACK_MODE}" \
    --arg schemaSensitivePathsSha256 "${installed_inventory_hash}" \
    --argjson schemaSensitive "${ACTUAL_SCHEMA_SENSITIVE}" \
    '{forwardBudgetSeconds:1200,recoveryBudgetSeconds:300,currentRevision:$currentRevision,
      targetRevision:$targetRevision,intent:$intent,operatorReason:$operatorReason,
      migrationRollbackMode:$migrationRollbackMode,schemaSensitivePathsSha256:$schemaSensitivePathsSha256,
      schemaSensitive:$schemaSensitive,candidateImageDigest:$candidateImageDigest}')"
  journal_state PREPARED "${prepared_details}"
  ROLLBACK_STATE_DIR="${state_dir}"
  mv "${temporary_dir}" "${state_dir}"
  PENDING_STATE_DIR=""
  sync -f "${STATE_ROOT}"
}

rollback_on_error() {
  local exit_code="$?"
  trap - ERR
  stop_forward_deadline_watchdog
  cleanup_pending_state || true
  if [[ -z "${ROLLBACK_STATE_DIR:-}" || ! -f "${ROLLBACK_STATE_DIR}/journal.jsonl" ]]; then
    echo "deploy-fukurou: stage=${DEPLOY_STAGE:-UNKNOWN} reason=DEPLOYMENT_FAILED_BEFORE_ROLLBACK_CAPTURE" >&2
    exit "${exit_code}"
  fi
  RECOVERY_DEADLINE_BOOTTIME="${RECOVERY_LIMIT_BOOTTIME:-$(( $(boottime_seconds) + 300 ))}"
  (( $(boottime_seconds) < RECOVERY_DEADLINE_BOOTTIME )) || exit "${exit_code}"
  echo "deploy-fukurou: deployment failed; entering durable recovery" >&2
  [[ "${RECOVERY_ALREADY_STARTED:-false}" == true ]] || journal_state RECOVERY_STARTED "{\"failedExitCode\":${exit_code}}" || true
  local origin_state
  origin_state="$(recovery_origin_state "${ROLLBACK_STATE_DIR}/journal.jsonl")"
  load_recovery_policy || {
    echo "deploy-fukurou: RECOVERY_POLICY_EVIDENCE_INVALID" >&2
    exit "${exit_code}"
  }
  if [[ "${MIGRATION_ROLLBACK_MODE}" == ROLL_FORWARD_ONLY ]]; then
    if [[ "${origin_state}" == PREPARED || "${origin_state}" == CAPTURED ]]; then
      journal_state CANDIDATE_ABORTED '{"reason":"roll-forward-only-before-safety-mutation"}' || true
      echo "deploy-fukurou: CANDIDATE_ABORTED_ROLL_FORWARD_ONLY" >&2
      exit "${exit_code}"
    fi

    reassert_recovery_safe_boundary "${origin_state}" || {
      echo "deploy-fukurou: MANUAL_RECOVERY_PENDING_SAFE_BOUNDARY_ROLL_FORWARD_ONLY" >&2
      exit "${exit_code}"
    }
    revoke_active_canary || {
      echo "deploy-fukurou: MANUAL_RECOVERY_PENDING_CANARY_REVOCATION_ROLL_FORWARD_ONLY" >&2
      exit "${exit_code}"
    }
    journal_state MANUAL_RECOVERY_REQUIRED \
      '{"reason":"roll-forward-only-after-safety-mutation","safeBoundaryReestablished":true,"canaryRevoked":true}' || true
    echo "deploy-fukurou: MANUAL_RECOVERY_REQUIRED_ROLL_FORWARD_ONLY" >&2
    exit "${exit_code}"
  fi
  bind_recovery_image_reference || {
    journal_state MANUAL_RECOVERY_REQUIRED '{"reason":"image-reference"}' || true
    echo "deploy-fukurou: MANUAL_RECOVERY_REQUIRED_IMAGE_REFERENCE" >&2
    exit "${exit_code}"
  }
  if [[ "${origin_state}" != PREPARED && "${origin_state}" != CAPTURED ]]; then
    reassert_recovery_safe_boundary "${origin_state}" || {
      echo "deploy-fukurou: MANUAL_RECOVERY_REQUIRED_SAFE_BOUNDARY" >&2
      exit "${exit_code}"
    }
  fi
  revoke_active_canary || { echo "deploy-fukurou: MANUAL_RECOVERY_REQUIRED_CANARY_NAMESPACE" >&2; exit "${exit_code}"; }

  if ! timeout 30 git -C "${REPO_DIR}" checkout --detach "${PREVIOUS_REPO_SHA}" >/dev/null 2>&1; then
    echo "deploy-fukurou: MANUAL_RECOVERY_REQUIRED_REPO" >&2; exit "${exit_code}"
  fi
  if [[ "${INSTALL_KIND}" != "FOUNDATION_V1" ]]; then
    journal_state MANUAL_RECOVERY_REQUIRED "{\"installKind\":\"${INSTALL_KIND}\"}" || true
    echo "deploy-fukurou: MANUAL_RECOVERY_REQUIRED_${INSTALL_KIND}" >&2
    exit "${exit_code}"
  fi

  local previous_reference previous_revision current_snapshot
  previous_reference="$(jq -er '.runningContainer.configuredImageReference' "${ROLLBACK_STATE_DIR}/state.json")"
  [[ "${previous_reference}" =~ ^${IMAGE_REPOSITORY}@sha256:[0-9a-f]{64}$ ]] || \
    previous_reference="${FUKUROU_IMAGE_REFERENCE}"
  [[ "${previous_reference}" =~ ^${IMAGE_REPOSITORY}@sha256:[0-9a-f]{64}$ ]] || {
    journal_state MANUAL_RECOVERY_REQUIRED '{"reason":"previous-digest"}' || true
    echo "deploy-fukurou: MANUAL_RECOVERY_REQUIRED_PREVIOUS_DIGEST" >&2; exit "${exit_code}";
  }
  previous_revision="$(jq -er '.runningContainer.revision | select(type == "string" and length > 0)' \
    "${ROLLBACK_STATE_DIR}/state.json")" || {
    journal_state MANUAL_RECOVERY_REQUIRED '{"reason":"previous-revision"}' || true
    echo "deploy-fukurou: MANUAL_RECOVERY_REQUIRED_PREVIOUS_REVISION" >&2; exit "${exit_code}";
  }
  current_snapshot="$(timeout 30 "${DB_HELPER}" snapshot)" || { echo "deploy-fukurou: MANUAL_RECOVERY_REQUIRED_DB" >&2; exit "${exit_code}"; }
  [[ "$(jq -er '.runtimeConfigVersion' <<<"${current_snapshot}")" == "${RUNTIME_CONFIG_VERSION}" && \
      "$(jq -er '.runtimeConfigHash' <<<"${current_snapshot}")" == "${RUNTIME_CONFIG_HASH}" ]] || {
    journal_state MANUAL_RECOVERY_REQUIRED '{"reason":"runtime-config-cas"}' || true
    echo "deploy-fukurou: RUNTIME_CONFIG_CAS_MISMATCH" >&2; exit "${exit_code}";
  }
  (( $(boottime_seconds) < RECOVERY_DEADLINE_BOOTTIME )) || exit "${exit_code}"
  timeout 45 docker compose --env-file "${ENV_FILE}" -f "${COMPOSE_FILE}" stop -t 30 ktor || exit "${exit_code}"
  assert_application_pid_zero || exit "${exit_code}"
  bind_image_reference "${previous_reference}"
  timeout 120 docker pull "${previous_reference}" >/dev/null || exit "${exit_code}"
  timeout 120 docker compose --env-file "${ENV_FILE}" -f "${ROLLBACK_STATE_DIR}/docker-compose.prod.yml" up -d --no-build || exit "${exit_code}"
  [[ "$(timeout 10 docker inspect --format '{{.Config.Image}}' fukurou-ktor)" == "${previous_reference}" ]] || exit "${exit_code}"
  [[ "$(timeout 10 docker inspect --format '{{range .Config.Env}}{{println .}}{{end}}' fukurou-ktor | awk -F= '$1=="FUKUROU_REVISION"{sub(/^[^=]*=/,"");print;exit}')" == "${previous_revision}" ]] || exit "${exit_code}"
  timeout "${APPLICATION_HEALTH_TIMEOUT}" bash -c 'until docker exec --user 10001 fukurou-ktor curl -fsS http://127.0.0.1:8080/health/live >/dev/null; do sleep 2; done' || exit "${exit_code}"
  timeout 30 "${DB_HELPER}" maintenance-cas "${TARGET_GENERATION}" true "${DEPLOYMENT_ID}" "${TARGET_GENERATION}" false "${DEPLOYMENT_ID}" || exit "${exit_code}"
  if ! enable_restored_runtime; then
    timeout 30 "${DB_HELPER}" maintenance-cas "${TARGET_GENERATION}" false "${DEPLOYMENT_ID}" \
      "${TARGET_GENERATION}" true "${DEPLOYMENT_ID}" || true
    journal_state MANUAL_RECOVERY_REQUIRED "{\"reason\":\"restored-runtime-enable-failed\",\"method\":\"${RESTORED_ENABLE_METHOD}\"}" || true
    echo "deploy-fukurou: MANUAL_RECOVERY_REQUIRED_RESTORED_RUNTIME_ENABLE" >&2
    exit "${exit_code}"
  fi
  if ! timeout "${APPLICATION_HEALTH_TIMEOUT}" bash -c 'until docker exec --user 10001 fukurou-ktor curl -fsS http://127.0.0.1:8080/health/ready >/dev/null; do sleep 2; done'; then
    restore_disabled_after_resume_failure || true
    journal_state MANUAL_RECOVERY_REQUIRED '{"reason":"restored-runtime-readiness-failed"}' || true
    echo "deploy-fukurou: MANUAL_RECOVERY_REQUIRED_RESTORED_RUNTIME_READINESS" >&2
    exit "${exit_code}"
  fi
  prepare_gap_event CLOSE || exit "${exit_code}"
  if ! append_prepared_gap_event; then
    restore_disabled_after_resume_failure || true
    exit "${exit_code}"
  fi
  journal_state ROLLED_BACK "{\"restoredEnable\":\"${RESTORED_ENABLE_METHOD}\"}" || true
  exit "${exit_code}"
}

reassert_recovery_safe_boundary() {
  local origin_state="$1" gap_state active_count child_count
  if request_supervisor DISABLE "${TARGET_GENERATION}" >/dev/null 2>&1; then
    child_count="$(observe_runtime_children)" || return 1
    [[ "${child_count}" == 0 ]] || return 1
  else
    timeout 45 docker compose --env-file "${ENV_FILE}" -f "${ROLLBACK_STATE_DIR}/docker-compose.prod.yml" stop -t 30 ktor
    assert_application_pid_zero
    write_fence_fallback DISABLED_PENDING_DB "${TARGET_GENERATION}"
  fi
  timeout 30 "${DB_HELPER}" ensure-maintenance "${TARGET_GENERATION}" "${DEPLOYMENT_ID}"
  active_count="$(timeout 10 "${DB_HELPER}" active-launch-count)" || return 1
  if [[ "${active_count}" != 0 ]]; then
    timeout 30 "${DB_HELPER}" interrupt-active-launches "${DEPLOYMENT_ID}"
    [[ "$(timeout 10 "${DB_HELPER}" active-launch-count)" == 0 ]] || return 1
  fi
  gap_state="$(timeout 10 "${DB_HELPER}" gap-state "${DEPLOYMENT_ID}")" || return 1
  case "${gap_state}" in
    MISSING)
      if load_prepared_gap_event OPEN; then
        GAP_DEPLOYMENT_ID="${DEPLOYMENT_ID}"
        append_prepared_gap_event
      else
        GAP_DEPLOYMENT_ID="${DEPLOYMENT_ID:0:80}-recovery"
        prepare_gap_event OPEN
        append_prepared_gap_event
      fi
      ;;
    OPEN)
      GAP_DEPLOYMENT_ID="${DEPLOYMENT_ID}"
      ;;
    CLOSED)
      GAP_DEPLOYMENT_ID="${DEPLOYMENT_ID:0:80}-recovery"
      prepare_gap_event OPEN
      append_prepared_gap_event
      ;;
    *) return 1 ;;
  esac
  [[ "$(timeout 10 "${DB_HELPER}" gap-state "${GAP_DEPLOYMENT_ID}")" == OPEN ]] || return 1
}

recovery_origin_state() {
  jq -sr '[.[] | select(.state != "SIGNAL_RECEIVED" and .state != "RECOVERY_STARTED")][-1].state' "$1"
}

load_recovery_policy() {
  local state_file="${ROLLBACK_STATE_DIR}/state.json" journal_file="${ROLLBACK_STATE_DIR}/journal.jsonl"
  local state_version
  state_version="$(jq -er 'if has("stateVersion") then .stateVersion else 1 end' "${state_file}")" || return 1
  if [[ "${state_version}" == 1 ]]; then
    jq -e '(has("stateVersion") | not) and (has("acceptedDeploy") | not)' "${state_file}" >/dev/null || return 1
    jq -e 'select(.version == 1)' < <(head -n 1 "${journal_file}") >/dev/null || return 1
    MIGRATION_ROLLBACK_MODE=AUTO_IMAGE_ROLLBACK
    return 0
  fi
  [[ "${state_version}" == 2 ]] || return 1

  jq -e --slurpfile journal "${journal_file}" '
    .stateVersion == 2 and
    (.acceptedDeploy | keys | sort) == ([
      "candidateImageDigest", "currentRevision", "intent", "migrationRollbackMode",
      "operatorReason", "schemaSensitive", "schemaSensitivePathsSha256", "targetRevision"
    ] | sort) and
    (.acceptedDeploy.currentRevision | type == "string" and (. == "" or test("^[0-9a-f]{40}$"))) and
    (.acceptedDeploy.targetRevision | type == "string" and test("^[0-9a-f]{40}$")) and
    (.acceptedDeploy.intent | IN("FORWARD", "AUTHORIZED_ROLLBACK")) and
    (.acceptedDeploy.operatorReason | type == "string") and
    (.acceptedDeploy.migrationRollbackMode |
      IN("AUTO_IMAGE_ROLLBACK", "BACKWARD_COMPATIBLE", "ROLL_FORWARD_ONLY")) and
    (.acceptedDeploy.schemaSensitivePathsSha256 | type == "string" and test("^[0-9a-f]{64}$")) and
    .acceptedDeploy.schemaSensitivePathsSha256 == .installed.schemaSensitivePathsSha256 and
    (.acceptedDeploy.schemaSensitive | type == "boolean") and
    (.acceptedDeploy.candidateImageDigest | type == "string" and test("^sha256:[0-9a-f]{64}$")) and
    ($journal | length > 0) and $journal[0].version == 2 and $journal[0].state == "PREPARED" and
    $journal[0].details == {
      forwardBudgetSeconds:1200,
      recoveryBudgetSeconds:300,
      currentRevision:.acceptedDeploy.currentRevision,
      targetRevision:.acceptedDeploy.targetRevision,
      intent:.acceptedDeploy.intent,
      operatorReason:.acceptedDeploy.operatorReason,
      migrationRollbackMode:.acceptedDeploy.migrationRollbackMode,
      schemaSensitivePathsSha256:.acceptedDeploy.schemaSensitivePathsSha256,
      schemaSensitive:.acceptedDeploy.schemaSensitive,
      candidateImageDigest:.acceptedDeploy.candidateImageDigest
    }
  ' "${state_file}" >/dev/null || return 1
  MIGRATION_ROLLBACK_MODE="$(jq -er '.acceptedDeploy.migrationRollbackMode' "${state_file}")"
  CANDIDATE_DIGEST="$(jq -er '.acceptedDeploy.candidateImageDigest' "${state_file}")"
}

provision_fence_root() {
  if [[ -e "${FENCE_ROOT}" ]]; then
    [[ -d "${FENCE_ROOT}" && ! -L "${FENCE_ROOT}" ]] || fail "invalid launch fence root"
  else
    install -d -o root -g root -m 0700 "${FENCE_ROOT}"
    sync -f "$(dirname "${FENCE_ROOT}")"
  fi
  chown root:root "${FENCE_ROOT}"
  chmod 0700 "${FENCE_ROOT}"
  record_operation_dispatch LAUNCH_FENCE_ROOT
}

provision_named_secret() {
  install -d -o root -g root -m 0700 "$(dirname "${CANARY_PRIVATE_KEY}")"
  if [[ ! -e "${CANARY_PRIVATE_KEY}" ]]; then
    local temporary_key="${CANARY_PRIVATE_KEY}.tmp.$$"
    openssl genpkey -algorithm ED25519 -out "${temporary_key}"
    chown "${APPLICATION_UID}:${APPLICATION_GID}" "${temporary_key}"
    chmod 0400 "${temporary_key}"
    sync -f "${temporary_key}"
    mv "${temporary_key}" "${CANARY_PRIVATE_KEY}"
    sync -f "$(dirname "${CANARY_PRIVATE_KEY}")"
  fi
  [[ -f "${CANARY_PRIVATE_KEY}" && ! -L "${CANARY_PRIVATE_KEY}" ]] || fail "invalid named signing secret"
  [[ "$(stat -c '%u:%g:%a' "${CANARY_PRIVATE_KEY}")" == "${APPLICATION_UID}:${APPLICATION_GID}:400" ]] || \
    fail "invalid signing secret metadata"

  local temporary_public="${CANARY_PUBLIC_KEY}.tmp.$$"
  openssl pkey -in "${CANARY_PRIVATE_KEY}" -pubout -out "${temporary_public}"
  chown root:root "${temporary_public}"
  chmod 0444 "${temporary_public}"
  sync -f "${temporary_public}"
  mv "${temporary_public}" "${CANARY_PUBLIC_KEY}"
  sync -f "$(dirname "${CANARY_PUBLIC_KEY}")"
  record_operation_dispatch LLM_LAUNCH_SIGNING_KEY_V1
}

request_supervisor() {
  local operation="$1" generation="$2"
  timeout 30 docker exec --user 0 fukurou-ktor "${SUPERVISOR_BINARY}" --control "${operation}" "${generation}" \
    | grep -Fx "ACK ${operation} ${generation}"
}

restored_supervisor_available() {
  timeout 10 docker exec fukurou-ktor test -x "${SUPERVISOR_BINARY}" >/dev/null 2>&1
}

enable_restored_runtime() {
  RESTORED_ENABLE_METHOD=supervisor
  if restored_supervisor_available; then
    request_supervisor ENABLE "${TARGET_GENERATION}" >/dev/null
    return
  fi

  # PRE_FOUNDATION image には supervisor が無く ENABLE を ACK できないため、
  # supervisor の ENABLE と同じ前提（maintenance 解除済み・active launch 0）を
  # executor 側で検証してから fence を ENABLED へ進める。
  RESTORED_ENABLE_METHOD=fence-fallback
  [[ "$(timeout 10 "${DB_HELPER}" active-launch-count)" == 0 ]] || return 1
  write_fence_fallback ENABLED "${TARGET_GENERATION}"
}

assert_application_pid_zero() {
  local inspection existing_names running pid
  if inspection="$(timeout 10 docker inspect --format '{{.State.Running}}|{{.State.Pid}}' fukurou-ktor 2>/dev/null)"; then
    running="${inspection%%|*}"
    pid="${inspection##*|}"
    [[ "${running}" == "false" && "${pid}" == "0" ]] || { fail "APPLICATION_PID_ZERO_NOT_PROVEN"; return 1; }
    return 0
  fi
  existing_names="$(timeout 10 docker container ls -a --format '{{.Names}}')" || {
    fail "APPLICATION_CONTAINER_OBSERVATION_FAILED"
    return 1
  }
  ! grep -Fxq "fukurou-ktor" <<<"${existing_names}" || {
    fail "APPLICATION_CONTAINER_INSPECTION_FAILED"
    return 1
  }
}

observe_runtime_children() {
  local process_table
  if process_table="$(timeout 10 docker top fukurou-ktor -eo pid,uid)"; then
    awk 'NR > 1 && ($2 == "10002" || $2 == "10003") { count++ } END { print count + 0 }' <<<"${process_table}"
    return 0
  fi
  if assert_application_pid_zero; then
    printf '0\n'
    return 0
  fi
  fail "RUNTIME_PROCESS_OBSERVATION_FAILED"
  return 1
}

write_fence_fallback() {
  timeout 30 docker run --rm --network none --read-only --cap-drop ALL \
    --security-opt no-new-privileges=true \
    --mount "type=bind,src=${FENCE_ROOT},dst=/var/lib/fukurou/launch-fence" \
    --entrypoint "${SUPERVISOR_BINARY}" \
    "${IMAGE_REPOSITORY}@${CANDIDATE_DIGEST}" --fence-write "$1" "$2"
}

journal_state() {
  local state="$1" details="${2:-}" target="${ROLLBACK_STATE_DIR}/journal.jsonl"
  [[ -n "${details}" ]] || details='{}'
  local previous_state="" previous_sequence=0 previous_hash="" journal_version=2 first_state=""
  if [[ -f "${target}" ]]; then
    previous_state="$(tail -n 1 "${target}" | jq -er '.state')" || { fail "JOURNAL_CORRUPT"; return 1; }
    previous_sequence="$(tail -n 1 "${target}" | jq -er '.sequence')" || { fail "JOURNAL_CORRUPT"; return 1; }
    previous_hash="$(tail -n 1 "${target}" | jq -er '.payloadHash')" || { fail "JOURNAL_CORRUPT"; return 1; }
    journal_version="$(tail -n 1 "${target}" | jq -er '.version')" || { fail "JOURNAL_CORRUPT"; return 1; }
    first_state="$(head -n 1 "${target}" | jq -er '.state')" || { fail "JOURNAL_CORRUPT"; return 1; }
    if [[ "${previous_state}" == "${state}" ]]; then
      jq -e --argjson details "${details}" '.details == $details' < <(tail -n 1 "${target}") >/dev/null || \
        { fail "JOURNAL_NON_IDEMPOTENT_REPLAY"; return 1; }
      return 0
    fi
  fi
  if [[ "${journal_version}" == 1 && "${first_state}" == CAPTURED ]]; then
    legacy_journal_transition_allowed "${previous_state}" "${state}" || {
      fail "JOURNAL_TRANSITION_REJECTED:${previous_state}:${state}"
      return 1
    }
  elif [[ "${journal_version}" == 1 ]]; then
    v1_current_journal_transition_allowed "${previous_state}" "${state}" || {
      fail "JOURNAL_TRANSITION_REJECTED:${previous_state}:${state}"
      return 1
    }
  else
    [[ "${journal_version}" == 2 ]] && journal_transition_allowed "${previous_state}" "${state}" || {
      fail "JOURNAL_TRANSITION_REJECTED:${previous_state}:${state}"
      return 1
    }
  fi
  local next_sequence=$((previous_sequence + 1))
  local entry="${target}.entry.$$" replacement="${target}.tmp.$$"
  local payload payload_hash
  payload="$(jq -cS -n --arg state "${state}" --arg previousState "${previous_state}" --arg previousHash "${previous_hash}" \
    --argjson version "${journal_version}" \
    --argjson sequence "${next_sequence}" --argjson details "${details}" \
    --arg at "$(timeout 10 "${DB_HELPER}" timestamp 2>/dev/null || date -u +%Y-%m-%dT%H:%M:%S.000000Z)" \
    '{version:$version,sequence:$sequence,previousState:$previousState,previousHash:$previousHash,state:$state,at:$at,details:$details}')"
  payload_hash="$(printf '%s' "${payload}" | sha256sum | awk '{print $1}')"
  jq -cS --arg payloadHash "${payload_hash}" '. + {payloadHash:$payloadHash}' <<<"${payload}" > "${entry}"
  chmod 0600 "${entry}"; sync -f "${entry}"
  if [[ -f "${target}" ]]; then cat "${target}" "${entry}" > "${replacement}"; else cat "${entry}" > "${replacement}"; fi
  chmod 0600 "${replacement}"; sync -f "${replacement}"
  local observed_sequence=0
  [[ ! -f "${target}" ]] || observed_sequence="$(tail -n 1 "${target}" | jq -er '.sequence')"
  [[ "${observed_sequence}" == "${previous_sequence}" ]] || { fail "JOURNAL_EXPECTED_STATE_CAS_FAILED"; return 1; }
  mv "${replacement}" "${target}"; rm -f "${entry}"; sync -f "${ROLLBACK_STATE_DIR}"
}

journal_transition_allowed() {
  case "$1:$2" in
    :PREPARED|PREPARED:CAPTURED|CAPTURED:SAFETY_MUTATION_STARTED|SAFETY_MUTATION_STARTED:LAUNCHES_DISABLED|\
    LAUNCHES_DISABLED:CANDIDATE_HEALTHY|\
    CANDIDATE_HEALTHY:DB_MAINTENANCE_CLEARED|DB_MAINTENANCE_CLEARED:ENABLE_ACKED|\
    ENABLE_ACKED:GAP_CLOSED|GAP_CLOSED:COMPLETE|\
    PREPARED:RECOVERY_STARTED|CAPTURED:RECOVERY_STARTED|SAFETY_MUTATION_STARTED:RECOVERY_STARTED|\
    LAUNCHES_DISABLED:RECOVERY_STARTED|CANDIDATE_HEALTHY:RECOVERY_STARTED|\
    DB_MAINTENANCE_CLEARED:RECOVERY_STARTED|ENABLE_ACKED:RECOVERY_STARTED|GAP_CLOSED:RECOVERY_STARTED|\
    PREPARED:SIGNAL_RECEIVED|CAPTURED:SIGNAL_RECEIVED|SAFETY_MUTATION_STARTED:SIGNAL_RECEIVED|\
    LAUNCHES_DISABLED:SIGNAL_RECEIVED|CANDIDATE_HEALTHY:SIGNAL_RECEIVED|\
    DB_MAINTENANCE_CLEARED:SIGNAL_RECEIVED|ENABLE_ACKED:SIGNAL_RECEIVED|GAP_CLOSED:SIGNAL_RECEIVED|\
    SIGNAL_RECEIVED:RECOVERY_STARTED|RECOVERY_STARTED:ROLLED_BACK|RECOVERY_STARTED:CANDIDATE_ABORTED|\
    RECOVERY_STARTED:MANUAL_RECOVERY_REQUIRED) return 0 ;;
    *) return 1 ;;
  esac
}

v1_current_journal_transition_allowed() {
  case "$1:$2" in
    :PREPARED|PREPARED:CAPTURED|CAPTURED:SAFETY_MUTATION_STARTED|SAFETY_MUTATION_STARTED:LAUNCHES_DISABLED|\
    LAUNCHES_DISABLED:CANDIDATE_HEALTHY|\
    CANDIDATE_HEALTHY:DB_MAINTENANCE_CLEARED|DB_MAINTENANCE_CLEARED:ENABLE_ACKED|\
    ENABLE_ACKED:GAP_CLOSED|GAP_CLOSED:COMPLETE|\
    PREPARED:RECOVERY_STARTED|CAPTURED:RECOVERY_STARTED|SAFETY_MUTATION_STARTED:RECOVERY_STARTED|\
    LAUNCHES_DISABLED:RECOVERY_STARTED|CANDIDATE_HEALTHY:RECOVERY_STARTED|\
    DB_MAINTENANCE_CLEARED:RECOVERY_STARTED|ENABLE_ACKED:RECOVERY_STARTED|GAP_CLOSED:RECOVERY_STARTED|\
    PREPARED:SIGNAL_RECEIVED|CAPTURED:SIGNAL_RECEIVED|SAFETY_MUTATION_STARTED:SIGNAL_RECEIVED|\
    LAUNCHES_DISABLED:SIGNAL_RECEIVED|CANDIDATE_HEALTHY:SIGNAL_RECEIVED|\
    DB_MAINTENANCE_CLEARED:SIGNAL_RECEIVED|ENABLE_ACKED:SIGNAL_RECEIVED|GAP_CLOSED:SIGNAL_RECEIVED|\
    SIGNAL_RECEIVED:RECOVERY_STARTED|RECOVERY_STARTED:ROLLED_BACK|RECOVERY_STARTED:MANUAL_RECOVERY_REQUIRED) return 0 ;;
    *) return 1 ;;
  esac
}

legacy_journal_transition_allowed() {
  case "$1:$2" in
    :CAPTURED|CAPTURED:LAUNCHES_DISABLED|LAUNCHES_DISABLED:CANDIDATE_HEALTHY|\
    CANDIDATE_HEALTHY:DB_MAINTENANCE_CLEARED|DB_MAINTENANCE_CLEARED:ENABLE_ACKED|\
    ENABLE_ACKED:GAP_CLOSED|GAP_CLOSED:COMPLETE|\
    CAPTURED:RECOVERY_STARTED|LAUNCHES_DISABLED:RECOVERY_STARTED|CANDIDATE_HEALTHY:RECOVERY_STARTED|\
    DB_MAINTENANCE_CLEARED:RECOVERY_STARTED|ENABLE_ACKED:RECOVERY_STARTED|GAP_CLOSED:RECOVERY_STARTED|\
    CAPTURED:SIGNAL_RECEIVED|LAUNCHES_DISABLED:SIGNAL_RECEIVED|CANDIDATE_HEALTHY:SIGNAL_RECEIVED|\
    DB_MAINTENANCE_CLEARED:SIGNAL_RECEIVED|ENABLE_ACKED:SIGNAL_RECEIVED|GAP_CLOSED:SIGNAL_RECEIVED|\
    SIGNAL_RECEIVED:RECOVERY_STARTED|RECOVERY_STARTED:ROLLED_BACK|RECOVERY_STARTED:MANUAL_RECOVERY_REQUIRED) return 0 ;;
    *) return 1 ;;
  esac
}

validate_journal_history() {
  local target="$1"
  jq -s -e '
    . as $entries |
    length > 0 and
    all(range(0; $entries | length); . as $index | $entries[$index] as $entry |
      ($entry.version | IN(1, 2)) and $entry.version == $entries[0].version and
      $entry.sequence == ($index + 1) and
      $entry.previousState == (if $index == 0 then "" else $entries[$index - 1].state end) and
      $entry.previousHash == (if $index == 0 then "" else $entries[$index - 1].payloadHash end) and
      ($entry.payloadHash | test("^[0-9a-f]{64}$")))
  ' "${target}" >/dev/null
  local previous_state="" previous_hash="" line canonical observed_hash calculated_hash state journal_format="" version
  while IFS= read -r line; do
    state="$(jq -er '.state' <<<"${line}")"
    version="$(jq -er '.version' <<<"${line}")"
    if [[ -z "${journal_format}" ]]; then
      case "${version}:${state}" in
        1:PREPARED) journal_format=current-v1 ;;
        1:CAPTURED) journal_format=legacy-v1 ;;
        2:PREPARED) journal_format=current-v2 ;;
        *) return 1 ;;
      esac
    fi
    if [[ "${journal_format}" == legacy-v1 ]]; then
      legacy_journal_transition_allowed "${previous_state}" "${state}" || return 1
    elif [[ "${journal_format}" == current-v1 ]]; then
      v1_current_journal_transition_allowed "${previous_state}" "${state}" || return 1
    else
      journal_transition_allowed "${previous_state}" "${state}" || return 1
    fi
    observed_hash="$(jq -er '.payloadHash' <<<"${line}")"
    canonical="$(jq -cS 'del(.payloadHash)' <<<"${line}")"
    calculated_hash="$(printf '%s' "${canonical}" | sha256sum | awk '{print $1}')"
    [[ "${observed_hash}" == "${calculated_hash}" ]] || return 1
    previous_state="${state}"; previous_hash="${observed_hash}"
  done < "${target}"
}

recover_unfinished_deployments() {
  local state_dir journal last_state recovered_state origin_state
  local candidate_deployment_id="${DEPLOYMENT_ID}" candidate_digest="${CANDIDATE_DIGEST}"
  local candidate_migration_rollback_mode="${MIGRATION_ROLLBACK_MODE}"
  shopt -s nullglob
  for journal in "${STATE_ROOT}"/*/journal.jsonl; do
    validate_journal_history "${journal}" || fail "RECOVERY_JOURNAL_CORRUPT:${journal}"
    last_state="$(tail -n 1 "${journal}" | jq -er '.state')" || fail "RECOVERY_JOURNAL_CORRUPT:${journal}"
    [[ "${last_state}" == "COMPLETE" || "${last_state}" == "ROLLED_BACK" || \
       "${last_state}" == "CANDIDATE_ABORTED" || "${last_state}" == "MANUAL_RECOVERY_REQUIRED" ]] && continue

    state_dir="$(dirname "${journal}")"
    [[ -f "${state_dir}/state.json" ]] || fail "RECOVERY_STATE_MISSING:${state_dir}"
    ROLLBACK_STATE_DIR="${state_dir}"
    DEPLOYMENT_ID="$(jq -er '.deploymentId' "${state_dir}/state.json")"
    INSTALL_KIND="$(jq -er '.installKind' "${state_dir}/state.json")"
    PREVIOUS_REPO_SHA="$(jq -er '.previousRepoSha' "${state_dir}/state.json")"
    RUNTIME_CONFIG_VERSION="$(jq -er '.runtimeConfigVersion' "${state_dir}/state.json")"
    RUNTIME_CONFIG_HASH="$(jq -er '.runtimeConfigHash' "${state_dir}/state.json")"
    FENCE_GENERATION="$(jq -er '.launchMaintenance.generation' "${state_dir}/state.json")"
    TARGET_GENERATION="$((FENCE_GENERATION + 1))"
    load_recovery_policy || fail "RECOVERY_POLICY_EVIDENCE_INVALID:${DEPLOYMENT_ID}"

    echo "deploy-fukurou: recovering unfinished deployment ${DEPLOYMENT_ID} from ${last_state}" >&2
    origin_state="$(recovery_origin_state "${journal}")"
    if [[ "${MIGRATION_ROLLBACK_MODE}" == ROLL_FORWARD_ONLY ]]; then
      [[ "${last_state}" != RECOVERY_STARTED ]] || RECOVERY_ALREADY_STARTED=true
      (set +e; trap - ERR; false; rollback_on_error) || true
      RECOVERY_ALREADY_STARTED=false
      recovered_state="$(tail -n 1 "${journal}" | jq -er '.state')" || fail "RECOVERY_JOURNAL_CORRUPT:${journal}"
      case "${origin_state}:${recovered_state}" in
        PREPARED:CANDIDATE_ABORTED|CAPTURED:CANDIDATE_ABORTED|\
        SAFETY_MUTATION_STARTED:MANUAL_RECOVERY_REQUIRED|LAUNCHES_DISABLED:MANUAL_RECOVERY_REQUIRED|\
        CANDIDATE_HEALTHY:MANUAL_RECOVERY_REQUIRED|DB_MAINTENANCE_CLEARED:MANUAL_RECOVERY_REQUIRED|\
        ENABLE_ACKED:MANUAL_RECOVERY_REQUIRED|GAP_CLOSED:MANUAL_RECOVERY_REQUIRED) ;;
        *) fail "ROLL_FORWARD_ONLY_RECOVERY_FAILED:${DEPLOYMENT_ID}:${origin_state}:${recovered_state}" ;;
      esac
      continue
    fi
    bind_recovery_image_reference || fail "RECOVERY_IMAGE_REFERENCE_INVALID:${DEPLOYMENT_ID}"
    if [[ "${origin_state}" == PREPARED || "${origin_state}" == CAPTURED ]]; then
      journal_state RECOVERY_STARTED '{"reason":"startup-captured"}'
      timeout 30 git -C "${REPO_DIR}" checkout --detach "${PREVIOUS_REPO_SHA}" >/dev/null
      journal_state ROLLED_BACK
      continue
    fi
    case "${origin_state}" in
      SAFETY_MUTATION_STARTED|LAUNCHES_DISABLED|CANDIDATE_HEALTHY|DB_MAINTENANCE_CLEARED|ENABLE_ACKED|GAP_CLOSED) ;;
      *) fail "RECOVERY_STATE_UNSUPPORTED:${origin_state}" ;;
    esac
    reassert_recovery_safe_boundary "${origin_state}" || fail "RECOVERY_SAFE_BOUNDARY_UNPROVEN:${DEPLOYMENT_ID}:${origin_state}"
    [[ "${last_state}" != RECOVERY_STARTED ]] || RECOVERY_ALREADY_STARTED=true
    # subshell 内の rollback_on_error は明示呼び出しの1回に限定する。継承 ERR trap を
    # 外さないと `false` で二重起動し、さらに subshell の非ゼロ終了に親の ERR trap が
    # 再発火して、recovery 完了後の executor 本体を終了させる（`|| true` で抑止する）。
    (set +e; trap - ERR; false; rollback_on_error) || true
    RECOVERY_ALREADY_STARTED=false
    recovered_state="$(tail -n 1 "${journal}" | jq -er '.state')" || fail "RECOVERY_JOURNAL_CORRUPT:${journal}"
    [[ "${recovered_state}" == "ROLLED_BACK" ]] || fail "UNFINISHED_DEPLOYMENT_RECOVERY_FAILED:${DEPLOYMENT_ID}"
  done
  shopt -u nullglob
  DEPLOYMENT_ID="${candidate_deployment_id}"
  CANDIDATE_DIGEST="${candidate_digest}"
  MIGRATION_ROLLBACK_MODE="${candidate_migration_rollback_mode}"
  # recovery が束縛した gap 対象を残すと、この後の forward path の OPEN が
  # 旧 deployment の immutable boundary へ衝突する。
  GAP_DEPLOYMENT_ID=""
}

accept_capability_catalog() {
  local installed_hash
  installed_hash="$(jq -cS . "${INSTALLED_CATALOG}" | tr -d '\n' | sha256sum | awk '{print $1}')"
  [[ "${installed_hash}" != "${CANDIDATE_CATALOG_HASH}" ]] || return 0
  install -d -o root -g root -m 0700 "${CATALOG_LEDGER}"
  local ledger_entry="${CATALOG_LEDGER}/${CANDIDATE_CATALOG_HASH}.json" temporary="${INSTALLED_CATALOG}.tmp.$$"
  printf '%s' "${CANDIDATE_CATALOG}" > "${ledger_entry}.tmp"
  chmod 0600 "${ledger_entry}.tmp"; sync -f "${ledger_entry}.tmp"; mv "${ledger_entry}.tmp" "${ledger_entry}"; sync -f "${CATALOG_LEDGER}"
  printf '%s' "${CANDIDATE_CATALOG}" > "${temporary}"
  chown root:root "${temporary}"; chmod 0444 "${temporary}"; sync -f "${temporary}"; mv "${temporary}" "${INSTALLED_CATALOG}"; sync -f "$(dirname "${INSTALLED_CATALOG}")"
}

revoke_active_canary() {
  [[ -n "${ROLLBACK_STATE_DIR:-}" ]] || return 0
  local audit="${ROLLBACK_STATE_DIR}/canary-audit.jsonl" compose="${ROLLBACK_STATE_DIR}/canary-compose.yml"
  if [[ -f "${compose}" ]]; then
    timeout 60 docker compose --env-file "${ENV_FILE}" -p "fukurou-canary-${DEPLOYMENT_ID}" \
      -f "${ROLLBACK_STATE_DIR}/docker-compose.prod.yml" -f "${compose}" \
      down --volumes --remove-orphans >/dev/null 2>&1 || return 1
  fi
  if [[ -f "${audit}" && "$(tail -n 1 "${audit}" | jq -r '.state')" != "REVOKED" ]]; then
    canary_transition "$(tail -n 1 "${audit}" | jq -r '.state')" REVOKED "recovery-revoked"
  fi
  unlink "${ROLLBACK_STATE_DIR}/canary-token.json" "${ROLLBACK_STATE_DIR}/canary-token.sig" 2>/dev/null || true
  sync -f "${ROLLBACK_STATE_DIR}"
}

canary_transition() {
  local expected_state="$1" next_state="$2" result="${3:-}" target="${ROLLBACK_STATE_DIR}/canary-audit.jsonl"
  local current_state="" sequence=0 token_hash="${CANARY_TOKEN_HASH:-}"
  if [[ -f "${target}" ]]; then
    current_state="$(tail -n 1 "${target}" | jq -er '.state')" || { fail "CANARY_JOURNAL_CORRUPT"; return 1; }
    sequence="$(tail -n 1 "${target}" | jq -er '.sequence')" || { fail "CANARY_JOURNAL_CORRUPT"; return 1; }
    [[ -n "${token_hash}" ]] || token_hash="$(tail -n 1 "${target}" | jq -er '.tokenHash')"
  fi
  [[ "${current_state}" == "${expected_state}" ]] || { fail "CANARY_EXPECTED_STATE_CAS_FAILED"; return 1; }
  local entry="${target}.entry.$$" replacement="${target}.tmp.$$"
  jq -cS -n --arg state "${next_state}" --arg previousState "${current_state}" --arg tokenHash "${token_hash}" \
    --arg result "${result}" --argjson sequence "$((sequence + 1))" --argjson at "$(date +%s)" \
    '{version:1,sequence:$sequence,previousState:$previousState,state:$state,tokenHash:$tokenHash,at:$at,result:(if $result=="" then null else $result end)}' > "${entry}"
  chmod 0600 "${entry}"; sync -f "${entry}"
  if [[ -f "${target}" ]]; then cat "${target}" "${entry}" > "${replacement}"; else cat "${entry}" > "${replacement}"; fi
  chmod 0600 "${replacement}"; sync -f "${replacement}"
  local observed_sequence=0
  [[ ! -f "${target}" ]] || observed_sequence="$(tail -n 1 "${target}" | jq -er '.sequence')"
  [[ "${observed_sequence}" == "${sequence}" ]] || { fail "CANARY_EXPECTED_STATE_CAS_FAILED"; return 1; }
  mv "${replacement}" "${target}"; rm -f "${entry}"
  sync -f "${ROLLBACK_STATE_DIR}"
}

write_canary_compose() {
  local token="$1" signature="$2" public_key="$3" output="$4" entrypoint_json="${5:-[\"--canary-preflight\",\"foundation\"]}"
  local canary_project="fukurou-canary-${DEPLOYMENT_ID}"
  local command_json
  command_json="$(jq -c '. + ["/canary-token.json","/canary-token.sig","/canary-public.pem"]' <<<"${entrypoint_json}")"
  jq -nr --arg containerName "${canary_project}-ktor" --arg token "${token}" --arg signature "${signature}" \
    --arg publicKey "${public_key}" --arg digest "${CANDIDATE_DIGEST}" --arg catalogHash "${CANDIDATE_CATALOG_HASH}" \
    --arg commandJson "${command_json}" \
    --argjson entrypoint "${entrypoint_json}" '
      "services:\n  ktor:\n    container_name: \($containerName)\n    restart: \"no\"\n    pids_limit: 64\n    cap_add: !override [SETGID, SETPCAP, SETUID]\n    depends_on: !reset {}\n    environment:\n      DB_URL: null\n      DB_USER: null\n      DB_PASSWORD: null\n      FUKUROU_CANDIDATE_DIGEST: \"\($digest)\"\n      FUKUROU_CANDIDATE_CATALOG_HASH: \"\($catalogHash)\"\n    volumes: !override\n      - type: bind\n        source: \($token)\n        target: /canary-token.json\n        read_only: true\n      - type: bind\n        source: \($signature)\n        target: /canary-token.sig\n        read_only: true\n      - type: bind\n        source: \($publicKey)\n        target: /canary-public.pem\n        read_only: true\n    networks: !override [fixture]\n    command: \($commandJson)\n  postgres:\n    profiles: [production-only]\n  cloudflared:\n    profiles: [production-only]\nnetworks:\n  fixture:\n    internal: true\n"' > "${output}"
}

validate_canary_compose_json() {
  jq -e --arg digest "${CANDIDATE_DIGEST}" --arg catalogHash "${CANDIDATE_CATALOG_HASH}" \
    --arg repository "${IMAGE_REPOSITORY}" '
    (.services | keys) == ["ktor"] and
    .services.ktor.read_only == true and .services.ktor.pids_limit == 64 and
    (.services.ktor.depends_on // {}) == {} and
    (.services.ktor.cap_drop | index("ALL")) != null and
    (.services.ktor.cap_add | sort) == ["SETGID","SETPCAP","SETUID"] and
    ([.services.ktor.environment | to_entries[] | select(.key | startswith("DB_")) | select(.value != null)] | length) == 0 and
    .services.ktor.environment.FUKUROU_CANDIDATE_DIGEST == $digest and
    .services.ktor.environment.FUKUROU_CANDIDATE_CATALOG_HASH == $catalogHash and
    .services.ktor.environment.FUKUROU_LLM_IMAGE_DIGEST == ($repository + "@" + $digest) and
    (.services.ktor.networks | keys) == ["fixture"] and
    .networks.fixture.internal == true and
    (.services.ktor.volumes | length) == 3 and
    all(.services.ktor.volumes[]; .type == "bind" and .read_only == true and
      (.target | IN("/canary-token.json","/canary-token.sig","/canary-public.pem")))
  ' "$1" >/dev/null
}

prepare_gap_event() {
  local boundary="$1"
  local occurred_at gap_id event_id payload payload_hash gap_deployment_id="${GAP_DEPLOYMENT_ID:-${DEPLOYMENT_ID}}"
  occurred_at="$(timeout 10 "${DB_HELPER}" timestamp)"
  gap_id="$(printf 'fukurou-gap-v1:%s' "${gap_deployment_id}" | md5sum | awk '{print substr($1,1,8)"-"substr($1,9,4)"-"substr($1,13,4)"-"substr($1,17,4)"-"substr($1,21,12)}')"
  event_id="$(printf 'fukurou-gap-v1:%s:%s' "${gap_deployment_id}" "${boundary}" | md5sum | awk '{print substr($1,1,8)"-"substr($1,9,4)"-"substr($1,13,4)"-"substr($1,17,4)"-"substr($1,21,12)}')"
  payload="$(jq -cS -n --arg boundary "${boundary}" --arg deploymentId "${gap_deployment_id}" --arg eventId "${event_id}" \
    --arg gapId "${gap_id}" --arg occurredAt "${occurred_at}" \
    '{boundary:$boundary,deploymentId:$deploymentId,eventId:$eventId,gapId:$gapId,occurredAt:$occurredAt,reason:"DEPLOY_MAINTENANCE",version:1}')"
  payload_hash="$(printf '%s' "${payload}" | sha256sum | awk '{print $1}')"
  printf '%s' "${payload}" > "${ROLLBACK_STATE_DIR}/gap-${boundary}.json.tmp"
  chmod 0600 "${ROLLBACK_STATE_DIR}/gap-${boundary}.json.tmp"; sync -f "${ROLLBACK_STATE_DIR}/gap-${boundary}.json.tmp"
  mv "${ROLLBACK_STATE_DIR}/gap-${boundary}.json.tmp" "${ROLLBACK_STATE_DIR}/gap-${boundary}.json"; sync -f "${ROLLBACK_STATE_DIR}"
  GAP_EVENT_DEPLOYMENT_ID="${gap_deployment_id}"; GAP_EVENT_BOUNDARY="${boundary}"
  GAP_EVENT_OCCURRED_AT="${occurred_at}"; GAP_EVENT_PAYLOAD_HASH="${payload_hash}"
}

load_prepared_gap_event() {
  local boundary="$1" prepared payload
  prepared="${ROLLBACK_STATE_DIR}/gap-${boundary}.json"
  [[ -f "${prepared}" ]] || return 1
  jq -e --arg boundary "${boundary}" --arg deploymentId "${DEPLOYMENT_ID}" '
    .version == 1 and .boundary == $boundary and .deploymentId == $deploymentId and
    .reason == "DEPLOY_MAINTENANCE" and
    (.eventId | type == "string" and length > 0) and
    (.gapId | type == "string" and length > 0) and
    (.occurredAt | type == "string" and length > 0)
  ' "${prepared}" >/dev/null || return 1
  payload="$(jq -cS . "${prepared}")" || return 1
  GAP_EVENT_DEPLOYMENT_ID="${DEPLOYMENT_ID}"
  GAP_EVENT_BOUNDARY="${boundary}"
  GAP_EVENT_OCCURRED_AT="$(jq -er '.occurredAt' <<<"${payload}")"
  GAP_EVENT_PAYLOAD_HASH="$(printf '%s' "${payload}" | sha256sum | awk '{print $1}')"
}

append_prepared_gap_event() {
  timeout 30 "${DB_HELPER}" append-gap "${GAP_EVENT_DEPLOYMENT_ID}" "${GAP_EVENT_BOUNDARY}" \
    "${GAP_EVENT_OCCURRED_AT}" "${GAP_EVENT_PAYLOAD_HASH}"
}

restore_disabled_after_resume_failure() {
  request_supervisor DISABLE "${TARGET_GENERATION}" >/dev/null || write_fence_fallback DISABLED_PENDING_DB "${TARGET_GENERATION}"
  timeout 30 "${DB_HELPER}" maintenance-cas "${TARGET_GENERATION}" false "${DEPLOYMENT_ID}" \
    "${TARGET_GENERATION}" true "${DEPLOYMENT_ID}"
  request_supervisor COMMIT "${TARGET_GENERATION}" >/dev/null || write_fence_fallback DISABLED_COMMITTED "${TARGET_GENERATION}"
}

disable_launches() {
  journal_state SAFETY_MUTATION_STARTED
  if ! request_supervisor DISABLE "${TARGET_GENERATION}"; then
    timeout 45 docker compose --env-file "${ENV_FILE}" -f "${COMPOSE_FILE}" stop -t 30 ktor
    assert_application_pid_zero
    write_fence_fallback DISABLED_PENDING_DB "${TARGET_GENERATION}"
  fi

  timeout 60 "${DB_HELPER}" install-foundation
  timeout 300 "${DB_HELPER}" install-indexes
  record_operation_dispatch INSTALL_FOUNDATION_V1
  timeout 30 "${DB_HELPER}" cleanup-terminal-pids >/dev/null
  prepare_gap_event OPEN
  timeout 30 "${DB_HELPER}" maintenance-cas "${FENCE_GENERATION}" "${MAINTENANCE_ACTIVE}" "${MAINTENANCE_DEPLOYMENT_ID}" \
    "${TARGET_GENERATION}" true "${DEPLOYMENT_ID}"
  crash_injection_point AFTER_MAINTENANCE_CAS || return $?
  record_operation_dispatch SET_LAUNCH_MAINTENANCE
  append_prepared_gap_event
  crash_injection_point AFTER_GAP_OPEN_APPEND || return $?
  record_operation_dispatch OPEN_INFRASTRUCTURE_GAP
  if ! request_supervisor COMMIT "${TARGET_GENERATION}"; then
    write_fence_fallback DISABLED_COMMITTED "${TARGET_GENERATION}"
  fi
  journal_state LAUNCHES_DISABLED
}

drain_launches() {
  local natural_deadline=$(( $(boottime_seconds) + 30 ))
  local absolute_deadline=$(( $(boottime_seconds) + 120 ))
  while (( $(boottime_seconds) < natural_deadline )); do
    local child_count reservation_count
    child_count="$(observe_runtime_children)"
    reservation_count="$(timeout 10 "${DB_HELPER}" active-launch-count)" || fail "ACTIVE_LAUNCH_OBSERVATION_FAILED"
    [[ "${child_count}" == "0" && "${reservation_count}" == "0" ]] && return 0
    sleep 5
  done

  timeout 45 docker compose --env-file "${ENV_FILE}" -f "${COMPOSE_FILE}" stop -t 30 ktor
  assert_application_pid_zero
  timeout 30 "${DB_HELPER}" interrupt-active-launches "${DEPLOYMENT_ID}"

  while (( $(boottime_seconds) < absolute_deadline )); do
    local active_count
    active_count="$(timeout 10 "${DB_HELPER}" active-launch-count)" || fail "ACTIVE_LAUNCH_OBSERVATION_FAILED"
    [[ "${active_count}" == "0" ]] && return 0
    sleep 5
  done
  fail "LLM_DRAIN_TIMEOUT"
}

run_candidate_preflight() {
  timeout 180 docker pull "${IMAGE_REPOSITORY}@${CANDIDATE_DIGEST}" >/dev/null
  local resolved_digest
  resolved_digest="$(timeout 10 docker image inspect --format '{{index .RepoDigests 0}}' "${IMAGE_REPOSITORY}@${CANDIDATE_DIGEST}")"
  [[ "${resolved_digest}" == "${IMAGE_REPOSITORY}@${CANDIDATE_DIGEST}" ]] || fail "CANDIDATE_DIGEST_MISMATCH"

  local token="${ROLLBACK_STATE_DIR}/canary-token.json"
  local signature="${ROLLBACK_STATE_DIR}/canary-token.sig"
  local audit="${ROLLBACK_STATE_DIR}/canary-audit.jsonl"
  local nonce issued_at expires_at
  nonce="$(openssl rand -hex 32)"
  issued_at="$(date +%s)"
  expires_at="$((issued_at + 900))"
  jq -cS -n \
    --arg namespaceId "canary-${DEPLOYMENT_ID}" \
    --arg candidateSha "${DEPLOY_SHA}" \
    --arg candidateDigest "${CANDIDATE_DIGEST}" \
    --arg contractHash "${CANDIDATE_CATALOG_HASH}" \
    --arg nonce "${nonce}" \
    --argjson generation "${TARGET_GENERATION}" \
    --argjson issuedAt "${issued_at}" \
    --argjson expiresAt "${expires_at}" \
    --argjson allowedHookIds "${REQUIRED_HOOKS_JSON}" \
    '{profile:"CANARY_ONLY",namespaceId:$namespaceId,generation:$generation,
      allowedHookIds:$allowedHookIds,candidateSha:$candidateSha,
      candidateDigest:$candidateDigest,contractHash:$contractHash,nonce:$nonce,
      issuedAt:$issuedAt,expiresAt:$expiresAt}' > "${token}"
  chown "${APPLICATION_UID}:${APPLICATION_GID}" "${token}"
  chmod 0400 "${token}"
  openssl pkeyutl -sign -rawin -inkey "${CANARY_PRIVATE_KEY}" -in "${token}" -out "${signature}"
  chown "${APPLICATION_UID}:${APPLICATION_GID}" "${signature}"
  chmod 0400 "${signature}"
  local token_hash
  token_hash="$(sha256sum "${token}" | awk '{print $1}')"
  CANARY_TOKEN_HASH="${token_hash}"
  [[ ! -e "${audit}" ]] || fail "CANARY_TOKEN_ALREADY_ISSUED"
  canary_transition "" ISSUED
  canary_transition ISSUED CONSUMED

  local canary_compose="${ROLLBACK_STATE_DIR}/canary-compose.yml" canary_project="fukurou-canary-${DEPLOYMENT_ID}"
  local result="failure"
  local effective_canary="${ROLLBACK_STATE_DIR}/canary-compose.json"
  bind_image_reference "${IMAGE_REPOSITORY}@${CANDIDATE_DIGEST}"
  local hook_entry operation_id entrypoint_json hook_count=0
  while IFS= read -r hook_entry; do
    [[ -n "${hook_entry}" ]] || continue
    hook_count=$((hook_count + 1))
    operation_id="$(jq -er '.operationId' <<<"${hook_entry}")"
    entrypoint_json="$(jq -c '.entrypoint' <<<"${hook_entry}")"
    write_canary_compose "${token}" "${signature}" "${CANARY_PUBLIC_KEY}" "${canary_compose}" "${entrypoint_json}"
    chmod 0600 "${canary_compose}"; sync -f "${canary_compose}"; sync -f "${ROLLBACK_STATE_DIR}"
    timeout 30 docker compose --env-file "${ENV_FILE}" -p "${canary_project}" \
      -f "${COMPOSE_FILE}" -f "${canary_compose}" config --format json > "${effective_canary}" || \
      fail "CANARY_COMPOSE_DERIVATION_FAILED"
    validate_canary_compose_json "${effective_canary}" || fail "CANARY_DENY_OVERLAY_FAILED"
    timeout 180 docker compose --env-file "${ENV_FILE}" -p "${canary_project}" \
      -f "${COMPOSE_FILE}" -f "${canary_compose}" run --rm --no-deps ktor || \
      fail "REQUIRED_HOOK_FAILED:${operation_id}"
    if [[ "${operation_id}" == "FOUNDATION_PREFLIGHT_V1" ]]; then
      FUKUROU_MCP_ROLE_SQL="${FOUNDATION_HARNESS_SQL}" timeout 900 "${FOUNDATION_HARNESS}" --reuse-image \
        "${IMAGE_REPOSITORY}@${CANDIDATE_DIGEST}" || fail "FOUNDATION_LIFECYCLE_CANARY_FAILED"
    fi
    record_operation_dispatch "${operation_id}"
  done < <(required_operation_plan CANDIDATE_HOOK_V1)
  [[ "${hook_count}" -gt 0 ]] || fail "REQUIRED_HOOK_PLAN_EMPTY"
  result="success"
  timeout 60 docker compose --env-file "${ENV_FILE}" -p "${canary_project}" \
    -f "${COMPOSE_FILE}" -f "${canary_compose}" down --volumes --remove-orphans >/dev/null 2>&1 || result="failure"
  canary_transition CONSUMED REVOKED "${result}"
  rm -f "${token}" "${signature}"
  sync -f "${ROLLBACK_STATE_DIR}"
  [[ "${result}" == "success" ]] || fail "FOUNDATION_PREFLIGHT_FAILED"
}

checkout_deploy_sha() {
  timeout 180 git -C "${REPO_DIR}" fetch --prune origin +refs/heads/main:refs/remotes/origin/main
  timeout 30 git -C "${REPO_DIR}" cat-file -e "${DEPLOY_SHA}^{commit}"
  timeout 30 git -C "${REPO_DIR}" merge-base --is-ancestor "${DEPLOY_SHA}" "${MAIN_REF}" || fail "candidate is not on main"
  timeout 30 git -C "${REPO_DIR}" checkout --detach "${DEPLOY_SHA}"
}

deploy_compose() {
  bind_image_reference "${IMAGE_REPOSITORY}@${CANDIDATE_DIGEST}"
  timeout 180 docker pull "${FUKUROU_IMAGE_REFERENCE}" >/dev/null
  [[ "$(timeout 10 docker image inspect --format '{{join .RepoDigests "|"}}' "${FUKUROU_IMAGE_REFERENCE}")" == *"${FUKUROU_IMAGE_REFERENCE}"* ]] || fail "DIGEST_PULL_MISMATCH"
  timeout 120 docker compose --env-file "${ENV_FILE}" -f "${COMPOSE_FILE}" up -d --no-build
  local deadline=$(( $(boottime_seconds) + 120 ))
  while (( $(boottime_seconds) < deadline )); do
    local status; status="$(inspect_optional_application '{{.State.Status}}')"
    [[ "${status}" == "running" ]] && break
    sleep 2
  done
  [[ "$(timeout 10 docker inspect --format '{{.Config.Image}}' fukurou-ktor)" == "${FUKUROU_IMAGE_REFERENCE}" ]] || fail "COMPOSE_CONFIG_IMAGE_MISMATCH"
  [[ "$(timeout 10 docker image inspect --format '{{join .RepoDigests "|"}}' "$(timeout 10 docker inspect --format '{{.Image}}' fukurou-ktor)")" == *"${FUKUROU_IMAGE_REFERENCE}"* ]] || fail "RUNNING_IMAGE_DIGEST_MISMATCH"
  [[ "$(timeout 10 docker inspect --format '{{range .Config.Env}}{{println .}}{{end}}' fukurou-ktor | awk -F= '$1=="FUKUROU_REVISION"{sub(/^[^=]*=/,"");print;exit}')" == "${DEPLOY_SHA}" ]] || fail "RUNNING_REVISION_MISMATCH"
  timeout "${APPLICATION_HEALTH_TIMEOUT}" bash -c 'until docker exec --user 10001 fukurou-ktor curl -fsS http://127.0.0.1:8080/health/live >/dev/null && docker exec --user 10001 fukurou-ktor curl -fsS http://127.0.0.1:8080/health/ready >/dev/null; do sleep 2; done'
  [[ "$(timeout 10 docker exec --user 10001 fukurou-ktor curl -fsS http://127.0.0.1:8080/revision)" == *"${DEPLOY_SHA}"* ]] || fail "HTTP_REVISION_MISMATCH"
  journal_state CANDIDATE_HEALTHY
  record_operation_dispatch PRODUCTION
}

resume_launches() {
  timeout 30 "${DB_HELPER}" maintenance-cas "${TARGET_GENERATION}" true "${DEPLOYMENT_ID}" \
    "${TARGET_GENERATION}" false "${DEPLOYMENT_ID}"
  record_operation_dispatch CLEAR_LAUNCH_MAINTENANCE
  journal_state DB_MAINTENANCE_CLEARED
  crash_injection_point AFTER_DB_MAINTENANCE_CLEAR || return $?
  if ! request_supervisor ENABLE "${TARGET_GENERATION}"; then
    timeout 30 "${DB_HELPER}" maintenance-cas "${TARGET_GENERATION}" false "${DEPLOYMENT_ID}" \
      "${TARGET_GENERATION}" true "${DEPLOYMENT_ID}" || {
        fail "ENABLE_ACK_AND_DB_RESTORE_FAILED"
        return 1
      }
    fail "ENABLE_ACK_FAILED"
    return 1
  fi
  journal_state ENABLE_ACKED
  crash_injection_point AFTER_ENABLE_ACK || return $?
  prepare_gap_event CLOSE
  if ! append_prepared_gap_event; then
    restore_disabled_after_resume_failure || {
      fail "GAP_CLOSE_AND_FAIL_CLOSED_RESTORE_FAILED"
      return 1
    }
    fail "GAP_CLOSE_FAILED"
    return 1
  fi
  crash_injection_point AFTER_GAP_CLOSE_APPEND || return $?
  record_operation_dispatch CLOSE_INFRASTRUCTURE_GAP
  journal_state GAP_CLOSED
  crash_injection_point AFTER_GAP_CLOSE || return $?
  journal_state COMPLETE
}

crash_injection_point() {
  [[ "${FUKUROU_DEPLOY_CRASH_AT:-}" != "$1" ]] || {
    [[ "${FUKUROU_DEPLOY_CRASH_MODE:-KILL}" != RETURN ]] || return 99
    kill -KILL "$$"
  }
}

prune_old_images() {
  local running_image_id
  running_image_id="$(timeout 10 docker inspect --format '{{.Image}}' fukurou-ktor 2>/dev/null || true)"
  mapfile -t image_ids < <(timeout 30 docker images "${IMAGE_REPOSITORY}" --no-trunc --format '{{.CreatedAt}}|{{.ID}}' | sort -r | awk -F'|' '!seen[$2]++ { print $2 }')
  local index=0 image_id
  for image_id in "${image_ids[@]}"; do
    index=$((index + 1))
    [[ "${index}" -le "${IMAGE_RETENTION_COUNT}" || "${image_id}" == "${running_image_id}" ]] && continue
    timeout 30 docker rmi "${image_id}" >/dev/null 2>&1 || true
  done
}

main() {
  if [[ "${1:-}" == "--print-contract-version" && -z "${2:-}" ]]; then
    printf '%s\n' "${CONTRACT_VERSION}"
    exit 0
  fi
  if [[ "${1:-}" == "--print-schema-sensitive-paths-sha256" && -z "${2:-}" ]]; then
    DEPLOY_STAGE=PRINT_SCHEMA_SENSITIVE_PATHS_SHA256
    require_root
    for command in awk sha256sum stat; do require_command "${command}"; done
    validate_schema_sensitive_inventory "${INSTALLED_SCHEMA_SENSITIVE_PATHS}" true
    schema_sensitive_inventory_hash "${INSTALLED_SCHEMA_SENSITIVE_PATHS}"
    exit 0
  fi

  DEPLOY_STAGE=PRECHECK
  PENDING_STATE_DIR=""
  require_root
  for command in awk base64 cat dirname docker find flock git jq md5sum openssl sha256sum stat sync timeout tr wc; do
    require_command "${command}"
  done
  parse_arguments "$@"
  DEPLOY_STAGE=VALIDATE_SIGNED_BUNDLE
  validate_signed_bundle
  DEPLOY_STAGE=REQUIRE_INITIAL_STATE
  require_initial_state

  exec 9>"${LOCK_FILE}"
  flock -n 9 || fail "another deployment is already running"
  DEPLOY_STAGE=CLEANUP_STALE_PENDING_STATES
  cleanup_stale_pending_states

  DEPLOY_START_BOOTTIME="$(boottime_seconds)"
  FORWARD_DEADLINE_BOOTTIME=$((DEPLOY_START_BOOTTIME + 1200))
  RECOVERY_LIMIT_BOOTTIME=$((DEPLOY_START_BOOTTIME + 1500))
  trap rollback_on_error ERR
  trap 'on_signal TERM 143' TERM
  trap 'on_signal INT 130' INT
  trap 'on_signal HUP 129' HUP
  trap 'on_signal DEADLINE 124' USR1
  trap stop_forward_deadline_watchdog EXIT
  start_forward_deadline_watchdog

  DEPLOY_STAGE=RECOVER_UNFINISHED_DEPLOYMENTS
  check_forward_deadline
  recover_unfinished_deployments
  ROLLBACK_STATE_DIR=""
  start_forward_deadline_watchdog
  check_forward_deadline
  DEPLOY_STAGE=OBSERVE_AND_ADMIT_DEPLOY
  observe_and_admit_deploy
  check_forward_deadline
  DEPLOY_STAGE=PROBE_CANDIDATE_OPERATIONS
  probe_candidate_operations
  check_forward_deadline
  DEPLOY_STAGE=VALIDATE_PRODUCTION_COMPOSE
  validate_production_compose
  check_forward_deadline
  DEPLOY_STAGE=CAPTURE_ROLLBACK_STATE
  capture_rollback_state
  DEPLOY_STAGE=PREPARE_DURABLE_JOURNAL
  journal_state CAPTURED
  DEPLOY_STAGE=ACCEPT_CAPABILITY_CATALOG
  accept_capability_catalog
  check_forward_deadline
  DEPLOY_STAGE=PROVISION_FENCE_ROOT
  provision_fence_root
  check_forward_deadline
  DEPLOY_STAGE=PROVISION_NAMED_SECRET
  provision_named_secret
  check_forward_deadline
  DEPLOY_STAGE=DISABLE_LAUNCHES
  disable_launches
  check_forward_deadline
  DEPLOY_STAGE=DRAIN_LAUNCHES
  drain_launches
  check_forward_deadline
  DEPLOY_STAGE=RUN_CANDIDATE_PREFLIGHT
  run_candidate_preflight
  check_forward_deadline
  DEPLOY_STAGE=CHECKOUT_DEPLOY_SHA
  checkout_deploy_sha
  check_forward_deadline
  DEPLOY_STAGE=DEPLOY_COMPOSE
  deploy_compose
  check_forward_deadline
  DEPLOY_STAGE=RESUME_LAUNCHES
  resume_launches
  DEPLOY_STAGE=VERIFY_REQUIRED_OPERATIONS
  verify_required_operations_dispatched
  DEPLOY_STAGE=PRUNE_OLD_IMAGES
  prune_old_images
  DEPLOY_STAGE=COMPLETE
  stop_forward_deadline_watchdog
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
