#!/usr/bin/env bash
set -Eeuo pipefail

readonly CONTRACT_VERSION=1
readonly DEPLOY_ROOT="${FUKUROU_DEPLOY_ROOT:-/srv/fukurou}"
readonly REPO_DIR="${DEPLOY_ROOT}/repo"
readonly ENV_FILE="${DEPLOY_ROOT}/.env"
readonly STATE_ROOT="${DEPLOY_ROOT}/deploy-state"
readonly FENCE_ROOT="${DEPLOY_ROOT}/runtime/launch-fence"
readonly LOCK_FILE="${FUKUROU_DEPLOY_LOCK:-/var/lock/fukurou-deploy.lock}"
readonly COMPOSE_FILE="${REPO_DIR}/docker-compose.prod.yml"
readonly MAIN_REF="${FUKUROU_MAIN_REF:-origin/main}"
readonly IMAGE_REPOSITORY="ghcr.io/matsumo0922/fukurou"
readonly PUBLIC_KEY="${FUKUROU_DEPLOY_PUBLIC_KEY:-/usr/local/share/fukurou/deploy-public-key.pem}"
readonly INSTALLED_CATALOG="${FUKUROU_DEPLOY_CATALOG:-/usr/local/share/fukurou/deploy-capability-catalog-v1.json}"
readonly CATALOG_LEDGER="${FUKUROU_DEPLOY_CATALOG_LEDGER:-${DEPLOY_ROOT}/deploy-catalog-ledger}"
readonly DB_HELPER="${FUKUROU_DEPLOY_DB_HELPER:-/usr/local/libexec/fukurou-deploy-db}"
readonly SUPERVISOR_BINARY="/usr/local/libexec/fukurou-runtime-supervisor"
readonly CANARY_PRIVATE_KEY="${DEPLOY_ROOT}/secrets/llm-launch-ed25519"
readonly CANARY_PUBLIC_KEY="${DEPLOY_ROOT}/secrets/llm-launch-ed25519.pub"
readonly IMAGE_RETENTION_COUNT="${FUKUROU_IMAGE_RETENTION_COUNT:-10}"
readonly APPLICATION_UID=10001
readonly APPLICATION_GID=10001

fail() {
  echo "deploy-fukurou: $*" >&2
  return 1
}

boottime_seconds() {
  local uptime
  IFS=' ' read -r uptime _ < /proc/uptime || fail "CLOCK_BOOTTIME_UNAVAILABLE"
  printf '%s\n' "${uptime%%.*}"
}

on_signal() {
  local signal_name="$1" code="$2"
  SIGNAL_NAME="${signal_name}"
  journal_state SIGNAL_RECEIVED "{\"signal\":\"${signal_name}\"}" 2>/dev/null || true
  (exit "${code}")
  rollback_on_error
}

check_forward_deadline() {
  [[ "$(boottime_seconds)" -lt "${FORWARD_DEADLINE_BOOTTIME}" ]] || fail "FORWARD_DEADLINE_EXCEEDED"
}

usage() {
  echo "Usage: deploy-fukurou --bundle <path> --signature <path> <40-character commit sha>" >&2
}

require_root() {
  [[ "$(id -u)" == "0" ]] || fail "this script must run as root via sudo"
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || fail "required command is unavailable: $1"
}

normalize_sha() {
  [[ "$1" =~ ^[0-9a-fA-F]{40}$ ]] || fail "commit sha must be a 40-character hexadecimal string"
  printf '%s' "$1" | tr 'A-F' 'a-f'
}

parse_arguments() {
  [[ "${1:-}" == "--bundle" && -n "${2:-}" && "${3:-}" == "--signature" && -n "${4:-}" && -n "${5:-}" && -z "${6:-}" ]] || {
    usage
    exit 2
  }
  BUNDLE_PATH="$2"
  SIGNATURE_PATH="$4"
  DEPLOY_SHA="$(normalize_sha "$5")"
}

validate_typed_operation_set() {
  local bundle_json="$1" catalog_json="$2"
  jq -e --argjson catalog "${catalog_json}" '
    def contains_all($actual; $required): all($required[]; . as $item | $actual | index($item) != null);
    def unique_items($items): ($items | unique | length) == ($items | length);
    def baseline_operations: [
      {"capability":"CREATE_DIR_V1","operationId":"LAUNCH_FENCE_ROOT"},
      {"capability":"INSTALL_SECRET_REF_V1","operationId":"LLM_LAUNCH_SIGNING_KEY_V1"},
      {"capability":"DB_MIGRATION_V1","operationId":"INSTALL_FOUNDATION_V1"},
      {"capability":"DB_MAINTENANCE_V1","operationId":"SET_LAUNCH_MAINTENANCE"},
      {"capability":"DB_MAINTENANCE_V1","operationId":"OPEN_INFRASTRUCTURE_GAP"},
      {"capability":"SMOKE_HOOK_V1","operationId":"FOUNDATION_PREFLIGHT_V1"},
      {"capability":"RUN_COMPOSE_PROJECT_V1","operationId":"PRODUCTION"},
      {"capability":"DB_MAINTENANCE_V1","operationId":"CLOSE_INFRASTRUCTURE_GAP"},
      {"capability":"DB_MAINTENANCE_V1","operationId":"CLEAR_LAUNCH_MAINTENANCE"}
    ];
    def baseline_capabilities: [
      "CREATE_DIR_V1", "DB_MAINTENANCE_V1", "DB_MIGRATION_V1",
      "INSTALL_SECRET_REF_V1", "RUN_COMPOSE_PROJECT_V1", "SMOKE_HOOK_V1"
    ];
    .minimumContractVersion == 1 and
    unique_items(.requiredCapabilities) and unique_items(.requiredHooks) and
    unique_items([.operations[].operationId]) and
    contains_all(.requiredCapabilities; baseline_capabilities) and
    contains_all(.requiredHooks; ["FOUNDATION_PREFLIGHT_V1"]) and
    contains_all(.operations; baseline_operations) and
    all(.requiredCapabilities[]; . as $capability | any($catalog.builtInCapabilities[]; .capabilityId == $capability)) and
    all(.requiredHooks[]; . as $hook | any($catalog.hooks[]; .hookId == $hook)) and
    all(.operations[]; . as $operation |
      any($catalog.operations[];
        .operationId == $operation.operationId and .capabilityId == $operation.capability))
  ' <<<"${bundle_json}" >/dev/null
}

validate_catalog_extension() {
  local installed_canonical="$1" candidate_catalog="$2" installed_hash="$3"
  local parent_hash candidate_version installed_version
  parent_hash="$(jq -er '.parentCatalogHash // ""' <<<"${candidate_catalog}")"
  candidate_version="$(jq -er '.catalogVersion' <<<"${candidate_catalog}")"
  installed_version="$(jq -er '.catalogVersion' <<<"${installed_canonical}")"
  [[ "${parent_hash}" == "${installed_hash}" && "${candidate_version}" -gt "${installed_version}" ]] || return 1
  jq -e --argjson old "${installed_canonical}" '
    def by_id($array; $field): reduce $array[] as $item ({}; .[$item[$field]] = $item);
    (by_id(.builtInCapabilities; "capabilityId")) as $newCapabilities |
    (by_id(.operations; "operationId")) as $newOperations |
    (by_id(.hooks; "hookId")) as $newHooks |
    all($old.builtInCapabilities[]; $newCapabilities[.capabilityId] == .) and
    all($old.operations[]; $newOperations[.operationId] == .) and
    all($old.hooks[]; $newHooks[.hookId] == .) and
    all(.builtInCapabilities[]; .capabilityId | IN("CREATE_DIR_V1","DB_MAINTENANCE_V1","DB_MIGRATION_V1","INSTALL_SECRET_REF_V1","RUN_COMPOSE_PROJECT_V1","SMOKE_HOOK_V1"))
  ' <<<"${candidate_catalog}" >/dev/null
}

validate_signed_bundle() {
  [[ -f "${BUNDLE_PATH}" && -f "${SIGNATURE_PATH}" ]] || fail "bundle or signature is missing"
  [[ -f "${PUBLIC_KEY}" ]] || fail "installed deploy public key is missing"
  [[ ! -L "${BUNDLE_PATH}" && ! -L "${SIGNATURE_PATH}" ]] || fail "bundle inputs must not be symlinks"
  [[ "$(stat -c '%s' "${BUNDLE_PATH}")" -le 65536 && "$(stat -c '%s' "${SIGNATURE_PATH}")" -le 1024 ]] || \
    fail "bundle inputs exceed size limit"

  local bundle_json signature_base64
  bundle_json="$(cat "${BUNDLE_PATH}"; printf x)"
  bundle_json="${bundle_json%x}"
  signature_base64="$(base64 -w 0 "${SIGNATURE_PATH}")"

  openssl pkeyutl -verify -pubin -inkey "${PUBLIC_KEY}" -rawin \
    -in <(printf '%s' "${bundle_json}") \
    -sigfile <(printf '%s' "${signature_base64}" | base64 -d) >/dev/null 2>&1 || fail "INVALID_BUNDLE_SIGNATURE"

  local candidate_sha minimum_version executor_hash public_key_hash self_hash installed_key_hash
  candidate_sha="$(jq -er '.candidateSha' <<<"${bundle_json}")"
  minimum_version="$(jq -er '.minimumContractVersion' <<<"${bundle_json}")"
  CANDIDATE_CATALOG="$(jq -cS '.capabilityCatalog' <<<"${bundle_json}")"
  CANDIDATE_CATALOG_HASH="$(jq -er '.capabilityCatalogHash' <<<"${bundle_json}")"
  executor_hash="$(jq -er '.executorSha256' <<<"${bundle_json}")"
  public_key_hash="$(jq -er '.publicKeySha256' <<<"${bundle_json}")"
  DEPLOYMENT_ID="$(jq -er '.deploymentId' <<<"${bundle_json}")"
  CANDIDATE_DIGEST="$(jq -er '.candidateImageDigest' <<<"${bundle_json}")"

  [[ "${candidate_sha}" == "${DEPLOY_SHA}" ]] || fail "BUNDLE_SHA_MISMATCH"
  [[ "${minimum_version}" == "${CONTRACT_VERSION}" ]] || fail "CONTRACT_VERSION_MISMATCH"
  [[ "$(printf '%s' "${CANDIDATE_CATALOG}" | sha256sum | awk '{print $1}')" == "${CANDIDATE_CATALOG_HASH}" ]] || fail "CAPABILITY_CATALOG_HASH_MISMATCH"
  [[ "${DEPLOYMENT_ID}" =~ ^[a-zA-Z0-9._-]{1,96}$ ]] || fail "INVALID_DEPLOYMENT_ID"
  [[ "${CANDIDATE_DIGEST}" =~ ^sha256:[0-9a-f]{64}$ ]] || fail "INVALID_CANDIDATE_DIGEST"

  self_hash="$(sha256sum "$(readlink -f "$0")" | awk '{print $1}')"
  installed_key_hash="$(sha256sum "${PUBLIC_KEY}" | awk '{print $1}')"
  [[ "${executor_hash}" == "${self_hash}" ]] || fail "INSTALLED_EXECUTOR_HASH_MISMATCH"
  [[ "${public_key_hash}" == "${installed_key_hash}" ]] || fail "INSTALLED_PUBLIC_KEY_HASH_MISMATCH"

  validate_typed_operation_set "${bundle_json}" "${CANDIDATE_CATALOG}" || fail "INVALID_TYPED_OPERATION_SET"
  REQUIRED_HOOKS_JSON="$(jq -cS '.requiredHooks' <<<"${bundle_json}")"

  [[ -f "${INSTALLED_CATALOG}" && ! -L "${INSTALLED_CATALOG}" ]] || fail "INSTALLED_CAPABILITY_CATALOG_MISSING"
  local installed_canonical installed_hash
  installed_canonical="$(jq -cS . "${INSTALLED_CATALOG}")"
  installed_hash="$(printf '%s' "${installed_canonical}" | sha256sum | awk '{print $1}')"
  if [[ "${CANDIDATE_CATALOG_HASH}" != "${installed_hash}" ]]; then
    validate_catalog_extension "${installed_canonical}" "${CANDIDATE_CATALOG}" "${installed_hash}" || \
      fail "CAPABILITY_CATALOG_REDEFINITION_OR_FORK"
  fi
}

require_initial_state() {
  [[ -d "${REPO_DIR}/.git" ]] || fail "repository checkout is missing"
  [[ -f "${ENV_FILE}" ]] || fail "production environment file is missing"
  [[ -d "${STATE_ROOT}" ]] || fail "deploy state root must be provisioned before executor installation"
  [[ -x "${DB_HELPER}" ]] || fail "installed DB helper is missing"
  [[ -x "${SUPERVISOR_BINARY}" ]] || fail "installed canonical fence codec is missing"
}

inspect_optional_application() {
  local format="$1" inspection existing_names
  if inspection="$(timeout 10 docker inspect --format "${format}" fukurou-ktor 2>/dev/null)"; then
    printf '%s\n' "${inspection}"
    return 0
  fi
  existing_names="$(timeout 10 docker container ls -a --format '{{.Names}}')" || {
    fail "APPLICATION_CONTAINER_OBSERVATION_FAILED"
    return 1
  }
  ! grep -Fxq "fukurou-ktor" <<<"${existing_names}" || {
    fail "APPLICATION_CONTAINER_INSPECTION_FAILED"
    return 1
  }
}

capture_rollback_state() {
  local state_dir="${STATE_ROOT}/${DEPLOYMENT_ID}"
  local temporary_dir="${STATE_ROOT}/.${DEPLOYMENT_ID}.tmp.$$"
  [[ ! -e "${state_dir}" && ! -e "${temporary_dir}" ]] || fail "deployment state already exists"

  install -d -o root -g root -m 0700 "${temporary_dir}"

  local previous_sha compose_hash runtime_snapshot install_kind configured_image image_id image_digest revision
  local fence_hash="" fence_bytes="" executor_hash public_key_hash installed_catalog_hash
  previous_sha="$(timeout 30 git -C "${REPO_DIR}" rev-parse HEAD)"
  configured_image="$(inspect_optional_application '{{.Config.Image}}')"
  image_id="$(inspect_optional_application '{{.Image}}')"
  image_digest=""
  [[ -z "${image_id}" ]] || image_digest="$(timeout 10 docker image inspect --format '{{join .RepoDigests "|"}}' "${image_id}")"
  revision="$(inspect_optional_application '{{range .Config.Env}}{{println .}}{{end}}' | awk -F= '$1=="FUKUROU_REVISION"{sub(/^[^=]*=/,"");print;exit}')"
  compose_hash="$(sha256sum "${COMPOSE_FILE}" | awk '{print $1}')"
  runtime_snapshot="$(timeout 30 "${DB_HELPER}" snapshot)"
  install_kind="$(jq -er '.installKind' <<<"${runtime_snapshot}")"
  [[ "${install_kind}" == "PRE_FOUNDATION" && -z "${configured_image}" ]] && install_kind="FRESH"
  RUNTIME_CONFIG_VERSION="$(jq -er '.runtimeConfigVersion' <<<"${runtime_snapshot}")"
  RUNTIME_CONFIG_HASH="$(jq -er '.runtimeConfigHash' <<<"${runtime_snapshot}")"
  PREFILTER_ACTIVE="$(jq -er '.preFilterActive' <<<"${runtime_snapshot}")"
  FENCE_GENERATION="$(jq -er '.maintenance.generation' <<<"${runtime_snapshot}")"
  MAINTENANCE_ACTIVE="$(jq -er '.maintenance.enabled' <<<"${runtime_snapshot}")"
  MAINTENANCE_DEPLOYMENT_ID="$(jq -er '.maintenance.deploymentId' <<<"${runtime_snapshot}")"
  TARGET_GENERATION="$((FENCE_GENERATION + 1))"
  [[ "${TARGET_GENERATION}" -le 9223372036854775807 ]] || fail "FENCE_GENERATION_OVERFLOW"
  PREVIOUS_REPO_SHA="${previous_sha}"
  PREVIOUS_IMAGE_DIGEST="${image_digest}"
  INSTALL_KIND="${install_kind}"
  if [[ -f "${FENCE_ROOT}/fence-v1" ]]; then
    fence_bytes="$(base64 -w0 "${FENCE_ROOT}/fence-v1")"
    fence_hash="$(sha256sum "${FENCE_ROOT}/fence-v1" | awk '{print $1}')"
  fi
  executor_hash="$(sha256sum "$(readlink -f "$0")" | awk '{print $1}')"
  public_key_hash="$(sha256sum "${PUBLIC_KEY}" | awk '{print $1}')"
  installed_catalog_hash="$(jq -cS . "${INSTALLED_CATALOG}" | tr -d '\n' | sha256sum | awk '{print $1}')"

  install -o root -g root -m 0600 "${COMPOSE_FILE}" "${temporary_dir}/docker-compose.prod.yml"
  jq -n \
    --arg deploymentId "${DEPLOYMENT_ID}" \
    --arg installKind "${install_kind}" \
    --arg captureDbTimestamp "$(jq -er '.captureDbTimestamp' <<<"${runtime_snapshot}")" \
    --arg previousRepoSha "${previous_sha}" \
    --arg composeSourceCommit "${previous_sha}" \
    --arg composeSha256 "${compose_hash}" \
    --arg configuredImageReference "${configured_image}" \
    --arg imageId "${image_id}" \
    --arg imageRepoDigests "${image_digest}" \
    --arg revision "${revision}" \
    --arg runtimeConfigVersion "${RUNTIME_CONFIG_VERSION}" \
    --arg runtimeConfigHash "${RUNTIME_CONFIG_HASH}" \
    --arg preFilterActive "${PREFILTER_ACTIVE}" \
    --argjson generation "${FENCE_GENERATION}" \
    --argjson maintenanceActive "${MAINTENANCE_ACTIVE}" \
    --arg maintenanceDeploymentId "${MAINTENANCE_DEPLOYMENT_ID}" \
    --arg fenceBytesBase64 "${fence_bytes}" \
    --arg fenceSha256 "${fence_hash}" \
    --arg foundationCatalogFingerprint "$(jq -er '.foundationCatalogFingerprint' <<<"${runtime_snapshot}")" \
    --arg executorSha256 "${executor_hash}" \
    --arg publicKeySha256 "${public_key_hash}" \
    --arg capabilityCatalogHash "${installed_catalog_hash}" \
    --argjson pidRegistrations "$(jq -c '.pidRegistrations' <<<"${runtime_snapshot}")" \
    '{deploymentId:$deploymentId,installKind:$installKind,captureDbTimestamp:$captureDbTimestamp,previousRepoSha:$previousRepoSha,
      composeSourceCommit:$composeSourceCommit,composeSources:{"docker-compose.prod.yml":$composeSha256},
      runningContainer:{configuredImageReference:$configuredImageReference,imageId:$imageId,repoDigests:($imageRepoDigests|split("|")|map(select(length>0))),revision:$revision},runtimeConfigVersion:$runtimeConfigVersion,
      runtimeConfigHash:$runtimeConfigHash,preFilterActive:$preFilterActive,
      launchMaintenance:{generation:$generation,enabled:$maintenanceActive,deploymentId:$maintenanceDeploymentId},
      launchFence:{bytesBase64:$fenceBytesBase64,sha256:$fenceSha256},foundationCatalogFingerprint:$foundationCatalogFingerprint,
      pidRegistrations:$pidRegistrations,installed:{executorSha256:$executorSha256,publicKeySha256:$publicKeySha256,capabilityCatalogHash:$capabilityCatalogHash}}' \
    > "${temporary_dir}/state.json"
  chmod 0600 "${temporary_dir}/state.json"

  sync -f "${temporary_dir}/docker-compose.prod.yml"
  sync -f "${temporary_dir}/state.json"
  mv "${temporary_dir}" "${state_dir}"
  sync -f "${STATE_ROOT}"
  ROLLBACK_STATE_DIR="${state_dir}"
}

rollback_on_error() {
  local exit_code="$?"
  trap - ERR
  if [[ -n "${DEADLINE_WATCHDOG_PID:-}" ]]; then kill "${DEADLINE_WATCHDOG_PID}" 2>/dev/null || true; fi
  local recovery_deadline=$(( $(boottime_seconds) + 300 ))
  echo "deploy-fukurou: deployment failed; entering durable recovery" >&2
  journal_state RECOVERY_STARTED "{\"failedExitCode\":${exit_code}}" || true
  revoke_active_canary || { echo "deploy-fukurou: MANUAL_RECOVERY_REQUIRED_CANARY_NAMESPACE" >&2; exit "${exit_code}"; }

  if ! git -C "${REPO_DIR}" checkout --detach "${PREVIOUS_REPO_SHA}" >/dev/null 2>&1; then
    echo "deploy-fukurou: MANUAL_RECOVERY_REQUIRED_REPO" >&2; exit "${exit_code}"
  fi
  if [[ "${INSTALL_KIND}" != "FOUNDATION_V1" ]]; then
    journal_state MANUAL_RECOVERY_REQUIRED "{\"installKind\":\"${INSTALL_KIND}\"}" || true
    echo "deploy-fukurou: MANUAL_RECOVERY_REQUIRED_${INSTALL_KIND}" >&2
    exit "${exit_code}"
  fi

  local previous_reference current_snapshot
  previous_reference="$(jq -er '.runningContainer.configuredImageReference' "${ROLLBACK_STATE_DIR}/state.json")"
  [[ "${previous_reference}" =~ ^${IMAGE_REPOSITORY}@sha256:[0-9a-f]{64}$ ]] || {
    echo "deploy-fukurou: MANUAL_RECOVERY_REQUIRED_PREVIOUS_DIGEST" >&2; exit "${exit_code}";
  }
  current_snapshot="$(timeout 30 "${DB_HELPER}" snapshot)" || { echo "deploy-fukurou: MANUAL_RECOVERY_REQUIRED_DB" >&2; exit "${exit_code}"; }
  [[ "$(jq -er '.runtimeConfigVersion' <<<"${current_snapshot}")" == "${RUNTIME_CONFIG_VERSION}" && \
      "$(jq -er '.runtimeConfigHash' <<<"${current_snapshot}")" == "${RUNTIME_CONFIG_HASH}" ]] || {
    echo "deploy-fukurou: RUNTIME_CONFIG_CAS_MISMATCH" >&2; exit "${exit_code}";
  }
  (( $(boottime_seconds) < recovery_deadline )) || exit "${exit_code}"
  timeout 45 docker compose --env-file "${ENV_FILE}" -f "${COMPOSE_FILE}" stop -t 30 ktor || exit "${exit_code}"
  assert_application_pid_zero || exit "${exit_code}"
  export FUKUROU_IMAGE_REFERENCE="${previous_reference}"
  timeout 120 docker pull "${previous_reference}" >/dev/null || exit "${exit_code}"
  timeout 120 docker compose --env-file "${ENV_FILE}" -f "${ROLLBACK_STATE_DIR}/docker-compose.prod.yml" up -d --no-build || exit "${exit_code}"
  [[ "$(timeout 10 docker inspect --format '{{.Config.Image}}' fukurou-ktor)" == "${previous_reference}" ]] || exit "${exit_code}"
  [[ "$(timeout 10 docker inspect --format '{{range .Config.Env}}{{println .}}{{end}}' fukurou-ktor | awk -F= '$1=="FUKUROU_REVISION"{sub(/^[^=]*=/,"");print;exit}')" == "${PREVIOUS_REPO_SHA}" ]] || exit "${exit_code}"
  timeout 120 bash -c 'until docker exec --user 10001 fukurou-ktor curl -fsS http://127.0.0.1:8080/health/live >/dev/null && docker exec --user 10001 fukurou-ktor curl -fsS http://127.0.0.1:8080/health/ready >/dev/null; do sleep 2; done' || exit "${exit_code}"
  timeout 30 "${DB_HELPER}" maintenance-cas "${TARGET_GENERATION}" true "${DEPLOYMENT_ID}" "${TARGET_GENERATION}" false "${DEPLOYMENT_ID}" || exit "${exit_code}"
  if ! request_supervisor ENABLE "${TARGET_GENERATION}" >/dev/null; then
    timeout 30 "${DB_HELPER}" maintenance-cas "${TARGET_GENERATION}" false "${DEPLOYMENT_ID}" \
      "${TARGET_GENERATION}" true "${DEPLOYMENT_ID}" || true
    exit "${exit_code}"
  fi
  prepare_gap_event CLOSE || exit "${exit_code}"
  if ! append_prepared_gap_event; then
    restore_disabled_after_resume_failure || true
    exit "${exit_code}"
  fi
  journal_state ROLLED_BACK || true
  exit "${exit_code}"
}

provision_fence_root() {
  if [[ -e "${FENCE_ROOT}" ]]; then
    [[ -d "${FENCE_ROOT}" && ! -L "${FENCE_ROOT}" ]] || fail "invalid launch fence root"
  else
    install -d -o root -g root -m 0700 "${FENCE_ROOT}"
    sync -f "$(dirname "${FENCE_ROOT}")"
  fi
  chown root:root "${FENCE_ROOT}"
  chmod 0700 "${FENCE_ROOT}"
}

provision_named_secret() {
  install -d -o root -g root -m 0700 "$(dirname "${CANARY_PRIVATE_KEY}")"
  if [[ ! -e "${CANARY_PRIVATE_KEY}" ]]; then
    local temporary_key="${CANARY_PRIVATE_KEY}.tmp.$$"
    openssl genpkey -algorithm ED25519 -out "${temporary_key}"
    chown "${APPLICATION_UID}:${APPLICATION_GID}" "${temporary_key}"
    chmod 0400 "${temporary_key}"
    sync -f "${temporary_key}"
    mv "${temporary_key}" "${CANARY_PRIVATE_KEY}"
    sync -f "$(dirname "${CANARY_PRIVATE_KEY}")"
  fi
  [[ -f "${CANARY_PRIVATE_KEY}" && ! -L "${CANARY_PRIVATE_KEY}" ]] || fail "invalid named signing secret"
  [[ "$(stat -c '%u:%g:%a' "${CANARY_PRIVATE_KEY}")" == "${APPLICATION_UID}:${APPLICATION_GID}:400" ]] || \
    fail "invalid signing secret metadata"

  local temporary_public="${CANARY_PUBLIC_KEY}.tmp.$$"
  openssl pkey -in "${CANARY_PRIVATE_KEY}" -pubout -out "${temporary_public}"
  chown root:root "${temporary_public}"
  chmod 0444 "${temporary_public}"
  sync -f "${temporary_public}"
  mv "${temporary_public}" "${CANARY_PUBLIC_KEY}"
  sync -f "$(dirname "${CANARY_PUBLIC_KEY}")"
}

request_supervisor() {
  local operation="$1" generation="$2"
  timeout 30 docker exec --user 0 fukurou-ktor "${SUPERVISOR_BINARY}" --control "${operation}" "${generation}" \
    | grep -Fx "ACK ${operation} ${generation}"
}

assert_application_pid_zero() {
  local inspection existing_names running pid
  if inspection="$(timeout 10 docker inspect --format '{{.State.Running}}|{{.State.Pid}}' fukurou-ktor 2>/dev/null)"; then
    running="${inspection%%|*}"
    pid="${inspection##*|}"
    [[ "${running}" == "false" && "${pid}" == "0" ]] || { fail "APPLICATION_PID_ZERO_NOT_PROVEN"; return 1; }
    return 0
  fi
  existing_names="$(timeout 10 docker container ls -a --format '{{.Names}}')" || {
    fail "APPLICATION_CONTAINER_OBSERVATION_FAILED"
    return 1
  }
  ! grep -Fxq "fukurou-ktor" <<<"${existing_names}" || {
    fail "APPLICATION_CONTAINER_INSPECTION_FAILED"
    return 1
  }
}

observe_runtime_children() {
  local process_table
  process_table="$(timeout 10 docker top fukurou-ktor -eo uid=)" || {
    fail "RUNTIME_PROCESS_OBSERVATION_FAILED"
    return 1
  }
  awk '$1 == "10002" || $1 == "10003" { count++ } END { print count + 0 }' <<<"${process_table}"
}

write_fence_fallback() {
  "${SUPERVISOR_BINARY}" --fence-write "$1" "$2"
}

journal_state() {
  local state="$1" details="${2:-}" target="${ROLLBACK_STATE_DIR}/journal.jsonl"
  [[ -n "${details}" ]] || details='{}'
  local previous_state="" previous_sequence=0
  if [[ -f "${target}" ]]; then
    previous_state="$(tail -n 1 "${target}" | jq -er '.state')" || { fail "JOURNAL_CORRUPT"; return 1; }
    previous_sequence="$(tail -n 1 "${target}" | jq -er '.sequence')" || { fail "JOURNAL_CORRUPT"; return 1; }
  fi
  local next_sequence=$((previous_sequence + 1))
  local entry="${target}.entry.$$" replacement="${target}.tmp.$$"
  jq -cS -n --arg state "${state}" --arg previousState "${previous_state}" \
    --argjson sequence "${next_sequence}" --argjson details "${details}" \
    --arg at "$(timeout 10 "${DB_HELPER}" timestamp 2>/dev/null || date -u +%Y-%m-%dT%H:%M:%S.000000Z)" \
    '{version:1,sequence:$sequence,previousState:$previousState,state:$state,at:$at,details:$details}' > "${entry}"
  chmod 0600 "${entry}"; sync -f "${entry}"
  if [[ -f "${target}" ]]; then cat "${target}" "${entry}" > "${replacement}"; else cat "${entry}" > "${replacement}"; fi
  chmod 0600 "${replacement}"; sync -f "${replacement}"
  local observed_sequence=0
  [[ ! -f "${target}" ]] || observed_sequence="$(tail -n 1 "${target}" | jq -er '.sequence')"
  [[ "${observed_sequence}" == "${previous_sequence}" ]] || { fail "JOURNAL_EXPECTED_STATE_CAS_FAILED"; return 1; }
  mv "${replacement}" "${target}"; rm -f "${entry}"; sync -f "${ROLLBACK_STATE_DIR}"
}

validate_journal_history() {
  local target="$1"
  jq -s -e '
    . as $entries |
    length > 0 and
    all(range(0; $entries | length); . as $index | $entries[$index] as $entry |
      $entry.sequence == ($index + 1) and
      $entry.previousState == (if $index == 0 then "" else $entries[$index - 1].state end))
  ' "${target}" >/dev/null
}

recover_unfinished_deployments() {
  local state_dir journal last_state recovered_state
  local candidate_deployment_id="${DEPLOYMENT_ID}"
  shopt -s nullglob
  for journal in "${STATE_ROOT}"/*/journal.jsonl; do
    validate_journal_history "${journal}" || fail "RECOVERY_JOURNAL_CORRUPT:${journal}"
    last_state="$(tail -n 1 "${journal}" | jq -er '.state')" || fail "RECOVERY_JOURNAL_CORRUPT:${journal}"
    [[ "${last_state}" == "COMPLETE" || "${last_state}" == "ROLLED_BACK" || \
       "${last_state}" == "MANUAL_RECOVERY_REQUIRED" ]] && continue

    state_dir="$(dirname "${journal}")"
    [[ -f "${state_dir}/state.json" ]] || fail "RECOVERY_STATE_MISSING:${state_dir}"
    ROLLBACK_STATE_DIR="${state_dir}"
    DEPLOYMENT_ID="$(jq -er '.deploymentId' "${state_dir}/state.json")"
    INSTALL_KIND="$(jq -er '.installKind' "${state_dir}/state.json")"
    PREVIOUS_REPO_SHA="$(jq -er '.previousRepoSha' "${state_dir}/state.json")"
    RUNTIME_CONFIG_VERSION="$(jq -er '.runtimeConfigVersion' "${state_dir}/state.json")"
    RUNTIME_CONFIG_HASH="$(jq -er '.runtimeConfigHash' "${state_dir}/state.json")"
    FENCE_GENERATION="$(jq -er '.launchMaintenance.generation' "${state_dir}/state.json")"
    TARGET_GENERATION="$((FENCE_GENERATION + 1))"

    echo "deploy-fukurou: recovering unfinished deployment ${DEPLOYMENT_ID} from ${last_state}" >&2
    set +e
    (false; rollback_on_error)
    set -e
    recovered_state="$(tail -n 1 "${journal}" | jq -er '.state')" || fail "RECOVERY_JOURNAL_CORRUPT:${journal}"
    [[ "${recovered_state}" == "ROLLED_BACK" ]] || fail "UNFINISHED_DEPLOYMENT_RECOVERY_FAILED:${DEPLOYMENT_ID}"
  done
  shopt -u nullglob
  DEPLOYMENT_ID="${candidate_deployment_id}"
}

accept_capability_catalog() {
  local installed_hash
  installed_hash="$(jq -cS . "${INSTALLED_CATALOG}" | tr -d '\n' | sha256sum | awk '{print $1}')"
  [[ "${installed_hash}" != "${CANDIDATE_CATALOG_HASH}" ]] || return 0
  install -d -o root -g root -m 0700 "${CATALOG_LEDGER}"
  local ledger_entry="${CATALOG_LEDGER}/${CANDIDATE_CATALOG_HASH}.json" temporary="${INSTALLED_CATALOG}.tmp.$$"
  printf '%s' "${CANDIDATE_CATALOG}" > "${ledger_entry}.tmp"
  chmod 0600 "${ledger_entry}.tmp"; sync -f "${ledger_entry}.tmp"; mv "${ledger_entry}.tmp" "${ledger_entry}"; sync -f "${CATALOG_LEDGER}"
  printf '%s' "${CANDIDATE_CATALOG}" > "${temporary}"
  chown root:root "${temporary}"; chmod 0444 "${temporary}"; sync -f "${temporary}"; mv "${temporary}" "${INSTALLED_CATALOG}"; sync -f "$(dirname "${INSTALLED_CATALOG}")"
}

revoke_active_canary() {
  [[ -n "${ROLLBACK_STATE_DIR:-}" ]] || return 0
  local audit="${ROLLBACK_STATE_DIR}/canary-audit.jsonl" compose="${ROLLBACK_STATE_DIR}/canary-compose.yml"
  if [[ -f "${compose}" ]]; then
    timeout 60 docker compose --env-file "${ENV_FILE}" -p "fukurou-canary-${DEPLOYMENT_ID}" \
      -f "${ROLLBACK_STATE_DIR}/docker-compose.prod.yml" -f "${compose}" \
      down --volumes --remove-orphans >/dev/null 2>&1 || return 1
  fi
  if [[ -f "${audit}" && "$(tail -n 1 "${audit}" | jq -r '.state')" != "REVOKED" ]]; then
    canary_transition "$(tail -n 1 "${audit}" | jq -r '.state')" REVOKED "recovery-revoked"
  fi
  unlink "${ROLLBACK_STATE_DIR}/canary-token.json" "${ROLLBACK_STATE_DIR}/canary-token.sig" 2>/dev/null || true
  sync -f "${ROLLBACK_STATE_DIR}"
}

canary_transition() {
  local expected_state="$1" next_state="$2" result="${3:-}" target="${ROLLBACK_STATE_DIR}/canary-audit.jsonl"
  local current_state="" sequence=0 token_hash="${CANARY_TOKEN_HASH:-}"
  if [[ -f "${target}" ]]; then
    current_state="$(tail -n 1 "${target}" | jq -er '.state')" || { fail "CANARY_JOURNAL_CORRUPT"; return 1; }
    sequence="$(tail -n 1 "${target}" | jq -er '.sequence')" || { fail "CANARY_JOURNAL_CORRUPT"; return 1; }
    [[ -n "${token_hash}" ]] || token_hash="$(tail -n 1 "${target}" | jq -er '.tokenHash')"
  fi
  [[ "${current_state}" == "${expected_state}" ]] || { fail "CANARY_EXPECTED_STATE_CAS_FAILED"; return 1; }
  local entry="${target}.entry.$$" replacement="${target}.tmp.$$"
  jq -cS -n --arg state "${next_state}" --arg previousState "${current_state}" --arg tokenHash "${token_hash}" \
    --arg result "${result}" --argjson sequence "$((sequence + 1))" --argjson at "$(date +%s)" \
    '{version:1,sequence:$sequence,previousState:$previousState,state:$state,tokenHash:$tokenHash,at:$at,result:(if $result=="" then null else $result end)}' > "${entry}"
  chmod 0600 "${entry}"; sync -f "${entry}"
  if [[ -f "${target}" ]]; then cat "${target}" "${entry}" > "${replacement}"; else cat "${entry}" > "${replacement}"; fi
  chmod 0600 "${replacement}"; sync -f "${replacement}"
  local observed_sequence=0
  [[ ! -f "${target}" ]] || observed_sequence="$(tail -n 1 "${target}" | jq -er '.sequence')"
  [[ "${observed_sequence}" == "${sequence}" ]] || { fail "CANARY_EXPECTED_STATE_CAS_FAILED"; return 1; }
  mv "${replacement}" "${target}"; rm -f "${entry}"
  sync -f "${ROLLBACK_STATE_DIR}"
}

write_canary_compose() {
  local token="$1" signature="$2" public_key="$3" output="$4"
  local canary_project="fukurou-canary-${DEPLOYMENT_ID}"
  jq -nr --arg containerName "${canary_project}-ktor" --arg token "${token}" --arg signature "${signature}" \
    --arg publicKey "${public_key}" --arg digest "${CANDIDATE_DIGEST}" --arg catalogHash "${CANDIDATE_CATALOG_HASH}" '
      "services:\n  ktor:\n    container_name: \($containerName)\n    restart: \"no\"\n    pids_limit: 64\n    cap_add: !override [SETGID, SETUID]\n    depends_on: !reset {}\n    environment:\n      DB_URL: null\n      DB_USER: null\n      DB_PASSWORD: null\n      FUKUROU_CANDIDATE_DIGEST: \"\($digest)\"\n      FUKUROU_CANDIDATE_CATALOG_HASH: \"\($catalogHash)\"\n    volumes: !override\n      - type: bind\n        source: \($token)\n        target: /canary-token.json\n        read_only: true\n      - type: bind\n        source: \($signature)\n        target: /canary-token.sig\n        read_only: true\n      - type: bind\n        source: \($publicKey)\n        target: /canary-public.pem\n        read_only: true\n    networks: !override [fixture]\n    command: [\"--canary-preflight\", \"foundation\", \"/canary-token.json\", \"/canary-token.sig\", \"/canary-public.pem\"]\n  postgres:\n    profiles: [production-only]\n  cloudflared:\n    profiles: [production-only]\nnetworks:\n  fixture:\n    internal: true\n"' > "${output}"
}

validate_canary_compose_json() {
  jq -e --arg digest "${CANDIDATE_DIGEST}" --arg catalogHash "${CANDIDATE_CATALOG_HASH}" '
    (.services | keys) == ["ktor"] and
    .services.ktor.read_only == true and .services.ktor.pids_limit == 64 and
    (.services.ktor.depends_on // {}) == {} and
    (.services.ktor.cap_drop | index("ALL")) != null and
    (.services.ktor.cap_add | sort) == ["SETGID","SETUID"] and
    ([.services.ktor.environment | to_entries[] | select(.key | startswith("DB_")) | select(.value != null)] | length) == 0 and
    .services.ktor.environment.FUKUROU_CANDIDATE_DIGEST == $digest and
    .services.ktor.environment.FUKUROU_CANDIDATE_CATALOG_HASH == $catalogHash and
    (.services.ktor.networks | keys) == ["fixture"] and
    .networks.fixture.internal == true and
    (.services.ktor.volumes | length) == 3 and
    all(.services.ktor.volumes[]; .type == "bind" and .read_only == true and
      (.target | IN("/canary-token.json","/canary-token.sig","/canary-public.pem")))
  ' "$1" >/dev/null
}

prepare_gap_event() {
  local boundary="$1"
  local occurred_at gap_id event_id payload payload_hash
  occurred_at="$(timeout 10 "${DB_HELPER}" timestamp)"
  gap_id="$(printf 'fukurou-gap-v1:%s' "${DEPLOYMENT_ID}" | md5sum | awk '{print substr($1,1,8)"-"substr($1,9,4)"-"substr($1,13,4)"-"substr($1,17,4)"-"substr($1,21,12)}')"
  event_id="$(printf 'fukurou-gap-v1:%s:%s' "${DEPLOYMENT_ID}" "${boundary}" | md5sum | awk '{print substr($1,1,8)"-"substr($1,9,4)"-"substr($1,13,4)"-"substr($1,17,4)"-"substr($1,21,12)}')"
  payload="$(jq -cS -n --arg boundary "${boundary}" --arg deploymentId "${DEPLOYMENT_ID}" --arg eventId "${event_id}" \
    --arg gapId "${gap_id}" --arg occurredAt "${occurred_at}" \
    '{boundary:$boundary,deploymentId:$deploymentId,eventId:$eventId,gapId:$gapId,occurredAt:$occurredAt,reason:"DEPLOY_MAINTENANCE",version:1}')"
  payload_hash="$(printf '%s' "${payload}" | sha256sum | awk '{print $1}')"
  printf '%s' "${payload}" > "${ROLLBACK_STATE_DIR}/gap-${boundary}.json.tmp"
  chmod 0600 "${ROLLBACK_STATE_DIR}/gap-${boundary}.json.tmp"; sync -f "${ROLLBACK_STATE_DIR}/gap-${boundary}.json.tmp"
  mv "${ROLLBACK_STATE_DIR}/gap-${boundary}.json.tmp" "${ROLLBACK_STATE_DIR}/gap-${boundary}.json"; sync -f "${ROLLBACK_STATE_DIR}"
  GAP_EVENT_BOUNDARY="${boundary}"; GAP_EVENT_OCCURRED_AT="${occurred_at}"; GAP_EVENT_PAYLOAD_HASH="${payload_hash}"
}

append_prepared_gap_event() {
  timeout 30 "${DB_HELPER}" append-gap "${DEPLOYMENT_ID}" "${GAP_EVENT_BOUNDARY}" "${GAP_EVENT_OCCURRED_AT}" "${GAP_EVENT_PAYLOAD_HASH}"
}

restore_disabled_after_resume_failure() {
  request_supervisor DISABLE "${TARGET_GENERATION}" >/dev/null || write_fence_fallback DISABLED_PENDING_DB "${TARGET_GENERATION}"
  timeout 30 "${DB_HELPER}" maintenance-cas "${TARGET_GENERATION}" false "${DEPLOYMENT_ID}" \
    "${TARGET_GENERATION}" true "${DEPLOYMENT_ID}"
  request_supervisor COMMIT "${TARGET_GENERATION}" >/dev/null || write_fence_fallback DISABLED_COMMITTED "${TARGET_GENERATION}"
}

disable_launches() {
  if ! request_supervisor DISABLE "${TARGET_GENERATION}"; then
    timeout 45 docker compose --env-file "${ENV_FILE}" -f "${COMPOSE_FILE}" stop -t 30 ktor
    assert_application_pid_zero
    write_fence_fallback DISABLED_PENDING_DB "${TARGET_GENERATION}"
  fi

  timeout 60 "${DB_HELPER}" install-foundation
  timeout 300 "${DB_HELPER}" install-indexes
  timeout 30 "${DB_HELPER}" cleanup-terminal-pids >/dev/null
  prepare_gap_event OPEN
  timeout 30 "${DB_HELPER}" maintenance-cas "${FENCE_GENERATION}" "${MAINTENANCE_ACTIVE}" "${MAINTENANCE_DEPLOYMENT_ID}" \
    "${TARGET_GENERATION}" true "${DEPLOYMENT_ID}"
  append_prepared_gap_event
  if ! request_supervisor COMMIT "${TARGET_GENERATION}"; then
    write_fence_fallback DISABLED_COMMITTED "${TARGET_GENERATION}"
  fi
  journal_state LAUNCHES_DISABLED
}

drain_launches() {
  local natural_deadline=$(( $(boottime_seconds) + 30 ))
  local absolute_deadline=$(( $(boottime_seconds) + 120 ))
  while (( $(boottime_seconds) < natural_deadline )); do
    local child_count reservation_count
    child_count="$(observe_runtime_children)"
    reservation_count="$(timeout 10 "${DB_HELPER}" active-launch-count)" || fail "ACTIVE_LAUNCH_OBSERVATION_FAILED"
    [[ "${child_count}" == "0" && "${reservation_count}" == "0" ]] && return 0
    sleep 5
  done

  timeout 45 docker compose --env-file "${ENV_FILE}" -f "${COMPOSE_FILE}" stop -t 30 ktor
  assert_application_pid_zero
  timeout 30 "${DB_HELPER}" interrupt-active-launches "${DEPLOYMENT_ID}"

  while (( $(boottime_seconds) < absolute_deadline )); do
    local active_count
    active_count="$(timeout 10 "${DB_HELPER}" active-launch-count)" || fail "ACTIVE_LAUNCH_OBSERVATION_FAILED"
    [[ "${active_count}" == "0" ]] && return 0
    sleep 5
  done
  fail "LLM_DRAIN_TIMEOUT"
}

run_candidate_preflight() {
  timeout 180 docker pull "${IMAGE_REPOSITORY}@${CANDIDATE_DIGEST}" >/dev/null
  local resolved_digest
  resolved_digest="$(timeout 10 docker image inspect --format '{{index .RepoDigests 0}}' "${IMAGE_REPOSITORY}@${CANDIDATE_DIGEST}")"
  [[ "${resolved_digest}" == "${IMAGE_REPOSITORY}@${CANDIDATE_DIGEST}" ]] || fail "CANDIDATE_DIGEST_MISMATCH"

  local token="${ROLLBACK_STATE_DIR}/canary-token.json"
  local signature="${ROLLBACK_STATE_DIR}/canary-token.sig"
  local audit="${ROLLBACK_STATE_DIR}/canary-audit.jsonl"
  local nonce issued_at expires_at
  nonce="$(openssl rand -hex 32)"
  issued_at="$(date +%s)"
  expires_at="$((issued_at + 900))"
  jq -cS -n \
    --arg namespaceId "canary-${DEPLOYMENT_ID}" \
    --arg candidateSha "${DEPLOY_SHA}" \
    --arg candidateDigest "${CANDIDATE_DIGEST}" \
    --arg contractHash "${CANDIDATE_CATALOG_HASH}" \
    --arg nonce "${nonce}" \
    --argjson generation "${TARGET_GENERATION}" \
    --argjson issuedAt "${issued_at}" \
    --argjson expiresAt "${expires_at}" \
    '{profile:"CANARY_ONLY",namespaceId:$namespaceId,generation:$generation,
      allowedHookIds:["FOUNDATION_PREFLIGHT_V1"],candidateSha:$candidateSha,
      candidateDigest:$candidateDigest,contractHash:$contractHash,nonce:$nonce,
      issuedAt:$issuedAt,expiresAt:$expiresAt}' > "${token}"
  chown "${APPLICATION_UID}:${APPLICATION_GID}" "${token}"
  chmod 0400 "${token}"
  openssl pkeyutl -sign -rawin -inkey "${CANARY_PRIVATE_KEY}" -in "${token}" -out "${signature}"
  chown "${APPLICATION_UID}:${APPLICATION_GID}" "${signature}"
  chmod 0400 "${signature}"
  local token_hash
  token_hash="$(sha256sum "${token}" | awk '{print $1}')"
  CANARY_TOKEN_HASH="${token_hash}"
  [[ ! -e "${audit}" ]] || fail "CANARY_TOKEN_ALREADY_ISSUED"
  canary_transition "" ISSUED
  canary_transition ISSUED CONSUMED

  local canary_compose="${ROLLBACK_STATE_DIR}/canary-compose.yml" canary_project="fukurou-canary-${DEPLOYMENT_ID}"
  write_canary_compose "${token}" "${signature}" "${CANARY_PUBLIC_KEY}" "${canary_compose}"
  chmod 0600 "${canary_compose}"; sync -f "${canary_compose}"; sync -f "${ROLLBACK_STATE_DIR}"
  local result="failure"
  local effective_canary="${ROLLBACK_STATE_DIR}/canary-compose.json"
  export FUKUROU_IMAGE_REFERENCE="${IMAGE_REPOSITORY}@${CANDIDATE_DIGEST}"
  timeout 30 docker compose --env-file "${ENV_FILE}" -p "${canary_project}" \
    -f "${COMPOSE_FILE}" -f "${canary_compose}" config --format json > "${effective_canary}" || \
    fail "CANARY_COMPOSE_DERIVATION_FAILED"
  validate_canary_compose_json "${effective_canary}" || fail "CANARY_DENY_OVERLAY_FAILED"
  if timeout 180 docker compose --env-file "${ENV_FILE}" -p "${canary_project}" \
    -f "${COMPOSE_FILE}" -f "${canary_compose}" run --rm --no-deps ktor; then
    result="success"
  fi
  timeout 60 docker compose --env-file "${ENV_FILE}" -p "${canary_project}" \
    -f "${COMPOSE_FILE}" -f "${canary_compose}" down --volumes --remove-orphans >/dev/null 2>&1 || result="failure"
  canary_transition CONSUMED REVOKED "${result}"
  rm -f "${token}" "${signature}"
  sync -f "${ROLLBACK_STATE_DIR}"
  [[ "${result}" == "success" ]] || fail "FOUNDATION_PREFLIGHT_FAILED"
}

checkout_deploy_sha() {
  timeout 180 git -C "${REPO_DIR}" fetch --prune origin +refs/heads/main:refs/remotes/origin/main
  timeout 30 git -C "${REPO_DIR}" cat-file -e "${DEPLOY_SHA}^{commit}"
  timeout 30 git -C "${REPO_DIR}" merge-base --is-ancestor "${DEPLOY_SHA}" "${MAIN_REF}" || fail "candidate is not on main"
  timeout 30 git -C "${REPO_DIR}" checkout --detach "${DEPLOY_SHA}"
}

deploy_compose() {
  export FUKUROU_IMAGE_REFERENCE="${IMAGE_REPOSITORY}@${CANDIDATE_DIGEST}"
  timeout 180 docker pull "${FUKUROU_IMAGE_REFERENCE}" >/dev/null
  [[ "$(timeout 10 docker image inspect --format '{{join .RepoDigests "|"}}' "${FUKUROU_IMAGE_REFERENCE}")" == *"${FUKUROU_IMAGE_REFERENCE}"* ]] || fail "DIGEST_PULL_MISMATCH"
  timeout 120 docker compose --env-file "${ENV_FILE}" -f "${COMPOSE_FILE}" up -d --no-build
  local deadline=$(( $(boottime_seconds) + 120 ))
  while (( $(boottime_seconds) < deadline )); do
    local status; status="$(inspect_optional_application '{{.State.Status}}')"
    [[ "${status}" == "running" ]] && break
    sleep 2
  done
  [[ "$(timeout 10 docker inspect --format '{{.Config.Image}}' fukurou-ktor)" == "${FUKUROU_IMAGE_REFERENCE}" ]] || fail "COMPOSE_CONFIG_IMAGE_MISMATCH"
  [[ "$(timeout 10 docker image inspect --format '{{join .RepoDigests "|"}}' "$(timeout 10 docker inspect --format '{{.Image}}' fukurou-ktor)")" == *"${FUKUROU_IMAGE_REFERENCE}"* ]] || fail "RUNNING_IMAGE_DIGEST_MISMATCH"
  [[ "$(timeout 10 docker inspect --format '{{range .Config.Env}}{{println .}}{{end}}' fukurou-ktor | awk -F= '$1=="FUKUROU_REVISION"{sub(/^[^=]*=/,"");print;exit}')" == "${DEPLOY_SHA}" ]] || fail "RUNNING_REVISION_MISMATCH"
  timeout 120 bash -c 'until docker exec --user 10001 fukurou-ktor curl -fsS http://127.0.0.1:8080/health/live >/dev/null && docker exec --user 10001 fukurou-ktor curl -fsS http://127.0.0.1:8080/health/ready >/dev/null; do sleep 2; done'
  [[ "$(timeout 10 docker exec --user 10001 fukurou-ktor curl -fsS http://127.0.0.1:8080/revision)" == *"${DEPLOY_SHA}"* ]] || fail "HTTP_REVISION_MISMATCH"
  journal_state CANDIDATE_HEALTHY
}

resume_launches() {
  timeout 30 "${DB_HELPER}" maintenance-cas "${TARGET_GENERATION}" true "${DEPLOYMENT_ID}" \
    "${TARGET_GENERATION}" false "${DEPLOYMENT_ID}"
  if ! request_supervisor ENABLE "${TARGET_GENERATION}"; then
    timeout 30 "${DB_HELPER}" maintenance-cas "${TARGET_GENERATION}" false "${DEPLOYMENT_ID}" \
      "${TARGET_GENERATION}" true "${DEPLOYMENT_ID}" || {
        fail "ENABLE_ACK_AND_DB_RESTORE_FAILED"
        return 1
      }
    fail "ENABLE_ACK_FAILED"
    return 1
  fi
  prepare_gap_event CLOSE
  if ! append_prepared_gap_event; then
    restore_disabled_after_resume_failure || {
      fail "GAP_CLOSE_AND_FAIL_CLOSED_RESTORE_FAILED"
      return 1
    }
    fail "GAP_CLOSE_FAILED"
    return 1
  fi
  journal_state COMPLETE
}

prune_old_images() {
  local running_image_id
  running_image_id="$(docker inspect --format '{{.Image}}' fukurou-ktor 2>/dev/null || true)"
  mapfile -t image_ids < <(docker images "${IMAGE_REPOSITORY}" --no-trunc --format '{{.CreatedAt}}|{{.ID}}' | sort -r | awk -F'|' '!seen[$2]++ { print $2 }')
  local index=0 image_id
  for image_id in "${image_ids[@]}"; do
    index=$((index + 1))
    [[ "${index}" -le "${IMAGE_RETENTION_COUNT}" || "${image_id}" == "${running_image_id}" ]] && continue
    docker rmi "${image_id}" >/dev/null 2>&1 || true
  done
}

main() {
  if [[ "${1:-}" == "--print-contract-version" && -z "${2:-}" ]]; then
    printf '%s\n' "${CONTRACT_VERSION}"
    exit 0
  fi

  require_root
  for command in base64 cat docker flock git jq md5sum openssl sha256sum sync timeout; do require_command "${command}"; done
  parse_arguments "$@"
  validate_signed_bundle
  require_initial_state

  exec 9>"${LOCK_FILE}"
  flock -n 9 || fail "another deployment is already running"

  recover_unfinished_deployments
  capture_rollback_state
  trap rollback_on_error ERR
  trap 'on_signal TERM 143' TERM
  trap 'on_signal INT 130' INT
  trap 'on_signal HUP 129' HUP
  trap 'on_signal DEADLINE 124' USR1
  (sleep 1200; kill -USR1 "$$" 2>/dev/null || true) &
  DEADLINE_WATCHDOG_PID="$!"
  FORWARD_DEADLINE_BOOTTIME=$(( $(boottime_seconds) + 1200 ))
  journal_state CAPTURED
  accept_capability_catalog
  check_forward_deadline
  provision_fence_root
  check_forward_deadline
  provision_named_secret
  check_forward_deadline
  disable_launches
  check_forward_deadline
  drain_launches
  check_forward_deadline
  run_candidate_preflight
  check_forward_deadline
  checkout_deploy_sha
  check_forward_deadline
  deploy_compose
  check_forward_deadline
  resume_launches
  prune_old_images
  kill "${DEADLINE_WATCHDOG_PID}" 2>/dev/null || true
  wait "${DEADLINE_WATCHDOG_PID}" 2>/dev/null || true
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
