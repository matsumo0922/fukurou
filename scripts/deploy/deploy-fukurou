#!/usr/bin/env bash
set -Eeuo pipefail

readonly DEPLOY_ROOT="${FUKUROU_DEPLOY_ROOT:-/srv/fukurou}"
readonly REPO_DIR="${DEPLOY_ROOT}/repo"
readonly ENV_FILE="${DEPLOY_ROOT}/.env"
readonly SIMPLE_STATE_ROOT="${FUKUROU_SIMPLE_DEPLOY_STATE_ROOT:-${DEPLOY_ROOT}/deploy}"
readonly PAUSED_STATE_FILE="${FUKUROU_PAUSED_STATE_FILE:-${SIMPLE_STATE_ROOT}/paused-state.json}"
readonly LEGACY_DRAIN_SENTINEL="${FUKUROU_LEGACY_DRAIN_SENTINEL:-${SIMPLE_STATE_ROOT}/.legacy-drain-confirmed}"
readonly LEGACY_STATE_ROOT="${FUKUROU_LEGACY_DEPLOY_STATE_ROOT:-${DEPLOY_ROOT}/deploy-state}"
readonly LEGACY_ROLLBACK_STATE_ROOT="${FUKUROU_LEGACY_ROLLBACK_STATE_ROOT:-${DEPLOY_ROOT}/rollback-state}"
readonly FENCE_ROOT="${DEPLOY_ROOT}/runtime/launch-fence"
readonly LOCK_FILE="${FUKUROU_DEPLOY_LOCK:-/var/lock/fukurou-deploy.lock}"
readonly COMPOSE_FILE="${REPO_DIR}/docker-compose.prod.yml"
readonly MAIN_REF="${FUKUROU_MAIN_REF:-origin/main}"
readonly IMAGE_REPOSITORY="${FUKUROU_IMAGE_REPOSITORY:-ghcr.io/matsumo0922/fukurou}"
readonly DB_HELPER="${FUKUROU_DEPLOY_DB_HELPER:-/usr/local/libexec/fukurou-deploy-db}"
readonly FOUNDATION_SQL="${FUKUROU_FOUNDATION_SQL:-/usr/local/share/fukurou/deploy-foundation-v1.sql}"
readonly FOUNDATION_INDEX_SQL="${FUKUROU_FOUNDATION_INDEX_SQL:-/usr/local/share/fukurou/deploy-foundation-v1-indexes.sql}"
readonly MCP_ROLE_SQL="${FUKUROU_MCP_ROLE_SQL:-/usr/local/share/fukurou/mcp-role.sql}"
readonly DB_HELPER_MARKER="${FUKUROU_DB_HELPER_MARKER:-/usr/local/share/fukurou/db-helper-manifest.sha256}"
readonly CANDIDATE_DB_HELPER_MARKER="/usr/local/share/fukurou/db-helper-manifest.sha256"
readonly BACKUP_HELPER="${FUKUROU_BACKUP_HELPER:-/usr/local/libexec/fukurou/backup-fukurou}"
readonly SUPERVISOR_BINARY="/usr/local/libexec/fukurou-runtime-supervisor"
readonly IMAGE_RETENTION_COUNT="${FUKUROU_IMAGE_RETENTION_COUNT:-10}"
readonly APPLICATION_HEALTH_TIMEOUT="${FUKUROU_DEPLOY_HEALTH_TIMEOUT:-120}"

fail() {
  echo "deploy-fukurou: stage=${DEPLOY_STAGE:-PRECHECK} reason=$*" >&2
  return 1
}

usage() {
  cat >&2 <<'EOF'
Usage:
  deploy-fukurou --event <push|workflow_dispatch> --image-digest <sha256:digest> --deployment-id <id> <commit-sha>
  deploy-fukurou --acknowledge-paused-state <deployment-id>
EOF
}

require_root() {
  [[ "$(id -u)" == "0" ]] || fail "root is required"
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || fail "required command is unavailable: $1"
}

normalize_sha() {
  [[ "$1" =~ ^[0-9a-fA-F]{40}$ ]] || fail "commit sha must be a 40-character hexadecimal string"
  printf '%s' "$1" | tr 'A-F' 'a-f'
}

validate_deployment_id() {
  [[ "$1" =~ ^[a-zA-Z0-9._-]{1,96}$ ]] || fail "invalid deployment id"
}

validate_digest() {
  [[ "$1" =~ ^sha256:[0-9a-f]{64}$ ]] || fail "invalid image digest"
}

parse_arguments() {
  MODE=deploy
  if [[ "${1:-}" == "--acknowledge-paused-state" ]]; then
    [[ -n "${2:-}" && -z "${3:-}" ]] || {
      usage
      exit 2
    }
    MODE=acknowledge
    ACKNOWLEDGED_DEPLOYMENT_ID="$2"
    validate_deployment_id "${ACKNOWLEDGED_DEPLOYMENT_ID}"
    return
  fi

  [[ "${1:-}" == "--event" && -n "${2:-}" &&
    "${3:-}" == "--image-digest" && -n "${4:-}" &&
    "${5:-}" == "--deployment-id" && -n "${6:-}" &&
    -n "${7:-}" && -z "${8:-}" ]] || {
    usage
    exit 2
  }

  WORKFLOW_EVENT="$2"
  CANDIDATE_DIGEST="$4"
  DEPLOYMENT_ID="$6"
  DEPLOY_SHA="$(normalize_sha "$7")"
  [[ "${WORKFLOW_EVENT}" == "push" || "${WORKFLOW_EVENT}" == "workflow_dispatch" ]] || fail "invalid workflow event"
  validate_digest "${CANDIDATE_DIGEST}"
  validate_deployment_id "${DEPLOYMENT_ID}"
}

require_initial_state() {
  [[ -d "${REPO_DIR}/.git" ]] || fail "repository checkout is missing"
  [[ -f "${ENV_FILE}" && ! -L "${ENV_FILE}" ]] || fail "production environment file is missing or invalid"
  [[ -d "${SIMPLE_STATE_ROOT}" && ! -L "${SIMPLE_STATE_ROOT}" ]] || fail "simple deploy state root is missing or invalid"
  [[ "$(stat -c '%u:%g:%a' "${SIMPLE_STATE_ROOT}")" == "0:0:700" ]] || fail "simple deploy state root metadata is invalid"
  [[ -x "${DB_HELPER}" && ! -L "${DB_HELPER}" ]] || fail "installed DB helper is missing or invalid"
  [[ -x "${BACKUP_HELPER}" && ! -L "${BACKUP_HELPER}" ]] || fail "installed backup helper is missing or invalid"
}

legacy_path_is_empty() {
  local path="$1"
  [[ ! -e "${path}" ]] && return 0
  [[ -d "${path}" && ! -L "${path}" ]] || return 1
  [[ -z "$(find "${path}" -xdev -mindepth 1 -maxdepth 1 -print -quit)" ]]
}

require_legacy_drain_confirmation() {
  [[ -f "${LEGACY_DRAIN_SENTINEL}" && ! -L "${LEGACY_DRAIN_SENTINEL}" ]] ||
    fail "LEGACY_DRAIN_SENTINEL_MISSING: follow docs/deploy.md before using the simple executor"
  legacy_path_is_empty "${LEGACY_STATE_ROOT}" ||
    fail "LEGACY_DEPLOY_STATE_NOT_EMPTY: archive terminal history and investigate unfinished state"
  legacy_path_is_empty "${LEGACY_ROLLBACK_STATE_ROOT}" ||
    fail "LEGACY_ROLLBACK_STATE_NOT_EMPTY: archive terminal history and investigate unfinished state"
}

validate_paused_state_json() {
  jq -e '
    (keys | sort) == ([
      "deploymentId", "expectedImageDigest", "gapClosedAt", "gapId", "gapOpenedAt",
      "incidentDeploymentId", "maintenanceGeneration", "migrationCompletedImageDigest",
      "migrationCompletedTargetSha", "phase", "schemaVersion", "targetSha"
    ] | sort) and
    .schemaVersion == 1 and
    (.deploymentId | type == "string" and test("^[a-zA-Z0-9._-]{1,96}$")) and
    (.incidentDeploymentId | type == "string" and test("^[a-zA-Z0-9._-]{1,96}$")) and
    (.targetSha | type == "string" and test("^[0-9a-f]{40}$")) and
    (.expectedImageDigest | type == "string" and test("^sha256:[0-9a-f]{64}$")) and
    (.maintenanceGeneration | type == "number" and floor == . and . >= 1 and . <= 9223372036854775807) and
    (.gapId | type == "string" and test("^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$")) and
    (.migrationCompletedTargetSha | type == "string" and (. == "" or test("^[0-9a-f]{40}$"))) and
    (.migrationCompletedImageDigest | type == "string" and (. == "" or test("^sha256:[0-9a-f]{64}$"))) and
    ((.migrationCompletedTargetSha == "") == (.migrationCompletedImageDigest == "")) and
    (.gapOpenedAt | type == "string") and
    (.gapClosedAt | type == "string") and
    (.phase | IN("PAUSED_BEFORE_MIGRATION", "MIGRATION_DONE", "CUTOVER_STARTED", "CUTOVER_HEALTHY_PENDING_CLOSE", "ACKNOWLEDGED_FOR_REDEPLOY"))
  ' <<<"$1" >/dev/null
}

load_paused_state() {
  [[ -f "${PAUSED_STATE_FILE}" && ! -L "${PAUSED_STATE_FILE}" ]] || return 1
  local document
  document="$(<"${PAUSED_STATE_FILE}")"
  validate_paused_state_json "${document}" || fail "PAUSED_STATE_INVALID"

  MARKER_DEPLOYMENT_ID="$(jq -er '.deploymentId' <<<"${document}")"
  MARKER_INCIDENT_DEPLOYMENT_ID="$(jq -er '.incidentDeploymentId' <<<"${document}")"
  MARKER_TARGET_SHA="$(jq -er '.targetSha' <<<"${document}")"
  MARKER_EXPECTED_DIGEST="$(jq -er '.expectedImageDigest' <<<"${document}")"
  MARKER_MAINTENANCE_GENERATION="$(jq -er '.maintenanceGeneration' <<<"${document}")"
  MARKER_GAP_ID="$(jq -er '.gapId' <<<"${document}")"
  MARKER_MIGRATION_SHA="$(jq -er '.migrationCompletedTargetSha' <<<"${document}")"
  MARKER_MIGRATION_DIGEST="$(jq -er '.migrationCompletedImageDigest' <<<"${document}")"
  MARKER_GAP_OPENED_AT="$(jq -er '.gapOpenedAt' <<<"${document}")"
  MARKER_GAP_CLOSED_AT="$(jq -er '.gapClosedAt' <<<"${document}")"
  MARKER_PHASE="$(jq -er '.phase' <<<"${document}")"
}

persist_paused_state() {
  local document temporary
  document="$(jq -cS -n \
    --arg deploymentId "${MARKER_DEPLOYMENT_ID}" \
    --arg incidentDeploymentId "${MARKER_INCIDENT_DEPLOYMENT_ID}" \
    --arg targetSha "${MARKER_TARGET_SHA}" \
    --arg expectedImageDigest "${MARKER_EXPECTED_DIGEST}" \
    --argjson maintenanceGeneration "${MARKER_MAINTENANCE_GENERATION}" \
    --arg gapId "${MARKER_GAP_ID}" \
    --arg migrationCompletedTargetSha "${MARKER_MIGRATION_SHA}" \
    --arg migrationCompletedImageDigest "${MARKER_MIGRATION_DIGEST}" \
    --arg gapOpenedAt "${MARKER_GAP_OPENED_AT}" \
    --arg gapClosedAt "${MARKER_GAP_CLOSED_AT}" \
    --arg phase "${MARKER_PHASE}" \
    '{schemaVersion:1,deploymentId:$deploymentId,incidentDeploymentId:$incidentDeploymentId,
      targetSha:$targetSha,expectedImageDigest:$expectedImageDigest,
      maintenanceGeneration:$maintenanceGeneration,gapId:$gapId,
      migrationCompletedTargetSha:$migrationCompletedTargetSha,
      migrationCompletedImageDigest:$migrationCompletedImageDigest,
      gapOpenedAt:$gapOpenedAt,gapClosedAt:$gapClosedAt,phase:$phase}')"
  validate_paused_state_json "${document}" || fail "PAUSED_STATE_GENERATION_FAILED"

  temporary="$(mktemp "${SIMPLE_STATE_ROOT}/.paused-state.json.tmp.XXXXXX")"
  chmod 0600 "${temporary}"
  printf '%s\n' "${document}" >"${temporary}"
  sync -f "${temporary}"
  mv -f "${temporary}" "${PAUSED_STATE_FILE}"
  sync -f "${SIMPLE_STATE_ROOT}"
}

clear_paused_state() {
  rm -f -- "${PAUSED_STATE_FILE}"
  sync -f "${SIMPLE_STATE_ROOT}"
}

uuid_from_md5() {
  local hex
  hex="$(printf '%s' "$1" | md5sum | awk '{print $1}')"
  printf '%s-%s-%s-%s-%s\n' \
    "${hex:0:8}" "${hex:8:4}" "${hex:12:4}" "${hex:16:4}" "${hex:20:12}"
}

expected_gap_id() {
  uuid_from_md5 "fukurou-gap-v1:$1"
}

expected_gap_event_id() {
  uuid_from_md5 "fukurou-gap-v1:$1:$2"
}

runtime_snapshot() {
  local snapshot
  snapshot="$(timeout 30 "${DB_HELPER}" snapshot)" || fail "RUNTIME_SNAPSHOT_UNAVAILABLE"
  jq -e '
    (.installKind | type == "string") and
    (.maintenance.generation | type == "number" and floor == . and . >= 0) and
    (.maintenance.enabled | type == "boolean") and
    (.maintenance.deploymentId | type == "string")
  ' <<<"${snapshot}" >/dev/null || fail "RUNTIME_SNAPSHOT_INVALID"
  printf '%s\n' "${snapshot}"
}

inspect_optional_application() {
  local format="$1" inspection existing_names
  if inspection="$(timeout 10 docker inspect --format "${format}" fukurou-ktor 2>/dev/null)"; then
    printf '%s\n' "${inspection}"
    return 0
  fi
  existing_names="$(timeout 10 docker container ls -a --format '{{.Names}}')" || fail "APPLICATION_CONTAINER_OBSERVATION_FAILED"
  ! grep -Fxq "fukurou-ktor" <<<"${existing_names}" || fail "APPLICATION_CONTAINER_INSPECTION_FAILED"
}

observe_running_revision() {
  inspect_optional_application '{{range .Config.Env}}{{println .}}{{end}}' |
    awk -F= '$1=="FUKUROU_REVISION"{sub(/^[^=]*=/,"");print;exit}'
}

fetch_and_validate_target() {
  timeout 180 git -C "${REPO_DIR}" fetch --prune origin +refs/heads/main:refs/remotes/origin/main
  timeout 30 git -C "${REPO_DIR}" cat-file -e "${DEPLOY_SHA}^{commit}" || fail "TARGET_REVISION_UNAVAILABLE"
  timeout 30 git -C "${REPO_DIR}" merge-base --is-ancestor "${DEPLOY_SHA}" "${MAIN_REF}" || fail "TARGET_REVISION_NOT_ON_MAIN"
}

authoritative_descendant_check() {
  [[ "${WORKFLOW_EVENT}" == "push" ]] || return 0
  local current_revision
  current_revision="$(observe_running_revision)"
  [[ -n "${current_revision}" ]] || return 0
  [[ "${current_revision}" =~ ^[0-9a-f]{40}$ ]] || fail "CURRENT_REVISION_MALFORMED"
  timeout 30 git -C "${REPO_DIR}" cat-file -e "${current_revision}^{commit}" || fail "CURRENT_REVISION_UNAVAILABLE"
  timeout 30 git -C "${REPO_DIR}" merge-base --is-ancestor "${current_revision}" "${DEPLOY_SHA}" ||
    fail "PUSH_TARGET_NOT_DESCENDANT:current=${current_revision}:target=${DEPLOY_SHA}"
}

db_helper_manifest_entries() {
  printf '%s\t%s\n' \
    "scripts/deploy/fukurou-deploy-db" "${DB_HELPER}" \
    "scripts/deploy/sql/deploy-foundation-v1-indexes.sql" "${FOUNDATION_INDEX_SQL}" \
    "scripts/deploy/sql/deploy-foundation-v1.sql" "${FOUNDATION_SQL}" \
    "scripts/deploy/sql/mcp-role.sql" "${MCP_ROLE_SQL}" |
    LC_ALL=C sort
}

calculate_installed_db_helper_manifest() {
  local digest
  digest="$({
    local relative_path installed_path content_hash
    while IFS=$'\t' read -r relative_path installed_path; do
      [[ -f "${installed_path}" && ! -L "${installed_path}" ]] || return 1
      content_hash="$(sha256sum "${installed_path}" | awk '{print $1}')" || return 1
      printf '%s\0%s\0' "${relative_path}" "${content_hash}"
    done < <(db_helper_manifest_entries)
  } | sha256sum | awk '{print $1}')" || fail "DB_HELPER_MANIFEST_RECOMPUTE_FAILED"
  [[ "${digest}" =~ ^[0-9a-f]{64}$ ]] || fail "DB_HELPER_MANIFEST_RECOMPUTE_FAILED"
  printf '%s\n' "${digest}"
}

read_candidate_db_helper_manifest() {
  local image_reference="$1" marker
  marker="$(timeout 30 docker run --rm --network none --entrypoint cat \
    "${image_reference}" "${CANDIDATE_DB_HELPER_MARKER}")" || fail "CANDIDATE_DB_HELPER_MARKER_UNAVAILABLE"
  [[ "${marker}" =~ ^[0-9a-f]{64}$ ]] || fail "CANDIDATE_DB_HELPER_MARKER_INVALID"
  printf '%s\n' "${marker}"
}

verify_db_helper_manifest() {
  [[ -f "${DB_HELPER_MARKER}" && ! -L "${DB_HELPER_MARKER}" ]] || fail "ROOT_DB_HELPER_MARKER_MISSING"
  [[ "$(stat -c '%u:%g:%a' "${DB_HELPER_MARKER}")" == "0:0:444" ]] || fail "ROOT_DB_HELPER_MARKER_METADATA_INVALID"
  local installed_recorded installed_actual candidate_expected
  installed_recorded="$(tr -d '\n' <"${DB_HELPER_MARKER}")"
  [[ "${installed_recorded}" =~ ^[0-9a-f]{64}$ ]] || fail "ROOT_DB_HELPER_MARKER_INVALID"
  installed_actual="$(calculate_installed_db_helper_manifest)"
  candidate_expected="$(read_candidate_db_helper_manifest "${IMAGE_REFERENCE}")"
  [[ "${installed_actual}" == "${installed_recorded}" ]] || fail "ROOT_DB_HELPER_INSTALLATION_CHANGED"
  [[ "${installed_actual}" == "${candidate_expected}" ]] || fail "CANDIDATE_DB_HELPER_MARKER_MISMATCH"
}

pull_candidate() {
  IMAGE_REFERENCE="${IMAGE_REPOSITORY}@${CANDIDATE_DIGEST}"
  timeout 180 docker pull "${IMAGE_REFERENCE}" >/dev/null
  local repo_digests
  repo_digests="$(timeout 10 docker image inspect --format '{{join .RepoDigests "|"}}' "${IMAGE_REFERENCE}")"
  [[ "${repo_digests}" == *"${IMAGE_REFERENCE}"* ]] || fail "DIGEST_PULL_MISMATCH"
  verify_db_helper_manifest
}

bind_image_reference() {
  export FUKUROU_IMAGE_REFERENCE="${IMAGE_REPOSITORY}@${MARKER_EXPECTED_DIGEST}"
}

request_supervisor() {
  local operation="$1" generation="$2"
  timeout 30 docker exec --user 0 fukurou-ktor "${SUPERVISOR_BINARY}" --control "${operation}" "${generation}" |
    grep -Fx "ACK ${operation} ${generation}"
}

write_fence_fallback() {
  bind_image_reference
  timeout 30 docker run --rm --network none --read-only --cap-drop ALL \
    --security-opt no-new-privileges=true \
    --mount "type=bind,src=${FENCE_ROOT},dst=/var/lib/fukurou/launch-fence" \
    --entrypoint "${SUPERVISOR_BINARY}" \
    "${FUKUROU_IMAGE_REFERENCE}" --fence-write "$1" "$2"
}

assert_application_pid_zero() {
  local inspection existing_names running pid
  if inspection="$(timeout 10 docker inspect --format '{{.State.Running}}|{{.State.Pid}}' fukurou-ktor 2>/dev/null)"; then
    running="${inspection%%|*}"
    pid="${inspection##*|}"
    [[ "${running}" == "false" && "${pid}" == "0" ]] || fail "APPLICATION_PID_ZERO_NOT_PROVEN"
    return
  fi
  existing_names="$(timeout 10 docker container ls -a --format '{{.Names}}')" || fail "APPLICATION_CONTAINER_OBSERVATION_FAILED"
  ! grep -Fxq "fukurou-ktor" <<<"${existing_names}" || fail "APPLICATION_CONTAINER_INSPECTION_FAILED"
}

observe_runtime_children() {
  local process_table
  if process_table="$(timeout 10 docker top fukurou-ktor -eo pid,uid 2>/dev/null)"; then
    awk 'NR > 1 && ($2 == "10002" || $2 == "10003") { count++ } END { print count + 0 }' <<<"${process_table}"
    return
  fi
  if assert_application_pid_zero; then
    printf '0\n'
    return
  fi
  fail "RUNTIME_PROCESS_OBSERVATION_FAILED"
}

drain_launches() {
  local natural_deadline=$(( $(date +%s) + 30 ))
  local absolute_deadline=$(( $(date +%s) + 120 ))
  while (( $(date +%s) < natural_deadline )); do
    local child_count reservation_count
    child_count="$(observe_runtime_children)"
    reservation_count="$(timeout 10 "${DB_HELPER}" active-launch-count)" || fail "ACTIVE_LAUNCH_OBSERVATION_FAILED"
    [[ "${child_count}" == "0" && "${reservation_count}" == "0" ]] && return 0
    sleep 5
  done

  timeout 45 docker compose --env-file "${ENV_FILE}" -f "${COMPOSE_FILE}" stop -t 30 ktor
  assert_application_pid_zero
  timeout 30 "${DB_HELPER}" interrupt-active-launches "${MARKER_INCIDENT_DEPLOYMENT_ID}"

  while (( $(date +%s) < absolute_deadline )); do
    [[ "$(timeout 10 "${DB_HELPER}" active-launch-count)" == "0" ]] && return 0
    sleep 5
  done
  fail "LLM_DRAIN_TIMEOUT"
}

gap_event_payload_hash() {
  local boundary="$1" occurred_at="$2" event_id payload
  event_id="$(expected_gap_event_id "${MARKER_INCIDENT_DEPLOYMENT_ID}" "${boundary}")"
  payload="$(jq -cS -n \
    --arg boundary "${boundary}" \
    --arg deploymentId "${MARKER_INCIDENT_DEPLOYMENT_ID}" \
    --arg eventId "${event_id}" \
    --arg gapId "${MARKER_GAP_ID}" \
    --arg occurredAt "${occurred_at}" \
    '{boundary:$boundary,deploymentId:$deploymentId,eventId:$eventId,gapId:$gapId,
      occurredAt:$occurredAt,reason:"DEPLOY_MAINTENANCE",version:1}')"
  printf '%s' "${payload}" | sha256sum | awk '{print $1}'
}

append_gap_event() {
  local boundary="$1" occurred_at="$2" payload_hash
  [[ "$(expected_gap_id "${MARKER_INCIDENT_DEPLOYMENT_ID}")" == "${MARKER_GAP_ID}" ]] || fail "PAUSED_STATE_GAP_ID_MISMATCH"
  payload_hash="$(gap_event_payload_hash "${boundary}" "${occurred_at}")"
  timeout 30 "${DB_HELPER}" append-gap \
    "${MARKER_INCIDENT_DEPLOYMENT_ID}" "${boundary}" "${occurred_at}" "${payload_hash}"
}

ensure_open_gap_for_acknowledged_attempt() {
  local snapshot active_count state
  snapshot="$(runtime_snapshot)"
  [[ "$(jq -er '.maintenance.enabled' <<<"${snapshot}")" == "true" ]] || fail "ACKNOWLEDGED_PAUSE_MAINTENANCE_NOT_ENABLED"
  [[ "$(jq -er '.maintenance.generation' <<<"${snapshot}")" == "${MARKER_MAINTENANCE_GENERATION}" ]] || fail "ACKNOWLEDGED_PAUSE_GENERATION_MISMATCH"
  [[ "$(jq -er '.maintenance.deploymentId' <<<"${snapshot}")" == "${MARKER_INCIDENT_DEPLOYMENT_ID}" ]] || fail "ACKNOWLEDGED_PAUSE_DEPLOYMENT_MISMATCH"
  active_count="$(timeout 10 "${DB_HELPER}" active-launch-count)" || fail "ACTIVE_LAUNCH_OBSERVATION_FAILED"
  [[ "${active_count}" == "0" ]] || fail "ACKNOWLEDGED_PAUSE_NOT_DRAINED"

  if [[ -z "${MARKER_GAP_OPENED_AT}" ]]; then
    MARKER_GAP_OPENED_AT="$(timeout 10 "${DB_HELPER}" timestamp)"
    persist_paused_state
  fi
  append_gap_event OPEN "${MARKER_GAP_OPENED_AT}"
  state="$(timeout 10 "${DB_HELPER}" gap-state "${MARKER_INCIDENT_DEPLOYMENT_ID}")"
  [[ "${state}" == "OPEN" ]] || fail "ACKNOWLEDGED_PAUSE_GAP_NOT_OPEN"
}

start_new_pause() {
  local snapshot current_generation current_enabled current_deployment install_kind
  snapshot="$(runtime_snapshot)"
  install_kind="$(jq -er '.installKind' <<<"${snapshot}")"
  [[ "${install_kind}" == "FOUNDATION_V1" ]] || fail "DEPLOY_FOUNDATION_REQUIRED_BEFORE_SIMPLE_EXECUTOR"
  current_generation="$(jq -er '.maintenance.generation' <<<"${snapshot}")"
  # jq -e は最後に出力した値が false/null だと exit 1 を返す値ベースの終了コード仕様のため、
  # 正常時の期待値である false を保護なし代入で受けると set -e でスクリプトごと即死する
  # （直後の明示チェックにすら到達しない）。-e を落として明示チェックだけに検証を委ねる。
  current_enabled="$(jq -r '.maintenance.enabled' <<<"${snapshot}")"
  current_deployment="$(jq -er '.maintenance.deploymentId' <<<"${snapshot}")"
  [[ "${current_enabled}" == "false" ]] || fail "UNTRACKED_LAUNCH_MAINTENANCE_ENABLED"
  [[ "${current_generation}" -lt 9223372036854775807 ]] || fail "MAINTENANCE_GENERATION_OVERFLOW"

  MARKER_DEPLOYMENT_ID="${DEPLOYMENT_ID}"
  MARKER_INCIDENT_DEPLOYMENT_ID="${DEPLOYMENT_ID}"
  MARKER_TARGET_SHA="${DEPLOY_SHA}"
  MARKER_EXPECTED_DIGEST="${CANDIDATE_DIGEST}"
  MARKER_MAINTENANCE_GENERATION="$((current_generation + 1))"
  MARKER_GAP_ID="$(expected_gap_id "${MARKER_INCIDENT_DEPLOYMENT_ID}")"
  MARKER_MIGRATION_SHA=""
  MARKER_MIGRATION_DIGEST=""
  MARKER_GAP_OPENED_AT=""
  MARKER_GAP_CLOSED_AT=""
  MARKER_PHASE="PAUSED_BEFORE_MIGRATION"
  persist_paused_state

  if ! request_supervisor DISABLE "${MARKER_MAINTENANCE_GENERATION}"; then
    timeout 45 docker compose --env-file "${ENV_FILE}" -f "${COMPOSE_FILE}" stop -t 30 ktor
    assert_application_pid_zero
    write_fence_fallback DISABLED_PENDING_DB "${MARKER_MAINTENANCE_GENERATION}"
  fi
  timeout 30 "${DB_HELPER}" maintenance-cas \
    "${current_generation}" false "${current_deployment}" \
    "${MARKER_MAINTENANCE_GENERATION}" true "${MARKER_INCIDENT_DEPLOYMENT_ID}"
  request_supervisor COMMIT "${MARKER_MAINTENANCE_GENERATION}" >/dev/null ||
    write_fence_fallback DISABLED_COMMITTED "${MARKER_MAINTENANCE_GENERATION}"

  drain_launches
  MARKER_GAP_OPENED_AT="$(timeout 10 "${DB_HELPER}" timestamp)"
  persist_paused_state
  append_gap_event OPEN "${MARKER_GAP_OPENED_AT}"
}

adopt_acknowledged_pause() {
  ensure_open_gap_for_acknowledged_attempt
  MARKER_DEPLOYMENT_ID="${DEPLOYMENT_ID}"
  MARKER_TARGET_SHA="${DEPLOY_SHA}"
  MARKER_EXPECTED_DIGEST="${CANDIDATE_DIGEST}"
  MARKER_GAP_CLOSED_AT=""
  if [[ "${MARKER_MIGRATION_SHA}" == "${DEPLOY_SHA}" && "${MARKER_MIGRATION_DIGEST}" == "${CANDIDATE_DIGEST}" ]]; then
    MARKER_PHASE="MIGRATION_DONE"
  else
    MARKER_PHASE="PAUSED_BEFORE_MIGRATION"
  fi
  persist_paused_state
}

perform_migration() {
  timeout 900 "${BACKUP_HELPER}" --invoked-by-deploy
  timeout 60 "${DB_HELPER}" install-foundation
  timeout 300 "${DB_HELPER}" install-indexes
  MARKER_MIGRATION_SHA="${MARKER_TARGET_SHA}"
  MARKER_MIGRATION_DIGEST="${MARKER_EXPECTED_DIGEST}"
  MARKER_PHASE="MIGRATION_DONE"
  persist_paused_state
}

checkout_target() {
  timeout 30 git -C "${REPO_DIR}" checkout --detach "${MARKER_TARGET_SHA}"
}

wait_for_health() {
  local deadline=$(( $(date +%s) + APPLICATION_HEALTH_TIMEOUT ))
  while (( $(date +%s) < deadline )); do
    if timeout 10 docker exec --user 10001 fukurou-ktor curl -fsS http://127.0.0.1:8080/health/live >/dev/null 2>&1 &&
      timeout 10 docker exec --user 10001 fukurou-ktor curl -fsS http://127.0.0.1:8080/health/ready >/dev/null 2>&1; then
      return 0
    fi
    sleep 2
  done
  fail "APPLICATION_HEALTH_TIMEOUT"
}

health_is_currently_ready() {
  timeout 10 docker exec --user 10001 fukurou-ktor curl -fsS http://127.0.0.1:8080/health/live >/dev/null 2>&1 &&
    timeout 10 docker exec --user 10001 fukurou-ktor curl -fsS http://127.0.0.1:8080/health/ready >/dev/null 2>&1
}

verify_running_revision() {
  local revision_response
  revision_response="$(timeout 10 docker exec --user 10001 fukurou-ktor curl -fsS http://127.0.0.1:8080/revision)"
  [[ "${revision_response}" == *"${MARKER_TARGET_SHA}"* ]] || fail "HTTP_REVISION_MISMATCH"
}

running_digest_matches_marker() {
  local configured_reference image_id repo_digests expected_reference
  expected_reference="${IMAGE_REPOSITORY}@${MARKER_EXPECTED_DIGEST}"
  configured_reference="$(timeout 10 docker inspect --format '{{.Config.Image}}' fukurou-ktor)" || return 1
  [[ "${configured_reference}" == "${expected_reference}" ]] || return 1
  image_id="$(timeout 10 docker inspect --format '{{.Image}}' fukurou-ktor)" || return 1
  repo_digests="$(timeout 10 docker image inspect --format '{{join .RepoDigests "|"}}' "${image_id}")" || return 1
  [[ "${repo_digests}" == *"${expected_reference}"* ]]
}

verify_running_digest() {
  running_digest_matches_marker || fail "RUNNING_IMAGE_DIGEST_MISMATCH"
}

compose_cutover() {
  bind_image_reference
  timeout 120 docker compose --env-file "${ENV_FILE}" -f "${COMPOSE_FILE}" up -d --no-build
  wait_for_health
  verify_running_revision
  verify_running_digest
}

restore_paused_maintenance_after_enable_failure() {
  timeout 30 "${DB_HELPER}" maintenance-cas \
    "${MARKER_MAINTENANCE_GENERATION}" false "${MARKER_INCIDENT_DEPLOYMENT_ID}" \
    "${MARKER_MAINTENANCE_GENERATION}" true "${MARKER_INCIDENT_DEPLOYMENT_ID}" || return 1
  request_supervisor COMMIT "${MARKER_MAINTENANCE_GENERATION}" >/dev/null ||
    write_fence_fallback DISABLED_COMMITTED "${MARKER_MAINTENANCE_GENERATION}"
}

resume_launches_idempotently() {
  local snapshot enabled generation deployment
  snapshot="$(runtime_snapshot)"
  # start_new_pause() と同じ理由で -e を落とす。enabled は true/false どちらも
  # 正常系（下の if/elif が両方を明示的に扱う）であり、false のときに jq -e が
  # 保護なし代入をset -eで即死させてしまう。
  enabled="$(jq -r '.maintenance.enabled' <<<"${snapshot}")"
  generation="$(jq -er '.maintenance.generation' <<<"${snapshot}")"
  deployment="$(jq -er '.maintenance.deploymentId' <<<"${snapshot}")"
  [[ "${generation}" == "${MARKER_MAINTENANCE_GENERATION}" ]] || fail "RESUME_MAINTENANCE_GENERATION_MISMATCH"
  [[ "${deployment}" == "${MARKER_INCIDENT_DEPLOYMENT_ID}" ]] || fail "RESUME_MAINTENANCE_DEPLOYMENT_MISMATCH"

  if [[ "${enabled}" == "true" ]]; then
    timeout 30 "${DB_HELPER}" maintenance-cas \
      "${MARKER_MAINTENANCE_GENERATION}" true "${MARKER_INCIDENT_DEPLOYMENT_ID}" \
      "${MARKER_MAINTENANCE_GENERATION}" false "${MARKER_INCIDENT_DEPLOYMENT_ID}"
  elif [[ "${enabled}" != "false" ]]; then
    fail "RESUME_MAINTENANCE_STATE_INVALID"
  fi

  if ! request_supervisor ENABLE "${MARKER_MAINTENANCE_GENERATION}"; then
    restore_paused_maintenance_after_enable_failure || fail "ENABLE_ACK_AND_MAINTENANCE_RESTORE_FAILED"
    fail "ENABLE_ACK_FAILED"
  fi
}

close_gap_idempotently() {
  local state
  if [[ -z "${MARKER_GAP_CLOSED_AT}" ]]; then
    MARKER_GAP_CLOSED_AT="$(timeout 10 "${DB_HELPER}" timestamp)"
    persist_paused_state
  fi
  append_gap_event CLOSE "${MARKER_GAP_CLOSED_AT}"
  state="$(timeout 10 "${DB_HELPER}" gap-state "${MARKER_INCIDENT_DEPLOYMENT_ID}")"
  [[ "${state}" == "CLOSED" ]] || fail "GAP_CLOSE_NOT_CONFIRMED"
}

complete_pending_close() {
  resume_launches_idempotently
  close_gap_idempotently
  clear_paused_state
}

recover_healthy_pending_close() {
  if running_digest_matches_marker && health_is_currently_ready; then
    complete_pending_close
    return 0
  fi
  MARKER_PHASE="CUTOVER_STARTED"
  persist_paused_state
  fail "PAUSED_STATE_ACKNOWLEDGEMENT_REQUIRED:${MARKER_DEPLOYMENT_ID}"
}

acknowledge_paused_state() {
  load_paused_state || fail "PAUSED_STATE_NOT_FOUND"
  [[ "${MARKER_DEPLOYMENT_ID}" == "${ACKNOWLEDGED_DEPLOYMENT_ID}" ]] || fail "PAUSED_STATE_DEPLOYMENT_ID_MISMATCH"
  case "${MARKER_PHASE}" in
    PAUSED_BEFORE_MIGRATION|MIGRATION_DONE|CUTOVER_STARTED) ;;
    *) fail "PAUSED_STATE_NOT_ACKNOWLEDGEABLE:${MARKER_PHASE}" ;;
  esac
  MARKER_PHASE="ACKNOWLEDGED_FOR_REDEPLOY"
  persist_paused_state
}

prune_old_images() {
  local running_image_id
  running_image_id="$(timeout 10 docker inspect --format '{{.Image}}' fukurou-ktor 2>/dev/null || true)"
  mapfile -t image_ids < <(
    timeout 30 docker images "${IMAGE_REPOSITORY}" --no-trunc --format '{{.CreatedAt}}|{{.ID}}' |
      sort -r | awk -F'|' '!seen[$2]++ { print $2 }'
  )
  local index=0 image_id
  for image_id in "${image_ids[@]}"; do
    index=$((index + 1))
    [[ "${index}" -le "${IMAGE_RETENTION_COUNT}" || "${image_id}" == "${running_image_id}" ]] && continue
    timeout 30 docker rmi "${image_id}" >/dev/null 2>&1 || true
  done
}

deploy_compose() {
  DEPLOY_STAGE=PULL_CANDIDATE
  pull_candidate

  if [[ "${EXISTING_MARKER_PHASE:-}" == "ACKNOWLEDGED_FOR_REDEPLOY" ]]; then
    DEPLOY_STAGE=ADOPT_ACKNOWLEDGED_PAUSE
    adopt_acknowledged_pause
  else
    DEPLOY_STAGE=PAUSE_LAUNCHES
    start_new_pause
  fi

  if [[ "${MARKER_PHASE}" == "PAUSED_BEFORE_MIGRATION" ]]; then
    DEPLOY_STAGE=BACKUP_AND_MIGRATE
    perform_migration
  fi
  [[ "${MARKER_PHASE}" == "MIGRATION_DONE" ]] || fail "MIGRATION_PHASE_INVALID:${MARKER_PHASE}"

  MARKER_PHASE="CUTOVER_STARTED"
  persist_paused_state
  DEPLOY_STAGE=CHECKOUT_TARGET
  checkout_target
  DEPLOY_STAGE=COMPOSE_CUTOVER
  compose_cutover
  MARKER_PHASE="CUTOVER_HEALTHY_PENDING_CLOSE"
  persist_paused_state
  DEPLOY_STAGE=RESUME_AND_CLOSE_GAP
  complete_pending_close
}

main() {
  DEPLOY_STAGE=PRECHECK
  require_root
  for command in awk date docker find flock git grep jq md5sum mktemp sha256sum sort stat sync timeout tr; do
    require_command "${command}"
  done
  parse_arguments "$@"
  require_initial_state

  exec 9>"${LOCK_FILE}"
  flock -n 9 || fail "another deployment is already running"
  require_legacy_drain_confirmation

  if [[ "${MODE}" == "acknowledge" ]]; then
    DEPLOY_STAGE=ACKNOWLEDGE_PAUSED_STATE
    acknowledge_paused_state
    return
  fi

  DEPLOY_STAGE=VALIDATE_TARGET
  fetch_and_validate_target
  authoritative_descendant_check

  EXISTING_MARKER_PHASE=""
  if load_paused_state; then
    EXISTING_MARKER_PHASE="${MARKER_PHASE}"
    case "${MARKER_PHASE}" in
      PAUSED_BEFORE_MIGRATION|MIGRATION_DONE|CUTOVER_STARTED)
        fail "PAUSED_STATE_ACKNOWLEDGEMENT_REQUIRED:${MARKER_DEPLOYMENT_ID}"
        ;;
      CUTOVER_HEALTHY_PENDING_CLOSE)
        DEPLOY_STAGE=RECOVER_HEALTHY_PENDING_CLOSE
        local completed_sha="${MARKER_TARGET_SHA}" completed_digest="${MARKER_EXPECTED_DIGEST}"
        recover_healthy_pending_close
        if [[ "${completed_sha}" == "${DEPLOY_SHA}" && "${completed_digest}" == "${CANDIDATE_DIGEST}" ]]; then
          return
        fi
        EXISTING_MARKER_PHASE=""
        ;;
      ACKNOWLEDGED_FOR_REDEPLOY)
        ;;
      *) fail "PAUSED_STATE_PHASE_INVALID:${MARKER_PHASE}" ;;
    esac
  fi

  deploy_compose
  DEPLOY_STAGE=PRUNE_OLD_IMAGES
  prune_old_images
  DEPLOY_STAGE=COMPLETE
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
