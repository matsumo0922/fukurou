#!/usr/bin/env bash
set -Eeuo pipefail

readonly SCRIPT_DIRECTORY="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly RESOLVER="${SCRIPT_DIRECTORY}/deploy-intent-resolver"
readonly TEST_ROOT="$(mktemp -d)"
readonly TEST_REPOSITORY="${TEST_ROOT}/repository"

cleanup() {
  rm -rf "${TEST_ROOT}"
}
trap cleanup EXIT

fail_selftest() {
  echo "deploy-intent-resolver-selftest: $*" >&2
  exit 1
}

git init -q "${TEST_REPOSITORY}"
git -C "${TEST_REPOSITORY}" config user.name selftest
git -C "${TEST_REPOSITORY}" config user.email selftest@example.invalid
mkdir -p "${TEST_REPOSITORY}/scripts/deploy" "${TEST_REPOSITORY}/schema"
printf '%s\n' 'schema' > "${TEST_REPOSITORY}/schema/owner.txt"
printf '%s\n' 'schema/owner.txt' > "${TEST_REPOSITORY}/scripts/deploy/deploy-schema-sensitive-paths-v1.txt"
git -C "${TEST_REPOSITORY}" add .
git -C "${TEST_REPOSITORY}" commit -qm base
base_sha="$(git -C "${TEST_REPOSITORY}" rev-parse HEAD)"

printf '%s\n' 'application' > "${TEST_REPOSITORY}/application.txt"
git -C "${TEST_REPOSITORY}" add application.txt
git -C "${TEST_REPOSITORY}" commit -qm application
application_sha="$(git -C "${TEST_REPOSITORY}" rev-parse HEAD)"

printf '%s\n' 'schema-v2' >> "${TEST_REPOSITORY}/schema/owner.txt"
git -C "${TEST_REPOSITORY}" add schema/owner.txt
git -C "${TEST_REPOSITORY}" commit -qm schema
schema_sha="$(git -C "${TEST_REPOSITORY}" rev-parse HEAD)"
git -C "${TEST_REPOSITORY}" branch -M main

run_case() {
  local name="$1" event="$2" target_sha="$3" before_sha="$4" reason="$5" mode="$6"
  local case_root="${TEST_ROOT}/${name}"
  mkdir -p "${case_root}"
  (
    cd "${TEST_REPOSITORY}"
    env \
      DEPLOY_RESOLVER_FETCH_MAIN=false \
      DEPLOY_RESOLVER_MAIN_REF=refs/heads/main \
      GITHUB_EVENT_NAME="${event}" \
      GITHUB_EVENT_BEFORE="${before_sha}" \
      GITHUB_SHA="${target_sha}" \
      GITHUB_OUTPUT="${case_root}/output" \
      INPUT_IMAGE_SHA="${target_sha}" \
      INPUT_ROLLBACK_REASON="${reason}" \
      INPUT_MIGRATION_ROLLBACK_MODE="${mode}" \
      "${RESOLVER}"
  ) >"${case_root}/stdout" 2>"${case_root}/stderr"
}

expect_accepted() {
  local name="$1"
  shift
  run_case "${name}" "$@" || {
    sed 's/^/  /' "${TEST_ROOT}/${name}/stderr" >&2
    fail_selftest "${name} was rejected"
  }
}

expect_rejected() {
  local name="$1" expected="$2"
  shift 2
  if run_case "${name}" "$@"; then
    fail_selftest "${name} was accepted"
  fi
  grep -Fq "${expected}" "${TEST_ROOT}/${name}/stderr" || fail_selftest "${name} returned the wrong reason"
}

expect_accepted push-forward push "${application_sha}" "${base_sha}" '' AUTO_IMAGE_ROLLBACK
grep -Fxq 'deploy_intent=FORWARD' "${TEST_ROOT}/push-forward/output" || fail_selftest "push intent was not FORWARD"

expect_rejected push-schema-sensitive SCHEMA_SENSITIVE_AUTOMATIC_DEPLOY_REQUIRES_MANUAL_REVIEW \
  push "${schema_sha}" "${application_sha}" '' AUTO_IMAGE_ROLLBACK
expect_rejected push-reason 'push may issue only FORWARD' \
  push "${application_sha}" "${base_sha}" 'manual reason' AUTO_IMAGE_ROLLBACK
expect_rejected push-explicit-mode 'push may issue only FORWARD' \
  push "${application_sha}" "${base_sha}" 'reviewed' BACKWARD_COMPATIBLE

expect_accepted manual-latest workflow_dispatch "${schema_sha}" '' '' AUTO_IMAGE_ROLLBACK
grep -Fxq 'deploy_intent=FORWARD' "${TEST_ROOT}/manual-latest/output" || fail_selftest "latest manual intent was not FORWARD"
expect_accepted manual-explicit workflow_dispatch "${schema_sha}" '' 'migration reviewed' ROLL_FORWARD_ONLY
expect_accepted manual-historical workflow_dispatch "${application_sha}" '' 'incident rollback' AUTO_IMAGE_ROLLBACK
grep -Fxq 'deploy_intent=AUTHORIZED_ROLLBACK' "${TEST_ROOT}/manual-historical/output" || \
  fail_selftest "historical manual intent was not AUTHORIZED_ROLLBACK"
expect_rejected historical-empty-reason 'historical target requires rollback_reason' \
  workflow_dispatch "${application_sha}" '' '' AUTO_IMAGE_ROLLBACK
expect_rejected latest-auto-reason 'latest-main AUTO_IMAGE_ROLLBACK does not accept rollback_reason' \
  workflow_dispatch "${schema_sha}" '' 'unexpected reason' AUTO_IMAGE_ROLLBACK
expect_rejected explicit-empty-reason 'explicit migration rollback mode requires rollback_reason' \
  workflow_dispatch "${schema_sha}" '' '' BACKWARD_COMPATIBLE
expect_rejected unsupported-event 'unsupported workflow event' \
  schedule "${schema_sha}" '' '' AUTO_IMAGE_ROLLBACK

expect_rejected bearer-secret 'secret-like value' \
  workflow_dispatch "${application_sha}" '' 'Bearer abcdefghijklmnopqrstuvwxyz' AUTO_IMAGE_ROLLBACK
expect_rejected credential-uri 'secret-like value' \
  workflow_dispatch "${application_sha}" '' 'postgresql://user:password@example.invalid/db' AUTO_IMAGE_ROLLBACK
expect_rejected private-key 'secret-like value' \
  workflow_dispatch "${application_sha}" '' '-----BEGIN PRIVATE KEY-----' AUTO_IMAGE_ROLLBACK
expect_rejected token-prefix 'secret-like value' \
  workflow_dispatch "${application_sha}" '' 'github_pat_abcdefghijklmnopqrstuvwxyz123456' AUTO_IMAGE_ROLLBACK

echo "DEPLOY_INTENT_RESOLVER_SELFTEST_OK event-matrix=closed reason-guard=closed historical-quality=required early-schema-diff=manual-only"
