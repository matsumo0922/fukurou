append_legacy_journal_entry() {
  local target="$1" state="$2" details="${3:-{}}"
  local previous_state="" previous_hash="" previous_sequence=0 payload payload_hash
  if [[ -f "${target}" ]]; then
    previous_state="$(tail -n 1 "${target}" | jq -er '.state')"
    previous_hash="$(tail -n 1 "${target}" | jq -er '.payloadHash')"
    previous_sequence="$(tail -n 1 "${target}" | jq -er '.sequence')"
  fi
  payload="$(jq -cS -n --arg state "${state}" --arg previousState "${previous_state}" --arg previousHash "${previous_hash}" \
    --argjson sequence "$((previous_sequence + 1))" --argjson details "${details}" \
    '{version:1,sequence:$sequence,previousState:$previousState,previousHash:$previousHash,state:$state,at:"2025-12-31T00:00:00.000000Z",details:$details}')"
  payload_hash="$(printf '%s' "${payload}" | sha256sum | awk '{print $1}')"
  jq -cS --arg payloadHash "${payload_hash}" '. + {payloadHash:$payloadHash}' <<<"${payload}" >> "${target}"
}

create_legacy_fixture() {
  local deployment_id="$1" unfinished_state="$2" state_dir="${STATE_ROOT}/$1"
  mkdir -p "${state_dir}"
  write_recovery_state "${state_dir}" "${deployment_id}"
  append_legacy_journal_entry "${state_dir}/journal.jsonl" CAPTURED
  [[ "${unfinished_state}" == CAPTURED ]] || append_legacy_journal_entry "${state_dir}/journal.jsonl" LAUNCHES_DISABLED
  [[ "${unfinished_state}" != COMPLETE ]] || {
    append_legacy_journal_entry "${state_dir}/journal.jsonl" CANDIDATE_HEALTHY
    append_legacy_journal_entry "${state_dir}/journal.jsonl" DB_MAINTENANCE_CLEARED
    append_legacy_journal_entry "${state_dir}/journal.jsonl" ENABLE_ACKED
    append_legacy_journal_entry "${state_dir}/journal.jsonl" GAP_CLOSED
    append_legacy_journal_entry "${state_dir}/journal.jsonl" COMPLETE
  }
}

