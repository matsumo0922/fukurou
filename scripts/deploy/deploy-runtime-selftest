create_recovery_fixture() {
  local deployment_id="$1" terminal_state="$2"
  local expected_state="${terminal_state}"
  local state_dir="${STATE_ROOT}/${deployment_id}"
  mkdir -p "${state_dir}"
  write_v2_recovery_state "${state_dir}" "${deployment_id}"
  printf 'OPEN\n' > "${DB_STATE_ROOT}/gaps/${deployment_id}"
  ROLLBACK_STATE_DIR="${state_dir}"; DEPLOYMENT_ID="${deployment_id}"
  journal_state PREPARED "$(v2_prepared_details)"
  journal_state CAPTURED '{"fixture":true}'
  journal_state SAFETY_MUTATION_STARTED
  journal_state LAUNCHES_DISABLED
  journal_state CANDIDATE_HEALTHY
  TARGET_GENERATION=7
  DISPATCHED_OPERATION_IDS=$'\nPRODUCTION\n'
  FUKUROU_DEPLOY_CRASH_MODE=RETURN
  case "${terminal_state}" in
    DB_MAINTENANCE_CLEARED) FUKUROU_DEPLOY_CRASH_AT=AFTER_DB_MAINTENANCE_CLEAR ;;
    ENABLE_ACKED) FUKUROU_DEPLOY_CRASH_AT=AFTER_ENABLE_ACK ;;
    GAP_CLOSE_APPENDED) FUKUROU_DEPLOY_CRASH_AT=AFTER_GAP_CLOSE_APPEND; expected_state=ENABLE_ACKED ;;
    GAP_CLOSED) FUKUROU_DEPLOY_CRASH_AT=AFTER_GAP_CLOSE; printf 'CLOSED\n' > "${DB_STATE_ROOT}/gaps/${deployment_id}" ;;
  esac
  if (resume_launches >/dev/null 2>&1); then
    echo "deploy-runtime-selftest: crash injection did not interrupt ${terminal_state}" >&2
    exit 1
  fi
  unset FUKUROU_DEPLOY_CRASH_AT FUKUROU_DEPLOY_CRASH_MODE
  [[ "$(tail -n 1 "${state_dir}/journal.jsonl" | jq -r '.state')" == "${expected_state}" ]]
}

