PRODUCTION_TIMEOUT_DEFINITION="$(declare -f timeout | sed '1s/^timeout/production_timeout/')"

boottime_seconds() { printf '1\n'; }

DB_CALLS="${SELFTEST_ROOT}/db-calls"
DOCKER_CALLS="${SELFTEST_ROOT}/docker-calls"
GIT_CALLS="${SELFTEST_ROOT}/git-calls"
DB_STATE_ROOT="${SELFTEST_ROOT}/db-state"
mkdir -p "${DB_STATE_ROOT}/gaps"
OBSERVATION_MODE=stopped
DB_MODE=success

timeout() {
  shift
  if [[ "$1" == "${DB_HELPER}" ]]; then
    shift
    printf '%s\n' "$*" >> "${DB_CALLS}"
    [[ "${DB_MODE}" == success ]] || return 1
    case "${1:-}" in
      timestamp) printf '2026-01-01T00:00:00.000000Z\n' ;;
      snapshot)
        if [[ -n "${DB_RUNTIME_SNAPSHOT:-}" ]]; then
          printf '%s\n' "${DB_RUNTIME_SNAPSHOT}"
        else
          printf '{"runtimeConfigVersion":"fixture","runtimeConfigHash":"fixture"}\n'
        fi
        ;;
      active-launch-count) printf '%s\n' "${ACTIVE_LAUNCH_COUNT_MODE:-0}" ;;
      gap-state)
        [[ -f "${DB_STATE_ROOT}/gaps/${2}" ]] && cat "${DB_STATE_ROOT}/gaps/${2}" || printf 'MISSING\n'
        ;;
      maintenance-cas)
        printf '%s|%s|%s\n' "$5" "$6" "$7" > "${DB_STATE_ROOT}/maintenance"
        ;;
      ensure-maintenance)
        printf '%s|true|%s\n' "$2" "$3" > "${DB_STATE_ROOT}/maintenance"
        ;;
      append-gap)
        case "$3" in
          OPEN) printf 'OPEN\n' > "${DB_STATE_ROOT}/gaps/${2}" ;;
          CLOSE) printf 'CLOSED\n' > "${DB_STATE_ROOT}/gaps/${2}" ;;
          *) return 1 ;;
        esac
        ;;
      *) printf '1\n' ;;
    esac
    return 0
  fi
  [[ "$1" != bash ]] || return 0
  "$@"
}

git() {
  printf '%s|%s\n' "${DEPLOYMENT_ID:-}" "$*" >> "${GIT_CALLS}"
  if [[ "${USE_REAL_GIT:-false}" == true ]]; then
    command git "$@"
  else
    return 0
  fi
}
docker() {
  local operation="${1:-}" argument="${2:-}" control="" generation=""
  printf '%s|%s\n' "${DEPLOYMENT_ID:-}" "$*" >> "${DOCKER_CALLS}"
  case "${operation}" in
    exec)
      if [[ "$*" == *" test -x "* ]]; then
        [[ "${SUPERVISOR_PRESENT_MODE:-present}" == present ]] || return 1
        return 0
      fi
      while [[ "$#" -gt 0 ]]; do
        if [[ "$1" == --control ]]; then control="$2"; generation="$3"; break; fi
        shift
      done
      if [[ -n "${control}" && "${DEPLOYMENT_ID:-}" == fixture-rfo-* ]]; then
        return 1
      fi
      [[ -z "${control}" ]] || printf 'ACK %s %s\n' "${control}" "${generation}"
      ;;
    top)
      [[ "${OBSERVATION_MODE}" != top-failed && "${OBSERVATION_MODE}" != top-failed-running ]] || return 1
      printf 'PID UID\n'
      [[ "${OBSERVATION_MODE}" != children ]] || printf '11 10001\n12 10002\n13 10003\n'
      [[ "${OBSERVATION_MODE}" == children ]] || printf '11 10001\n'
      ;;
    inspect)
      [[ "${OBSERVATION_MODE}" != failed ]] || return 1
      [[ "${OBSERVATION_MODE}" != absent ]] || return 1
      case "${3:-}" in
        *State.Running*)
          case "${OBSERVATION_MODE}" in
            running|top-failed-running) printf 'true|42\n' ;;
            absent) return 1 ;;
            *) printf 'false|0\n' ;;
          esac
          ;;
        *Config.Image*) printf 'ghcr.io/matsumo0922/fukurou@sha256:%064d\n' 0 ;;
        *Config.Env*) printf 'FUKUROU_REVISION=%s\n' "${CURRENT_REVISION:-$(printf '%040d' 0)}" ;;
        *) printf 'fixture\n' ;;
      esac
      ;;
    container)
      [[ "${OBSERVATION_MODE}" != failed ]] || return 1
      [[ "${OBSERVATION_MODE}" != absent ]] || return 0
      printf 'fukurou-ktor\n'
      ;;
    compose)
      [[ "${CANARY_REVOKE_MODE:-success}" != fail || "$*" != *" down "* ]] || return 1
      [[ "${FUKUROU_IMAGE_REFERENCE:-}" =~ ^ghcr.io/matsumo0922/fukurou@sha256:[0-9a-f]{64}$ ]]
      [[ "${FUKUROU_IMAGE_TAG:-}" == "${FUKUROU_IMAGE_REFERENCE}" ]]
      ;;
    pull|image|images|rmi) return 0 ;;
    *) return 0 ;;
  esac
}

