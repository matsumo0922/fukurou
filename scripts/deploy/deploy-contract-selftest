#!/usr/bin/env bash
set -Eeuo pipefail

readonly SCRIPT_DIRECTORY="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SELFTEST_HARNESS="$(mktemp)"
SELFTEST_HARNESS_SQL="$(mktemp)"
SELFTEST_DEPLOY_ROOT="$(mktemp -d)"
printf '%s\n' '#!/bin/sh' 'set -eu' \
  'if [ "${1:-}" = --cli-acceptance ]; then' \
  '  [ "${FUKUROU_CANARY_DOCKER+x}${FUKUROU_FOUNDATION_HARNESS+x}${FUKUROU_CLI_CANARY_SELFTEST+x}" = "" ]' \
  '  printf "%s\n" "$*" > "$SELFTEST_ACCEPTANCE_LOG"' \
  '  [ "${SELFTEST_ACCEPTANCE_FAIL:-false}" != true ] || { echo raw-provider-output >&2; exit 7; }' \
  '  echo "CLI_ACCEPTANCE_SMOKE_V1 OK digest=$5 runs=1 selftest=false"' \
  'fi' > "${SELFTEST_HARNESS}"
printf '%s\n' 'SELECT 1;' > "${SELFTEST_HARNESS_SQL}"
chmod 0755 "${SELFTEST_HARNESS}"
export FUKUROU_FOUNDATION_HARNESS="${SELFTEST_HARNESS}"
export FUKUROU_FOUNDATION_HARNESS_SQL="${SELFTEST_HARNESS_SQL}"
export FUKUROU_DEPLOY_ROOT="${SELFTEST_DEPLOY_ROOT}"
source "${SCRIPT_DIRECTORY}/deploy-fukurou"

timeout() {
  shift
  "$@"
}

fail_selftest() {
  echo "deploy-contract-selftest: $*" >&2
  exit 1
}

expect_rejected() {
  local name="$1"
  shift
  if "$@"; then fail_selftest "${name} was accepted"; fi
}

signature_test_root="$(mktemp -d)"
openssl genpkey -algorithm ED25519 -out "${signature_test_root}/private.pem" >/dev/null 2>&1
openssl pkey -in "${signature_test_root}/private.pem" -pubout -out "${signature_test_root}/public.pem" >/dev/null 2>&1
printf '%s' '{"candidateSha":"0123456789abcdef0123456789abcdef01234567"}' > "${signature_test_root}/bundle.json"
openssl pkeyutl -sign -rawin -inkey "${signature_test_root}/private.pem" \
  -in "${signature_test_root}/bundle.json" -out "${signature_test_root}/bundle.sig"
verify_bundle_signature \
  "${signature_test_root}/bundle.json" \
  "${signature_test_root}/bundle.sig" \
  "${signature_test_root}/public.pem" || \
  fail_selftest "regular-file signature rejected"
printf 'x' >> "${signature_test_root}/bundle.json"
expect_rejected tampered-regular-file-signature \
  verify_bundle_signature \
  "${signature_test_root}/bundle.json" \
  "${signature_test_root}/bundle.sig" \
  "${signature_test_root}/public.pem"
rm -rf "${signature_test_root}"

installed_catalog="$(jq -cS . "${SCRIPT_DIRECTORY}/deploy-capability-catalog-v1.json")"
installed_hash="$(printf '%s' "${installed_catalog}" | sha256sum | awk '{print $1}')"
[[ "$(jq -er '.capabilityCatalogHash' "${SCRIPT_DIRECTORY}/deploy-contract-v1.json")" == "${installed_hash}" ]] || \
  fail_selftest "static contract catalog hash is stale"
jq -e '
  .title == "Fukurou signed deploy bundle v2" and
  (.required | index("bundleSchemaVersion")) != null and
  (.required | index("workflowEvent")) != null and
  (.required | index("deployIntent")) != null and
  (.required | index("operatorReason")) != null and
  (.required | index("migrationRollbackMode")) != null and
  (.required | index("schemaSensitivePathsSha256")) != null and
  (.required | index("foundationHarnessSha256")) != null and
  (.allOf[0].oneOf | length) == 4 and
  any(.allOf[0].oneOf[];
    .properties.workflowEvent.const == "push" and
    .properties.deployIntent.const == "FORWARD" and
    .properties.operatorReason.const == "" and
    .properties.migrationRollbackMode.const == "AUTO_IMAGE_ROLLBACK") and
  any(.allOf[0].oneOf[];
    .properties.workflowEvent.const == "workflow_dispatch" and
    .properties.deployIntent.const == "FORWARD" and
    .properties.operatorReason.const == "" and
    .properties.migrationRollbackMode.const == "AUTO_IMAGE_ROLLBACK") and
  any(.allOf[0].oneOf[];
    .properties.workflowEvent.const == "workflow_dispatch" and
    .properties.deployIntent.const == "FORWARD" and
    .properties.operatorReason.minLength == 1 and
    .properties.migrationRollbackMode.enum == ["BACKWARD_COMPATIBLE", "ROLL_FORWARD_ONLY"]) and
  any(.allOf[0].oneOf[];
    .properties.workflowEvent.const == "workflow_dispatch" and
    .properties.deployIntent.const == "AUTHORIZED_ROLLBACK" and
    .properties.operatorReason.minLength == 1) and
  .properties.bundleSchemaVersion.const == 2 and
  .properties.minimumContractVersion.const == 2 and
  .properties.operatorReason.pattern == "^(?:$|\\S(?:[^\\u0000-\\u001f\\u007f]*\\S)?)$" and
  .properties.foundationHarnessSha256.pattern == "^[0-9a-f]{64}$"
' "${SCRIPT_DIRECTORY}/deploy-bundle.schema.json" >/dev/null || \
  fail_selftest "bundle schema does not require the signed foundation harness hash"
baseline_bundle="$(jq -cS -n --argjson catalog "${installed_catalog}" '
  {minimumContractVersion:2,deployIntent:"AUTHORIZED_ROLLBACK",
   requiredCapabilities:[$catalog.builtInCapabilities[].capabilityId],
   requiredHooks:["FOUNDATION_PREFLIGHT_V1"],
   operations:[$catalog.operations[] |
     select(.profile=="EXECUTOR_STAGE_V1" or .operationId=="FOUNDATION_PREFLIGHT_V1") |
     {capability:.capabilityId,operationId:.operationId}]}
')"
validate_typed_operation_set "${baseline_bundle}" "${installed_catalog}" || fail_selftest "baseline rejected"
forward_bundle="$(jq -cS '
  .deployIntent="FORWARD" |
  .requiredHooks=["CLI_AUTH_PREFLIGHT_V1","FOUNDATION_PREFLIGHT_V1"] |
  .operations |= (map(select(.operationId != "FOUNDATION_PREFLIGHT_V1")) +
    [{capability:"SMOKE_HOOK_V1",operationId:"CLI_AUTH_PREFLIGHT_V1"},
     {capability:"SMOKE_HOOK_V1",operationId:"FOUNDATION_PREFLIGHT_V1"}])
' <<<"${baseline_bundle}")"
validate_typed_operation_set "${forward_bundle}" "${installed_catalog}" || fail_selftest "forward hook set rejected"
expect_rejected missing-cli-forward validate_typed_operation_set \
  "$(jq -cS '.deployIntent="FORWARD"' <<<"${baseline_bundle}")" "${installed_catalog}"
expect_rejected cli-on-rollback validate_typed_operation_set \
  "$(jq -cS '.deployIntent="AUTHORIZED_ROLLBACK"' <<<"${forward_bundle}")" "${installed_catalog}"
expect_rejected reordered-forward-hooks validate_typed_operation_set \
  "$(jq -cS '.requiredHooks |= reverse' <<<"${forward_bundle}")" "${installed_catalog}"

intent_bundle="$(jq -cS -n --argjson catalog "${installed_catalog}" '
  {deploymentId:"selftest",bundleSchemaVersion:2,workflowEvent:"push",deployIntent:"FORWARD",operatorReason:"",
   migrationRollbackMode:"AUTO_IMAGE_ROLLBACK",schemaSensitivePathsSha256:("a" * 64),
   candidateSha:("b" * 40),candidateImageDigest:("sha256:" + ("c" * 64)),minimumContractVersion:2,
   requiredCapabilities:[],requiredHooks:[],capabilityCatalog:$catalog,capabilityCatalogHash:("d" * 64),
   executorSha256:("e" * 64),foundationHarnessSha256:("f" * 64),publicKeySha256:("0" * 64),operations:[]}
')"
validate_deploy_intent_fields "${intent_bundle}" || fail_selftest "valid push intent rejected"
expect_rejected push-authorized-rollback validate_deploy_intent_fields \
  "$(jq -cS '.deployIntent="AUTHORIZED_ROLLBACK" | .operatorReason="operator approved"' <<<"${intent_bundle}")"
expect_rejected explicit-mode-empty-reason validate_deploy_intent_fields \
  "$(jq -cS '.workflowEvent="workflow_dispatch" | .migrationRollbackMode="ROLL_FORWARD_ONLY"' <<<"${intent_bundle}")"
for secret_reason in \
  'password=correct-horse-battery-staple' \
  'Bearer abcdefghijklmnopqrstuvwxyz' \
  'postgresql://user:password@example.invalid/db' \
  '-----BEGIN PRIVATE KEY-----' \
  'github_pat_abcdefghijklmnopqrstuvwxyz123456'; do
  expect_rejected secret-like-reason validate_deploy_intent_fields \
    "$(jq -cS --arg reason "${secret_reason}" '.workflowEvent="workflow_dispatch" | .deployIntent="AUTHORIZED_ROLLBACK" | .operatorReason=$reason' <<<"${intent_bundle}")"
done
manual_rollback_bundle="$(jq -cS '
  .workflowEvent="workflow_dispatch" | .deployIntent="AUTHORIZED_ROLLBACK" | .operatorReason="incident rollback"
' <<<"${intent_bundle}")"
validate_deploy_intent_fields "${manual_rollback_bundle}" || fail_selftest "valid authorized rollback rejected"
expect_rejected tampered-intent-field validate_deploy_intent_fields \
  "$(jq -cS '.workflowEvent="push"' <<<"${manual_rollback_bundle}")"

validate_schema_sensitive_inventory "${SCRIPT_DIRECTORY}/deploy-schema-sensitive-paths-v1.txt" || \
  fail_selftest "repository schema-sensitive inventory rejected"
inventory_hash="$(schema_sensitive_inventory_hash "${SCRIPT_DIRECTORY}/deploy-schema-sensitive-paths-v1.txt")"
[[ "${inventory_hash}" =~ ^[0-9a-f]{64}$ ]] || \
  fail_selftest "schema-sensitive inventory hash is invalid"
inventory_copy="$(mktemp)"
cp "${SCRIPT_DIRECTORY}/deploy-schema-sensitive-paths-v1.txt" "${inventory_copy}"
validate_schema_sensitive_inventory_agreement \
  "${inventory_hash}" "${SCRIPT_DIRECTORY}/deploy-schema-sensitive-paths-v1.txt" "${inventory_copy}" false || \
  fail_selftest "matching schema-sensitive inventories rejected"
printf 'tampered/path\n' >> "${inventory_copy}"
expect_rejected inventory-hash-mismatch validate_schema_sensitive_inventory_agreement \
  "${inventory_hash}" "${SCRIPT_DIRECTORY}/deploy-schema-sensitive-paths-v1.txt" "${inventory_copy}" false
rm -f "${inventory_copy}"

superset_catalog="$(jq -cS --arg parent "${installed_hash}" '
  .catalogVersion=2 | .parentCatalogHash=$parent |
  .hooks += [{hookId:"FOUNDATION_RECOVERY_PROBE_V2",profile:"CANDIDATE_HOOK_V1",entrypoint:["--canary-preflight","recovery-v2"]}] |
  .operations += [{capabilityId:"SMOKE_HOOK_V1",operationId:"FOUNDATION_RECOVERY_PROBE_V2",parameterSchemaId:"SMOKE_HOOK_FOUNDATION_V1",profile:"CANDIDATE_HOOK_V1",entrypoint:["--canary-preflight","recovery-v2"]}]
' <<<"${installed_catalog}")"
superset_bundle="$(jq -cS '
  .requiredHooks += ["FOUNDATION_RECOVERY_PROBE_V2"] |
  .operations += [{capability:"SMOKE_HOOK_V1",operationId:"FOUNDATION_RECOVERY_PROBE_V2"}]
' <<<"${baseline_bundle}")"
validate_catalog_extension "${installed_catalog}" "${superset_catalog}" "${installed_hash}" || fail_selftest "superset catalog rejected"
expect_rejected undeclared-intent-hook validate_typed_operation_set "${superset_bundle}" "${superset_catalog}"
CANDIDATE_CATALOG="${superset_catalog}"
SIGNED_BUNDLE_JSON="${superset_bundle}"
[[ "$(required_operation_plan CANDIDATE_HOOK_V1 | jq -s 'length')" == "2" ]] || fail_selftest "accepted required hook missing from dispatch plan"

deleted_bundle="$(jq -cS '.operations |= map(select(.operationId != "CLEAR_LAUNCH_MAINTENANCE"))' <<<"${baseline_bundle}")"
expect_rejected bundle-deletion validate_typed_operation_set "${deleted_bundle}" "${installed_catalog}"
deleted_catalog="$(jq -cS --arg parent "${installed_hash}" '.catalogVersion=2|.parentCatalogHash=$parent|.operations|=map(select(.operationId!="CLEAR_LAUNCH_MAINTENANCE"))' <<<"${installed_catalog}")"
expect_rejected catalog-deletion validate_catalog_extension "${installed_catalog}" "${deleted_catalog}" "${installed_hash}"
redefined_catalog="$(jq -cS --arg parent "${installed_hash}" '.catalogVersion=2|.parentCatalogHash=$parent|(.operations[]|select(.operationId=="PRODUCTION").capabilityId)="SMOKE_HOOK_V1"' <<<"${installed_catalog}")"
expect_rejected catalog-redefinition validate_catalog_extension "${installed_catalog}" "${redefined_catalog}" "${installed_hash}"
forked_catalog="$(jq -cS '.catalogVersion=2|.parentCatalogHash=("0" * 64)' <<<"${installed_catalog}")"
expect_rejected catalog-fork validate_catalog_extension "${installed_catalog}" "${forked_catalog}" "${installed_hash}"
downgraded_catalog="$(jq -cS --arg parent "${installed_hash}" '.catalogVersion=1|.parentCatalogHash=$parent' <<<"${installed_catalog}")"
expect_rejected catalog-downgrade validate_catalog_extension "${installed_catalog}" "${downgraded_catalog}" "${installed_hash}"
duplicate_catalog="$(jq -cS '.operations += [.operations[0]]' <<<"${installed_catalog}")"
expect_rejected duplicate-operation validate_catalog_dispatchability "${duplicate_catalog}"
unsupported_schema_catalog="$(jq -cS '(.operations[]|select(.operationId=="FOUNDATION_PREFLIGHT_V1").parameterSchemaId)="UNKNOWN_V2"' <<<"${installed_catalog}")"
expect_rejected unsupported-schema validate_catalog_dispatchability "${unsupported_schema_catalog}"
unsupported_profile_catalog="$(jq -cS '(.operations[]|select(.operationId=="FOUNDATION_PREFLIGHT_V1").profile)="UNSUPPORTED_V2"' <<<"${installed_catalog}")"
expect_rejected unsupported-profile validate_catalog_dispatchability "${unsupported_profile_catalog}"
bad_entrypoint_catalog="$(jq -cS '(.operations[]|select(.operationId=="FOUNDATION_PREFLIGHT_V1").entrypoint)=["/bin/sh","-c"]' <<<"${installed_catalog}")"
expect_rejected unsupported-entrypoint validate_catalog_dispatchability "${bad_entrypoint_catalog}"

CANDIDATE_DIGEST="sha256:$(printf 'a%.0s' {1..64})"
CANDIDATE_CATALOG_HASH="${installed_hash}"
CANDIDATE_CATALOG="${installed_catalog}"
SIGNED_BUNDLE_JSON="${baseline_bundle}"
PROBED_HOOKS=""
docker() {
  if [[ "$1" == image && "$2" == inspect ]]; then
    printf '%s@%s\n' "${IMAGE_REPOSITORY}" "${CANDIDATE_DIGEST}"
    return 0
  fi
  if [[ "$1" == run ]]; then
    case " $* " in
      *" CLI_AUTH_PREFLIGHT_V1 SMOKE_HOOK_FOUNDATION_V1 CANDIDATE_HOOK_V1 cli-auth "*) PROBED_HOOKS="${PROBED_HOOKS}cli," ;;
      *" FOUNDATION_PREFLIGHT_V1 SMOKE_HOOK_FOUNDATION_V1 CANDIDATE_HOOK_V1 foundation "*) PROBED_HOOKS="${PROBED_HOOKS}foundation," ;;
      *) return 1 ;;
    esac
    return
  fi
  return 0
}
probe_candidate_operations || fail_selftest "exact candidate foundation probe rejected"
SIGNED_BUNDLE_JSON="${forward_bundle}"
probe_candidate_operations || fail_selftest "exact candidate forward probes rejected"
[[ "${PROBED_HOOKS}" == "foundation,cli,foundation," ]] || fail_selftest "candidate hook probe order drifted"
CANDIDATE_CATALOG="${superset_catalog}"
SIGNED_BUNDLE_JSON="${superset_bundle}"
expect_rejected future-image-operation probe_candidate_operations

ROLLBACK_STATE_DIR="$(mktemp -d)"
DISPATCHED_OPERATION_IDS=""
record_operation_dispatch FOUNDATION_PREFLIGHT_V1
record_operation_dispatch PRODUCTION
[[ "$(wc -l < "${ROLLBACK_STATE_DIR}/operation-dispatch.jsonl" | tr -d ' ')" == 2 ]] || fail_selftest "durable dispatch ledger missing entries"
expect_rejected duplicate-durable-dispatch record_operation_dispatch PRODUCTION
MUTATION_COUNT=0
harness_hash="$(sha256sum "${SELFTEST_HARNESS}" "${SELFTEST_HARNESS_SQL}" | awk '{print $1}' | sha256sum | awk '{print $1}')"
validate_foundation_harness_hash "${harness_hash}" || fail_selftest "signed harness hash rejected"
expect_rejected tampered-harness-mutation0 validate_foundation_harness_hash "$(printf '0%.0s' {1..64})"
[[ "${MUTATION_COUNT}" == 0 ]] || fail_selftest "harness mismatch mutated state"

DEPLOY_INTENT=FORWARD
CANDIDATE_DIGEST="sha256:$(printf 'c%.0s' {1..64})"
SELFTEST_ACCEPTANCE_LOG="${SELFTEST_DEPLOY_ROOT}/acceptance-argv"
export SELFTEST_ACCEPTANCE_LOG FUKUROU_CANARY_DOCKER=fake FUKUROU_CLI_CANARY_SELFTEST=true
run_cli_acceptance_gate || fail_selftest "one-run CLI acceptance gate rejected"
[[ "$(cat "${SELFTEST_ACCEPTANCE_LOG}")" == \
  "--cli-acceptance --runs 1 --reuse-image ${IMAGE_REPOSITORY}@${CANDIDATE_DIGEST}" ]] || \
  fail_selftest "CLI acceptance argv drifted"
SELFTEST_ACCEPTANCE_FAIL=true
export SELFTEST_ACCEPTANCE_FAIL
acceptance_failure="${SELFTEST_DEPLOY_ROOT}/acceptance-failure"
expect_rejected cli-acceptance-failure run_cli_acceptance_gate 2>"${acceptance_failure}"
! grep -Fq raw-provider-output "${acceptance_failure}" || fail_selftest "raw CLI failure escaped artifact"
artifact_dir="$(sed -n 's/.*artifacts=//p' "${acceptance_failure}")"
[[ -d "${artifact_dir}" ]] || fail_selftest "CLI failure artifact was not preserved"
rm -rf -- "${artifact_dir}"
unset SELFTEST_ACCEPTANCE_FAIL FUKUROU_CANARY_DOCKER FUKUROU_CLI_CANARY_SELFTEST

echo "DEPLOY_CONTRACT_SELFTEST_OK signature=regular-file-accepted-tamper-rejected superset=accepted-dispatched exact-image-probe=future-rejected-mutation0 durable-dispatch=recorded deletion=rejected redefinition=rejected fork=rejected downgrade=rejected schema-profile-entrypoint-duplicates=rejected"
