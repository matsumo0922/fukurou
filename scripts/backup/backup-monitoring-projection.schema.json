{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fukurou.matsumo.me/schemas/backup-monitoring-projection-v1.json",
  "title": "Fukurou public backup monitoring projection v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "publishedAt", "backup", "restore"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "publishedAt": { "$ref": "#/$defs/timestamp" },
    "backup": { "$ref": "#/$defs/job" },
    "restore": { "$ref": "#/$defs/job" }
  },
  "$defs": {
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "invocationId": { "type": "string", "pattern": "^[0-9a-f]{32}$" },
    "bootId": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "startedAt", "terminalAt", "terminalSemantic", "invocationId", "bootId"],
      "properties": {
        "state": { "enum": ["RUNNING", "TERMINAL"] },
        "startedAt": { "$ref": "#/$defs/timestamp" },
        "terminalAt": { "anyOf": [{ "type": "null" }, { "$ref": "#/$defs/timestamp" }] },
        "terminalSemantic": {
          "anyOf": [{ "type": "null" }, { "enum": ["SUCCESS", "FAILURE", "UNKNOWN"] }]
        },
        "invocationId": { "$ref": "#/$defs/invocationId" },
        "bootId": { "$ref": "#/$defs/bootId" }
      }
    },
    "attempt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attemptedAt", "resultCode", "invocationId", "bootId"],
      "properties": {
        "attemptedAt": { "$ref": "#/$defs/timestamp" },
        "resultCode": {
          "enum": [
            "BACKUP_BUSY",
            "BACKUP_SIGNALLED",
            "CAPACITY_FLOOR_NOT_MET",
            "DEPLOY_IN_PROGRESS",
            "DUMP_FAILED",
            "INTEGRITY_CHECK_FAILED",
            "INVALID_CONFIGURATION",
            "INVALID_STATUS",
            "PARTIAL_SNAPSHOT_FORGET_FAILED",
            "REPOSITORY_FAILED",
            "RESTORE_CLEANUP_FAILED",
            "RESTORE_PROFILE_FAILED",
            "RESTORE_SIGNALLED",
            "RESTORE_SNAPSHOT_FAILED",
            "RESTORE_START_FAILED",
            "RESTORE_TIMEOUT",
            "RETENTION_FAILED",
            "SNAPSHOT_IDENTITY_FAILED",
            "STATUS_PUBLICATION_FAILED",
            "SUCCESS",
            "WATCHDOG_TERMINATION_FAILED"
          ]
        },
        "invocationId": { "$ref": "#/$defs/invocationId" },
        "bootId": { "$ref": "#/$defs/bootId" }
      }
    },
    "job": {
      "type": "object",
      "additionalProperties": false,
      "required": ["service", "lastAttempt", "lastSuccessAt"],
      "properties": {
        "service": { "anyOf": [{ "type": "null" }, { "$ref": "#/$defs/service" }] },
        "lastAttempt": { "anyOf": [{ "type": "null" }, { "$ref": "#/$defs/attempt" }] },
        "lastSuccessAt": { "anyOf": [{ "type": "null" }, { "$ref": "#/$defs/timestamp" }] }
      }
    }
  }
}
