#!/usr/bin/env bash
set -Eeuo pipefail

readonly DEFAULT_PUBLIC_DIRECTORY=/srv/fukurou/monitoring-public
readonly DEFAULT_AUTHORITATIVE_STATUS_FILE=/srv/fukurou/monitoring/backup-status.json
readonly DEFAULT_BACKUP_COMMON_FILE=/usr/local/libexec/fukurou/backup-common
readonly DEFAULT_BOOT_ID_FILE=/proc/sys/kernel/random/boot_id
readonly PROJECTION_FILE_NAME=backup-restore.json
readonly PROJECTION_LOCK_FILE=/var/lock/fukurou-monitoring-projection.lock

if [[ ${FUKUROU_MONITORING_PUBLISHER_SELFTEST:-false} == true ]]; then
    readonly PUBLIC_DIRECTORY=${FUKUROU_MONITORING_PUBLIC_DIRECTORY:?selftest public directory is required}
    readonly AUTHORITATIVE_STATUS_FILE=${FUKUROU_BACKUP_STATUS_FILE:?selftest status file is required}
    readonly BACKUP_COMMON_FILE=${FUKUROU_BACKUP_COMMON_FILE:?selftest backup-common is required}
    readonly BOOT_ID_FILE=${FUKUROU_SERVICE_BOOT_ID_FILE:?selftest boot ID file is required}
    readonly LOCK_FILE=${FUKUROU_MONITORING_LOCK_FILE:?selftest lock file is required}
else
    readonly PUBLIC_DIRECTORY=${DEFAULT_PUBLIC_DIRECTORY}
    readonly AUTHORITATIVE_STATUS_FILE=${DEFAULT_AUTHORITATIVE_STATUS_FILE}
    readonly BACKUP_COMMON_FILE=${DEFAULT_BACKUP_COMMON_FILE}
    readonly BOOT_ID_FILE=${DEFAULT_BOOT_ID_FILE}
    readonly LOCK_FILE=${PROJECTION_LOCK_FILE}
fi
readonly PROJECTION_FILE=${PUBLIC_DIRECTORY}/${PROJECTION_FILE_NAME}

die() {
    printf 'publish-backup-monitoring: %s\n' "$1" >&2
    exit "${2:-1}"
}

require_root() {
    if [[ ${FUKUROU_MONITORING_PUBLISHER_SELFTEST:-false} != true ]]; then
        [[ ${EUID} -eq 0 ]] || die 'root is required' 77
    fi
}

timestamp_now() {
    date -u '+%Y-%m-%dT%H:%M:%SZ'
}

current_invocation_id() {
    local invocation_id=${INVOCATION_ID:-}

    invocation_id=$(printf '%s' "${invocation_id}" | tr '[:upper:]' '[:lower:]')
    [[ ${invocation_id} =~ ^[0-9a-f]{32}$ ]] || return 1
    printf '%s\n' "${invocation_id}"
}

current_boot_id() {
    local boot_id

    [[ -f ${BOOT_ID_FILE} && ! -L ${BOOT_ID_FILE} ]] || return 1
    boot_id=$(<"${BOOT_ID_FILE}")
    boot_id=$(printf '%s' "${boot_id}" | tr '[:upper:]' '[:lower:]')
    [[ ${boot_id} =~ ^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$ ]] || return 1
    printf '%s\n' "${boot_id}"
}

empty_projection() {
    local published_at=$1

    jq -cn --arg published_at "${published_at}" '
        {
          schemaVersion: 1,
          publishedAt: $published_at,
          backup: {service: null, lastAttempt: null, lastSuccessAt: null},
          restore: {service: null, lastAttempt: null, lastSuccessAt: null}
        }
    '
}

validate_projection() {
    jq -e '
      def timestamp: type == "string" and test("^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$");
      def invocation: type == "string" and test("^[0-9a-f]{32}$");
      def boot: type == "string" and test("^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$");
      def exact_keys($keys): (keys | sort) == ($keys | sort);
      def service:
        . == null or (
          type == "object" and
          exact_keys(["bootId", "invocationId", "startedAt", "state", "terminalAt", "terminalSemantic"]) and
          (.state == "RUNNING" or .state == "TERMINAL") and (.startedAt | timestamp)
        );
      def valid_service:
        service and
        if . == null then true else
          (.invocationId | invocation) and (.bootId | boot) and
          if .state == "RUNNING" then .terminalAt == null and .terminalSemantic == null
          else (.terminalAt | timestamp) and (.terminalSemantic | IN("SUCCESS", "FAILURE", "UNKNOWN")) end
        end;
      def attempt:
        . == null or (
          type == "object" and exact_keys(["attemptedAt", "bootId", "invocationId", "resultCode"]) and
          (.attemptedAt | timestamp) and
          (.resultCode | IN(
            "BACKUP_BUSY", "BACKUP_SIGNALLED", "CAPACITY_FLOOR_NOT_MET", "DEPLOY_IN_PROGRESS",
            "DUMP_FAILED", "INTEGRITY_CHECK_FAILED", "INVALID_CONFIGURATION", "INVALID_STATUS",
            "PARTIAL_SNAPSHOT_FORGET_FAILED", "REPOSITORY_FAILED", "RESTORE_CLEANUP_FAILED",
            "RESTORE_PROFILE_FAILED", "RESTORE_SIGNALLED", "RESTORE_SNAPSHOT_FAILED", "RESTORE_START_FAILED",
            "RESTORE_TIMEOUT", "RETENTION_FAILED", "SNAPSHOT_IDENTITY_FAILED", "STATUS_PUBLICATION_FAILED",
            "SUCCESS", "WATCHDOG_TERMINATION_FAILED"
          )) and
          (.invocationId | invocation) and (.bootId | boot)
        );
      def job:
        type == "object" and exact_keys(["lastAttempt", "lastSuccessAt", "service"]) and
        (.service | valid_service) and (.lastAttempt | attempt) and
        (.lastSuccessAt == null or (.lastSuccessAt | timestamp));
      type == "object" and exact_keys(["backup", "publishedAt", "restore", "schemaVersion"]) and
      .schemaVersion == 1 and (.publishedAt | timestamp) and (.backup | job) and (.restore | job)
    ' >/dev/null
}

load_projection() {
    local published_at=$1 document

    if [[ ! -e ${PROJECTION_FILE} ]]; then
        empty_projection "${published_at}"
        return
    fi
    [[ -f ${PROJECTION_FILE} && ! -L ${PROJECTION_FILE} ]] || return 1
    document=$(<"${PROJECTION_FILE}")
    validate_projection <<<"${document}" || return 1
    printf '%s\n' "${document}"
}

sync_projection_path() {
    local path=$1

    # GNU sync -d issues fdatasync for the selected path. BSD variants do not
    # expose that mode, so retain the existing filesystem-sync fallback.
    sync -d "${path}" 2>/dev/null || sync -f "${path}"
}

publish_projection() {
    local candidate=$1 temporary

    validate_projection <<<"${candidate}" || return 1
    temporary=$(mktemp "${PUBLIC_DIRECTORY}/.${PROJECTION_FILE_NAME}.tmp.XXXXXX") || return 1
    if ! printf '%s\n' "${candidate}" >"${temporary}" || ! chmod 0444 "${temporary}"; then
        rm -f -- "${temporary}"
        return 1
    fi
    if [[ ${FUKUROU_MONITORING_PUBLISHER_SELFTEST:-false} != true ]] &&
        ! chown root:root "${temporary}" 2>/dev/null; then
        rm -f -- "${temporary}"
        return 1
    fi
    if ! sync_projection_path "${temporary}"; then
        rm -f -- "${temporary}"
        return 1
    fi
    if [[ ${FUKUROU_MONITORING_PUBLISHER_SELFTEST:-false} == true &&
        ${FUKUROU_MONITORING_FAIL_BEFORE_RENAME:-false} == true ]]; then
        rm -f -- "${temporary}"
        return 1
    fi
    mv -f -- "${temporary}" "${PROJECTION_FILE}" || { rm -f -- "${temporary}"; return 1; }
    sync_projection_path "${PUBLIC_DIRECTORY}" || return 1
    return 0
}

read_authoritative_status() {
    local document

    [[ -f ${AUTHORITATIVE_STATUS_FILE} && ! -L ${AUTHORITATIVE_STATUS_FILE} ]] || return 1
    # shellcheck source=scripts/backup/backup-common
    source "${BACKUP_COMMON_FILE}"
    document=$(<"${AUTHORITATIVE_STATUS_FILE}")
    backup_validate_status_json "${document}" || return 1
    printf '%s\n' "${document}"
}

project_matching_authoritative_job() {
    local candidate=$1 job=$2 invocation_id=$3 boot_id=$4 authoritative=$5
    local attempted_at result_code last_success_at

    jq -e --arg job "${job}" --arg invocation_id "${invocation_id}" --arg boot_id "${boot_id}" '
      .[$job].lastAttempt.serviceInvocationId == $invocation_id and
      .[$job].lastAttempt.serviceBootId == $boot_id
    ' <<<"${authoritative}" >/dev/null || return 1
    attempted_at=$(jq -er --arg job "${job}" '.[$job].lastAttempt.attemptedAt' <<<"${authoritative}") || return 1
    result_code=$(jq -er --arg job "${job}" '.[$job].lastAttempt.resultCode' <<<"${authoritative}") || return 1
    last_success_at=$(jq -er --arg job "${job}" '.[$job].lastSuccess.verifiedAt // empty' <<<"${authoritative}") || true

    jq -c --arg job "${job}" --arg attempted_at "${attempted_at}" --arg result_code "${result_code}" \
        --arg invocation_id "${invocation_id}" --arg boot_id "${boot_id}" --arg last_success_at "${last_success_at}" '
      .[$job].lastAttempt = {
        attemptedAt: $attempted_at,
        resultCode: $result_code,
        invocationId: $invocation_id,
        bootId: $boot_id
      } |
      .[$job].lastSuccessAt = (if $last_success_at == "" then null else $last_success_at end)
    ' <<<"${candidate}"
}

publish_start() {
    local job=$1 invocation_id boot_id published_at candidate

    invocation_id=$(current_invocation_id) || die 'systemd invocation ID is invalid' 65
    boot_id=$(current_boot_id) || die 'boot ID is invalid' 65
    published_at=$(timestamp_now) || die 'timestamp is unavailable' 74
    candidate=$(load_projection "${published_at}") || die 'existing projection is invalid' 65
    candidate=$(jq -c --arg job "${job}" --arg published_at "${published_at}" \
        --arg invocation_id "${invocation_id}" --arg boot_id "${boot_id}" '
      .publishedAt = $published_at |
      .[$job].service = {
        state: "RUNNING",
        startedAt: $published_at,
        terminalAt: null,
        terminalSemantic: null,
        invocationId: $invocation_id,
        bootId: $boot_id
      }
    ' <<<"${candidate}") || die 'start projection composition failed' 74
    publish_projection "${candidate}" || die 'start projection publication failed' 74
}

publish_terminal() {
    local job=$1 service_result=$2 exit_code=$3 exit_status=$4
    local invocation_id boot_id published_at candidate authoritative terminal_semantic=FAILURE

    invocation_id=$(current_invocation_id) || die 'systemd invocation ID is invalid' 65
    boot_id=$(current_boot_id) || die 'boot ID is invalid' 65
    published_at=$(timestamp_now) || die 'timestamp is unavailable' 74
    candidate=$(load_projection "${published_at}") || die 'existing projection is invalid' 65
    jq -e --arg job "${job}" --arg invocation_id "${invocation_id}" --arg boot_id "${boot_id}" '
      .[$job].service.state == "RUNNING" and
      .[$job].service.invocationId == $invocation_id and
      .[$job].service.bootId == $boot_id
    ' <<<"${candidate}" >/dev/null || die 'terminal does not match running invocation' 65

    if [[ ${service_result} == success && ${exit_code} == exited && ${exit_status} == 0 ]]; then
        terminal_semantic=UNKNOWN
    fi
    if authoritative=$(read_authoritative_status); then
        if projected=$(project_matching_authoritative_job \
            "${candidate}" "${job}" "${invocation_id}" "${boot_id}" "${authoritative}"); then
            candidate=${projected}
            if [[ ${service_result} == success && ${exit_code} == exited && ${exit_status} == 0 &&
                $(jq -r --arg job "${job}" '.[$job].lastAttempt.resultCode' <<<"${authoritative}") == SUCCESS ]]; then
                terminal_semantic=SUCCESS
            fi
        fi
    elif [[ -e ${AUTHORITATIVE_STATUS_FILE} ]]; then
        die 'authoritative status is malformed or symbolic' 65
    fi

    candidate=$(jq -c --arg job "${job}" --arg published_at "${published_at}" \
        --arg terminal_semantic "${terminal_semantic}" '
      .publishedAt = $published_at |
      .[$job].service.state = "TERMINAL" |
      .[$job].service.terminalAt = $published_at |
      .[$job].service.terminalSemantic = $terminal_semantic
    ' <<<"${candidate}") || die 'terminal projection composition failed' 74
    publish_projection "${candidate}" || die 'terminal projection publication failed' 74
}

usage() {
    printf '%s\n' 'Usage: publish-backup-monitoring {start JOB|terminal JOB SERVICE_RESULT EXIT_CODE EXIT_STATUS}' >&2
    exit 64
}

main() {
    local action=${1:-} job=${2:-}

    require_root
    [[ ${job} == backup || ${job} == restore ]] || usage
    command -v jq >/dev/null || die 'jq is unavailable' 69
    command -v flock >/dev/null || die 'flock is unavailable' 69
    command -v sync >/dev/null || die 'sync is unavailable' 69
    [[ -d ${PUBLIC_DIRECTORY} && ! -L ${PUBLIC_DIRECTORY} ]] || die 'public directory is unavailable' 66
    exec 9>"${LOCK_FILE}" || die 'projection lock is unavailable' 74
    flock -x 9 || die 'projection lock cannot be acquired' 75

    case ${action} in
        start)
            [[ $# -eq 2 ]] || usage
            publish_start "${job}"
            ;;
        terminal)
            [[ $# -eq 5 ]] || usage
            publish_terminal "${job}" "$3" "$4" "$5"
            ;;
        *) usage ;;
    esac
}

if [[ ${BASH_SOURCE[0]} == "$0" ]]; then
    main "$@"
fi
