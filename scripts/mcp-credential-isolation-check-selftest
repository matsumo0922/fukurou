#!/bin/sh
set -eu

repo_root=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)
work=$(mktemp -d)
digest="example.invalid/fukurou@sha256:$(printf 'a%.0s' $(seq 1 64))"
trap 'rm -rf "$work"' EXIT HUP INT TERM

cat >"$work/docker" <<'EOF'
#!/bin/sh
set -eu
printf '%s\n' "$*" >>"$FAKE_DOCKER_LOG"
case "$1:$2" in
    image:inspect)
        echo "$FAKE_IMAGE"
        ;;
    volume:inspect)
        [ "${FAKE_AUTH_PRESENT:-true}" = true ]
        ;;
    run:--rm)
        case " $* " in *" --user 10001:10004 "*) ;; *) exit 91 ;; esac
        case " $* " in *" --read-only "*) ;; *) exit 91 ;; esac
        case " $* " in *" --cap-drop ALL "*) ;; *) exit 91 ;; esac
        case " $* " in *" type=volume,src=llm-canary-auth,dst=/canary-auth,readonly,volume-nocopy "*) ;; *) exit 91 ;; esac
        case " $* " in *" 720 /opt/java/openjdk/bin/java "*|*" 2160 /opt/java/openjdk/bin/java "*) ;; *) exit 91 ;; esac
        case " $* " in
            *"llm-auth"*|*"DB_PASSWORD"*|*"docker.sock"*|*"--network fukurou"*) exit 92 ;;
        esac
        if [ "${FAKE_PROVIDER_FAILURE:-false}" = typed ]; then
            echo "CLI_ACCEPTANCE_V1 FAIL code=TOOL_CALL phase=FALSIFIER iteration=1 adapter=future-adapter-v2 cleanup=FAILED"
            echo "raw-provider-secret-/credential/path" >&2
            exit 7
        elif [ "${FAKE_PROVIDER_FAILURE:-false}" = contaminated ]; then
            printf 'CLI_ACCEPTANCE_V1 FAIL code=TOOL_CALL phase=FALSIFIER iteration=1 adapter=future-adapter-v2 cleanup=FAILED\nraw-provider-secret'; exit 7
        elif [ "${FAKE_PROVIDER_FAILURE:-false}" = terminate ]; then
            kill -TERM "$(cat "$FAKE_HARNESS_PID_FILE")"
            exit 143
        fi
        repetitions=
        for argument in "$@"; do repetitions=$argument; done
        echo "CLI_ACCEPTANCE_V1 OK runs=$repetitions phases=4"
        echo "OpenJDK harmless warning" >&2
        ;;
    rm:-f) ;;
    *) exit 93 ;;
esac
EOF
chmod +x "$work/docker"

cat >"$work/foundation" <<'EOF'
#!/bin/sh
set -eu
[ "$1" = --reuse-image ]
[ "$2" = "$FAKE_IMAGE" ]
echo "foundation raw output is intentionally captured"
EOF
chmod +x "$work/foundation"
export FAKE_DOCKER_LOG="$work/docker.log" FAKE_IMAGE="$digest" FUKUROU_CANARY_DOCKER="$work/docker" FUKUROU_FOUNDATION_HARNESS="$work/foundation" FUKUROU_CLI_CANARY_SELFTEST=true

for phase in proposer falsifier; do
    if [ "$phase" = proposer ]; then probe=submit_decision; else probe=submit_falsification; fi
    manifest="cli-canary-$phase-1-fixture"
    record="/tmp/$manifest.calls"
    rm -f "$record"
    printf '%s\n' \
        '{"jsonrpc":"2.0","id":1,"method":"tools/list"}' \
        "{\"jsonrpc\":\"2.0\",\"id\":2,\"method\":\"tools/call\",\"params\":{\"name\":\"$probe\",\"arguments\":{}}}" | \
        FUKUROU_CLI_CANARY_RECORD_PATH="$record" node "$repo_root/scripts/runtime/fukurou-cli-canary-mcp.mjs" \
        "$manifest" >"$work/fixture-$phase.jsonl"
    grep -Fq '"text":"FUKUROU_CLI_CANARY_OK"' "$work/fixture-$phase.jsonl"
    grep -Fxq "$(printf '%s\t%s' "$(printf '%s' "$phase" | tr '[:lower:]' '[:upper:]')" "$probe")" "$record"
    rm -f "$record"
done
grep -Fq 'submit_decision' "$work/fixture-proposer.jsonl"
! grep -Fq 'submit_falsification' "$work/fixture-proposer.jsonl"
grep -Fq 'submit_falsification' "$work/fixture-falsifier.jsonl"
! grep -Fq 'submit_decision' "$work/fixture-falsifier.jsonl"
grep -Fq '"name":"submit_decision"' "$work/fixture-proposer.jsonl"
grep -Fq '"readOnlyHint":false' "$work/fixture-proposer.jsonl"
grep -Fq '"openWorldHint":true' "$work/fixture-proposer.jsonl"
grep -Fq '"openWorldHint":false' "$work/fixture-proposer.jsonl"

run_failure() {
    expected=$1
    shift
    : >"$work/docker.log"
    set +e
    "$repo_root/scripts/mcp-credential-isolation-check" "$@" \
        >"$work/stdout" 2>"$work/stderr"
    status=$?
    set -e
    [ "$status" -ne 0 ]
    [ ! -s "$work/stdout" ]
    grep -Eq "^CLI_ACCEPTANCE_HARNESS_V1 FAIL code=$expected( artifacts=/.*)?$" "$work/stderr" || {
        echo "unexpected failure expected=$expected:" >&2
        cat "$work/stderr" >&2
        cat "$work/docker.log" >&2
        return 1
    }
    artifact_path=$(sed -n 's/.* artifacts=//p' "$work/stderr")
    if [ -n "$artifact_path" ]; then [ -d "$artifact_path" ]; rm -rf "$artifact_path"; fi
}

run_failure REPETITION --cli-acceptance --runs 2 --reuse-image "$digest"
[ ! -s "$work/docker.log" ]
run_failure IMAGE_IDENTITY --qualification --runs 3 --reuse-image example.invalid/fukurou:latest
[ ! -s "$work/docker.log" ]

: >"$work/docker.log"
set +e
env FUKUROU_CANARY_DOCKER= FUKUROU_FOUNDATION_HARNESS= FUKUROU_CLI_CANARY_SELFTEST=false \
    "$repo_root/scripts/mcp-credential-isolation-check" --cli-acceptance --runs 1 --reuse-image "$digest" \
    >"$work/stdout" 2>"$work/stderr"
status=$?
set -e
[ "$status" -ne 0 ]
grep -Fxq 'CLI_ACCEPTANCE_HARNESS_V1 FAIL code=OVERRIDE_ENVIRONMENT' "$work/stderr"
[ ! -s "$work/docker.log" ]

FAKE_AUTH_PRESENT=false
export FAKE_AUTH_PRESENT
run_failure CANARY_AUTH_MISSING --cli-acceptance --runs 1 --reuse-image "$digest"
unset FAKE_AUTH_PRESENT
! grep -q '^run ' "$work/docker.log"

FAKE_PROVIDER_FAILURE=typed
export FAKE_PROVIDER_FAILURE
set +e
"$repo_root/scripts/mcp-credential-isolation-check" --cli-acceptance --runs 1 --reuse-image "$digest" \
    >"$work/stdout" 2>"$work/stderr"
status=$?
set -e
unset FAKE_PROVIDER_FAILURE
[ "$status" -ne 0 ]
[ ! -s "$work/stdout" ]
grep -Fxq 'CLI_ACCEPTANCE_V1 FAIL code=TOOL_CALL phase=FALSIFIER iteration=1 adapter=future-adapter-v2 cleanup=FAILED' "$work/stderr"
artifact_path=$(sed -n 's/^CLI_ACCEPTANCE_ARTIFACTS_V1 path=//p' "$work/stderr")
[ -d "$artifact_path" ]
rm -rf "$artifact_path"
! grep -Fq 'raw-provider-secret' "$work/stderr"
grep -q '^rm -f fukurou-cli-canary-' "$work/docker.log"
FAKE_PROVIDER_FAILURE=contaminated; export FAKE_PROVIDER_FAILURE
run_failure ACCEPTANCE --cli-acceptance --runs 1 --reuse-image "$digest"
unset FAKE_PROVIDER_FAILURE; ! grep -Fq 'raw-provider-secret' "$work/stderr"

: >"$work/docker.log"
FAKE_PROVIDER_FAILURE=terminate; export FAKE_PROVIDER_FAILURE
FAKE_HARNESS_PID_FILE="$work/harness.pid"; export FAKE_HARNESS_PID_FILE
set +e
sh -c 'echo $$ > "$FAKE_HARNESS_PID_FILE"; exec "$@"' _ \
    "$repo_root/scripts/mcp-credential-isolation-check" --cli-acceptance --runs 1 --reuse-image "$digest" \
    >"$work/stdout" 2>"$work/stderr"
status=$?
set -e
unset FAKE_PROVIDER_FAILURE FAKE_HARNESS_PID_FILE
[ "$status" -ne 0 ]
grep -q '^rm -f fukurou-cli-canary-' "$work/docker.log"
artifact_path=$(sed -n 's/.* artifacts=//p' "$work/stderr")
if [ -n "$artifact_path" ]; then rm -rf "$artifact_path"; fi

: >"$work/docker.log"
set +e
"$repo_root/scripts/mcp-credential-isolation-check" \
    --qualification --runs 3 --reuse-image "$digest" >"$work/stdout" 2>"$work/stderr"
status=$?
set -e
[ "$status" -eq 0 ] || {
    cat "$work/stdout" "$work/stderr" "$work/docker.log" >&2
    exit 1
}
[ "$(cat "$work/stdout")" = \
    "CLI_QUALIFICATION_V1 OK digest=$digest foundation=OK acceptance=OK runs=3 selftest=true" ]
[ ! -s "$work/stderr" ]
[ "$(grep -c '^image inspect ' "$work/docker.log")" -eq 1 ]

echo "mcp-credential-isolation-check-selftest: PASS"
