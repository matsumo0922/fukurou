#!/usr/bin/env bash
set -Eeuo pipefail

readonly SCRIPT_NAME="$(basename "$0")"
readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
readonly DEFAULT_BASE_URL="https://fukurou.matsumo.me"

readonly ORIGINAL_CLIENT_ID_WAS_SET="${CLOUDFLARED_TUNNEL_CLIENT_ID+x}"
readonly ORIGINAL_CLIENT_ID="${CLOUDFLARED_TUNNEL_CLIENT_ID:-}"
readonly ORIGINAL_CLIENT_SECRET_WAS_SET="${CLOUDFLARED_TUNNEL_CLIENT_SECRET+x}"
readonly ORIGINAL_CLIENT_SECRET="${CLOUDFLARED_TUNNEL_CLIENT_SECRET:-}"
readonly ORIGINAL_BASE_URL_WAS_SET="${FUKUROU_PROD_BASE_URL+x}"
readonly ORIGINAL_BASE_URL="${FUKUROU_PROD_BASE_URL:-}"

usage() {
  cat >&2 <<EOF
Usage: ${SCRIPT_NAME} <path-or-url> [curl options...]

Full URLs are allowed only when their origin matches FUKUROU_PROD_BASE_URL.

Examples:
  ${SCRIPT_NAME} "/health/live" -i
  ${SCRIPT_NAME} "/health/ready" -i
  ${SCRIPT_NAME} "/api/v1/example" --json '{"foo":"bar"}'
  ${SCRIPT_NAME} "/api/v1/example" -X PATCH --json '{"enabled":true}'
  ${SCRIPT_NAME} "/api/v1/example" -H "Content-Type: application/json" --data-binary @payload.json
EOF
}

fail() {
  echo "${SCRIPT_NAME}: $*" >&2
  exit 1
}

source_env_file() {
  local env_file="$1"

  [[ -f "${env_file}" ]] || return 0

  set -a
  # shellcheck source=/dev/null
  source "${env_file}"
  set +a
}

load_local_env() {
  if [[ -n "${FUKUROU_PROD_CURL_ENV_FILE:-}" ]]; then
    [[ -f "${FUKUROU_PROD_CURL_ENV_FILE}" ]] ||
      fail "env file not found: FUKUROU_PROD_CURL_ENV_FILE=${FUKUROU_PROD_CURL_ENV_FILE}"

    source_env_file "${FUKUROU_PROD_CURL_ENV_FILE}"
    return
  fi

  source_env_file "${REPO_ROOT}/.env"
  source_env_file "${REPO_ROOT}/.env.local"
}

restore_explicit_env() {
  if [[ "${ORIGINAL_CLIENT_ID_WAS_SET}" == "x" ]]; then
    CLOUDFLARED_TUNNEL_CLIENT_ID="${ORIGINAL_CLIENT_ID}"
  fi

  if [[ "${ORIGINAL_CLIENT_SECRET_WAS_SET}" == "x" ]]; then
    CLOUDFLARED_TUNNEL_CLIENT_SECRET="${ORIGINAL_CLIENT_SECRET}"
  fi

  if [[ "${ORIGINAL_BASE_URL_WAS_SET}" == "x" ]]; then
    FUKUROU_PROD_BASE_URL="${ORIGINAL_BASE_URL}"
  fi
}

require_service_token() {
  local missing_names=()

  if [[ -z "${CLOUDFLARED_TUNNEL_CLIENT_ID:-}" ]]; then
    missing_names+=("CLOUDFLARED_TUNNEL_CLIENT_ID")
  fi

  if [[ -z "${CLOUDFLARED_TUNNEL_CLIENT_SECRET:-}" ]]; then
    missing_names+=("CLOUDFLARED_TUNNEL_CLIENT_SECRET")
  fi

  if (( ${#missing_names[@]} > 0 )); then
    local joined_names
    joined_names="$(printf '%s, ' "${missing_names[@]}")"
    joined_names="${joined_names%, }"

    fail "missing required env: ${joined_names}. Set them in exported env, .env.local, .env, or FUKUROU_PROD_CURL_ENV_FILE."
  fi
}

normalize_base_url() {
  local raw_base_url="${FUKUROU_PROD_BASE_URL:-${DEFAULT_BASE_URL}}"

  [[ -n "${raw_base_url}" ]] || fail "FUKUROU_PROD_BASE_URL must not be empty"

  printf '%s' "${raw_base_url%/}"
}

resolve_url() {
  local target="$1"
  local base_url="$2"

  case "${target}" in
    http://* | https://*)
      printf '%s' "${target}"
      ;;
    /*)
      printf '%s%s' "${base_url}" "${target}"
      ;;
    *)
      printf '%s/%s' "${base_url}" "${target}"
      ;;
  esac
}

url_origin() {
  local url="$1"

  case "${url}" in
    http://* | https://*)
      ;;
    *)
      fail "URL must start with http:// or https://: ${url}"
      ;;
  esac

  local scheme="${url%%://*}"
  local remainder="${url#*://}"
  local authority="${remainder%%/*}"
  authority="${authority%%\?*}"
  authority="${authority%%#*}"

  [[ -n "${authority}" ]] || fail "URL host is missing: ${url}"

  printf '%s://%s' "${scheme}" "${authority}"
}

require_token_destination() {
  local url="$1"
  local base_url="$2"

  local target_origin
  target_origin="$(url_origin "${url}")"

  local allowed_origin
  allowed_origin="$(url_origin "${base_url}")"

  if [[ "${target_origin}" != "${allowed_origin}" ]]; then
    fail "refusing to send Cloudflare Access token to ${target_origin}. Expected ${allowed_origin}; use curl directly for other hosts."
  fi
}

main() {
  if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    usage
    exit 0
  fi

  if (( $# < 1 )); then
    usage
    exit 1
  fi

  command -v curl >/dev/null 2>&1 || fail "curl is required"

  local target="$1"
  shift

  load_local_env
  restore_explicit_env

  local base_url
  base_url="$(normalize_base_url)"

  local url
  url="$(resolve_url "${target}" "${base_url}")"

  require_token_destination "${url}" "${base_url}"
  require_service_token

  exec curl \
    -H "CF-Access-Client-Id: ${CLOUDFLARED_TUNNEL_CLIENT_ID}" \
    -H "CF-Access-Client-Secret: ${CLOUDFLARED_TUNNEL_CLIENT_SECRET}" \
    "${url}" \
    "$@"
}

main "$@"
