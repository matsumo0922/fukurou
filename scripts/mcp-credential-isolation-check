#!/bin/sh
set -eu

reuse_image=false
if [ "${1:-}" = "--reuse-image" ]; then
    reuse_image=true
    shift
fi
image=${1:-fukurou-mcp-isolation:local}
marker_prefix=FUKUROU_CANARY
artifact_root=$(mktemp -d)
database_container=
application_container=
canary_network=
canary_secrets_volume=
cleanup() {
    if [ -n "$application_container" ]; then docker rm -f "$application_container" >/dev/null 2>&1 || true; fi
    if [ -n "$database_container" ]; then docker rm -f "$database_container" >/dev/null 2>&1 || true; fi
    if [ -n "$canary_network" ]; then docker network rm "$canary_network" >/dev/null 2>&1 || true; fi
    if [ -n "$canary_secrets_volume" ]; then docker volume rm "$canary_secrets_volume" >/dev/null 2>&1 || true; fi
    rm -rf "$artifact_root"
}
trap cleanup EXIT HUP INT TERM

validate_llm_launcher_probe() {
    probe_file=$1
    probe_phase=$2
    case "$probe_file:$probe_phase" in
        provider-proposer.stdout:PROPOSER|provider-falsifier.stdout:FALSIFIER) ;;
        *) echo "canary failure: invalid validator target" >&2; exit 1 ;;
    esac
    docker run --rm \
        --user 0:0 \
        --read-only \
        --network none \
        --cap-drop ALL \
        --cap-add DAC_READ_SEARCH \
        --security-opt no-new-privileges=true \
        --pids-limit 32 \
        --mount "type=bind,src=$artifact_root,dst=/artifacts,readonly" \
        --entrypoint /usr/bin/node \
        "$image" \
        /usr/local/libexec/validate-llm-launcher-probe.mjs "/artifacts/$probe_file" "$probe_phase"
}

segment_one=$(od -An -N12 -tx1 /dev/urandom | tr -d ' \n')
segment_two=$(od -An -N12 -tx1 /dev/urandom | tr -d ' \n')
segment_three=$(od -An -N12 -tx1 /dev/urandom | tr -d ' \n')
marker=${marker_prefix}_${segment_one}_${segment_two}_${segment_three}
app_credential=${segment_one}${segment_two}

if [ "$reuse_image" = false ]; then
    docker build --tag "$image" .
else
    docker image inspect "$image" >/dev/null
fi
docker image inspect "$image" >"$artifact_root/image-inspect.json"
chmod 0700 "$artifact_root"
artifact_root_mode=$(stat -c %a "$artifact_root" 2>/dev/null || stat -f %Lp "$artifact_root")
[ "$artifact_root_mode" = "700" ] || {
    echo "canary failure: artifact root must remain private" >&2
    exit 1
}
docker run --rm \
    --user 0:0 \
    --read-only \
    --network none \
    --cap-drop ALL \
    --cap-add DAC_READ_SEARCH \
    --cap-add SETUID \
    --cap-add SETGID \
    --security-opt no-new-privileges=true \
    --pids-limit 32 \
    --mount "type=bind,src=$artifact_root,dst=/artifacts,readonly" \
    --tmpfs /private:rw,noexec,nosuid,nodev,mode=0700,uid=0,gid=0 \
    --entrypoint /bin/sh \
    "$image" -ec '
        cp /artifacts/image-inspect.json /private/image-inspect.json
        chmod 0400 /private/image-inspect.json
        su -s /bin/sh appuser -c "sh -ec '\''
            test \"\$(awk \"/CapEff/ {print \\\$2}\" /proc/self/status)\" = 0000000000000000
            test ! -r /private/image-inspect.json
        '\''"
    '

docker run --rm --user root --env CANARY="$marker" --entrypoint /bin/sh "$image" -ec '
    umask 077
    printf "%s" "$CANARY" >/run/secrets/fukurou_mcp_db_password
    chown 0:0 /run/secrets/fukurou_mcp_db_password
    chmod 0400 /run/secrets/fukurou_mcp_db_password
    test -e /run/secrets/fukurou_mcp_db_password
    test -e /proc/1/environ
    su -s /bin/sh llm-agent -c "test ! -r /run/secrets/fukurou_mcp_db_password"
    su -s /bin/sh llm-agent -c "test ! -r /proc/1/environ"
    su -s /bin/sh llm-agent -c "test ! -e /var/run/docker.sock"
' >"$artifact_root/offline-reader.stdout" 2>"$artifact_root/offline-reader.stderr"
echo "canary stage: offline reader complete"

if ! docker run --rm --user root --entrypoint /bin/sh "$image" -ec '
    umask 007
    auth_source=/tmp/persistent-auth-source
    install -d -o 10001 -g 10004 -m 0770 "$auth_source" /run/fukurou/llm-homes/fukurou-llm-config-123 /run/fukurou/llm-homes/fukurou-codex-home-123
    printf "%s\n" "fixture-auth-source" >"$auth_source/auth.json"
    chown 10001:10004 "$auth_source/auth.json"
    chmod 0660 "$auth_source/auth.json"
    cp "$auth_source/auth.json" /run/fukurou/llm-homes/fukurou-codex-home-123/auth.json
    printf "%s\n" "model_reasoning_effort = \"low\"" >/run/fukurou/llm-homes/fukurou-codex-home-123/config.toml
    printf "%s\n" "{}" >/run/fukurou/llm-homes/fukurou-llm-config-123/mcp.json
    chown -R 10001:10004 /run/fukurou/llm-homes
    chmod 0660 /run/fukurou/llm-homes/fukurou-codex-home-123/auth.json /run/fukurou/llm-homes/fukurou-codex-home-123/config.toml /run/fukurou/llm-homes/fukurou-llm-config-123/mcp.json
    before=$(sha256sum "$auth_source/auth.json")
    su -s /bin/sh llm-agent -c "test -r /run/fukurou/llm-homes/fukurou-codex-home-123/auth.json && test -w /run/fukurou/llm-homes/fukurou-codex-home-123"
    su -s /bin/sh llm-agent -c "test -r /run/fukurou/llm-homes/fukurou-llm-config-123/mcp.json && test -w /run/fukurou/llm-homes/fukurou-llm-config-123"
    su -s /bin/sh appuser -c "HOME=/run/fukurou/llm-homes/fukurou-codex-home-123 CODEX_HOME=/run/fukurou/llm-homes/fukurou-codex-home-123 /usr/local/libexec/fukurou-llm-agent-launcher codex --version"
    su -s /bin/sh appuser -c "HOME=/run/fukurou/llm-homes/fukurou-llm-config-123 CLAUDE_CONFIG_DIR=/run/fukurou/llm-homes/fukurou-llm-config-123 /usr/local/libexec/fukurou-llm-agent-launcher claude --version"
    su -s /bin/sh llm-agent -c "mkdir -p /run/fukurou/llm-homes/fukurou-codex-home-123/session/cache && printf fixture >/run/fukurou/llm-homes/fukurou-codex-home-123/session/cache/state.json && chmod 0755 /run/fukurou/llm-homes/fukurou-codex-home-123/session /run/fukurou/llm-homes/fukurou-codex-home-123/session/cache && chmod 0644 /run/fukurou/llm-homes/fukurou-codex-home-123/session/cache/state.json"
    su -s /bin/sh appuser -c "FUKUROU_MCP_CANARY_ARTIFACT_GENERATOR=true /opt/java/openjdk/bin/java -cp /app/app.jar me.matsumo.fukurou.trading.runner.McpIsolationCanaryArtifactsKt CLEANUP /run/fukurou/llm-homes/fukurou-codex-home-123"
    test ! -e /run/fukurou/llm-homes/fukurou-codex-home-123
    test ! -e /run/fukurou/llm-homes/.cleanup-quarantine
    after=$(sha256sum "$auth_source/auth.json")
    test "$before" = "$after"
    rm -rf /run/fukurou/llm-homes/fukurou-llm-config-123
    test ! -e /run/fukurou/llm-homes/fukurou-llm-config-123
    test ! -e /run/fukurou/llm-homes/fukurou-codex-home-123
' >"$artifact_root/llm-launcher.stdout" 2>"$artifact_root/llm-launcher.stderr"; then
    cat "$artifact_root/llm-launcher.stderr" >&2
    echo "canary failure: LLM launcher artifact cleanup wiring" >&2
    exit 1
fi
echo "canary stage: LLM launcher artifact access complete"

canary_network=fukurou-mcp-canary-${segment_one}
docker network create "$canary_network" >/dev/null
database_container=$(docker run -d --rm --network "$canary_network" --network-alias postgres --env POSTGRES_PASSWORD="$app_credential" --env POSTGRES_DB=fukurou_canary postgres:16-alpine)
attempt=0
until docker exec "$database_container" pg_isready -U postgres -d fukurou_canary >/dev/null 2>&1; do
    attempt=$((attempt + 1))
    [ "$attempt" -lt 30 ] || { echo "canary failure: disposable database readiness" >&2; exit 1; }
    sleep 1
done
echo "canary stage: disposable database ready"
canary_secrets_volume=fukurou-mcp-canary-secrets-${segment_one}
docker volume create "$canary_secrets_volume" >/dev/null
docker run --rm --user 0:0 --read-only --network none --cap-drop ALL --security-opt no-new-privileges=true \
    --mount "type=volume,src=$canary_secrets_volume,dst=/secrets" --entrypoint /bin/sh "$image" -ec '
      umask 077
      printf "%s" "$1" >/secrets/fukurou_mcp_db_password
      printf enabled >/secrets/fukurou_canary_enabled
      chmod 0400 /secrets/fukurou_mcp_db_password /secrets/fukurou_canary_enabled
    ' canary-secret-setup "$marker"
application_container=$(docker run -d --user 10001:10004 --network "$canary_network" \
    --read-only --init --pids-limit 512 \
    --cap-drop ALL --cap-add CHOWN --cap-add DAC_READ_SEARCH --cap-add SETGID --cap-add SETUID --cap-add SETPCAP \
    --tmpfs /tmp:rw,noexec,nosuid,nodev,mode=1777 \
    --tmpfs /run/fukurou/llm-homes:rw,noexec,nosuid,nodev,mode=2750,uid=10001,gid=10004 \
    --tmpfs /run/fukurou/mcp-manifests:rw,noexec,nosuid,nodev,mode=0700,uid=10001,gid=10004 \
    --mount "type=volume,src=$canary_secrets_volume,dst=/run/secrets,readonly" \
    --env DB_URL=jdbc:postgresql://postgres:5432/fukurou_canary --env DB_USER=postgres --env DB_PASSWORD="$app_credential" \
    "$image")
docker inspect --format 'user={{.Config.User}} readonly={{.HostConfig.ReadonlyRootfs}} init={{.HostConfig.Init}} pids={{.HostConfig.PidsLimit}} tmp={{index .HostConfig.Tmpfs "/tmp"}} llm={{index .HostConfig.Tmpfs "/run/fukurou/llm-homes"}} manifests={{index .HostConfig.Tmpfs "/run/fukurou/mcp-manifests"}} secret={{range .Mounts}}{{if eq .Destination "/run/secrets"}}{{.Type}}:{{.RW}}{{end}}{{end}}' \
    "$application_container" >"$artifact_root/application-security.txt"
grep -q '^user=10001:10004 readonly=true init=true pids=512 tmp=rw,noexec,nosuid,nodev,mode=1777 llm=rw,noexec,nosuid,nodev,mode=2750,uid=10001,gid=10004 manifests=rw,noexec,nosuid,nodev,mode=0700,uid=10001,gid=10004 secret=volume:false$' \
    "$artifact_root/application-security.txt" || {
    cat "$artifact_root/application-security.txt" >&2
    echo "canary failure: application security profile mismatch" >&2
    exit 1
}
normalize_capabilities() {
    tr '[:lower:]' '[:upper:]' | sed 's/^CAP_//' | sed '/^$/d' | sort -u
}
actual_cap_add=$(docker inspect --format '{{range .HostConfig.CapAdd}}{{println .}}{{end}}' "$application_container" | normalize_capabilities)
expected_cap_add=$(printf '%s\n' CHOWN DAC_READ_SEARCH SETGID SETPCAP SETUID | sort -u)
[ "$actual_cap_add" = "$expected_cap_add" ] || { echo "canary failure: application added capability set mismatch" >&2; exit 1; }
actual_cap_drop=$(docker inspect --format '{{range .HostConfig.CapDrop}}{{println .}}{{end}}' "$application_container" | normalize_capabilities)
[ "$actual_cap_drop" = "ALL" ] || { echo "canary failure: application dropped capability set mismatch" >&2; exit 1; }
attempt=0
until docker exec --env PGPASSWORD="$app_credential" "$database_container" psql -U postgres -d fukurou_canary -Atc \
    "SELECT to_regclass('public.llm_runs') IS NOT NULL AND to_regclass('public.mcp_current_evaluation_scope') IS NOT NULL AND to_regclass('public.mcp_evaluation_epochs') IS NOT NULL" \
    2>/dev/null | grep -q t; do
    attempt=$((attempt + 1))
    [ "$attempt" -lt 45 ] || { docker logs "$application_container" >"$artifact_root/application.log" 2>&1; tail -20 "$artifact_root/application.log" >&2; echo "canary failure: application schema bootstrap" >&2; exit 1; }
    sleep 1
done
docker cp scripts/deploy/sql/mcp-role.sql "$database_container":/tmp/mcp-role.sql
docker exec --env PGPASSWORD="$app_credential" "$database_container" psql -U postgres -d fukurou_canary \
    -v ON_ERROR_STOP=1 -v mcp_role=fukurou_mcp -v mcp_password="$marker" -v database_name=fukurou_canary -v app_role=postgres \
    -f /tmp/mcp-role.sql >"$artifact_root/database-setup.stdout" 2>"$artifact_root/database-setup.stderr"
docker exec --env PGPASSWORD="$app_credential" "$database_container" psql -U postgres -d fukurou_canary -v ON_ERROR_STOP=1 -c \
    "INSERT INTO llm_runs(invocation_id,mode,symbol,status,started_at) VALUES ('mcp-canary-run','PAPER','BTC','RUNNING',0)" \
    >>"$artifact_root/database-setup.stdout" 2>>"$artifact_root/database-setup.stderr"
echo "canary stage: database fixture complete"

if ! docker exec --user 10001:10004 "$application_container" /bin/sh -ec '
  install -d -m 0770 /tmp/fukurou-cli-home/.claude /tmp/fukurou-cli-home/.codex
  printf "%s" "{\"fixture\":\"fixture-auth\"}" >/tmp/fukurou-cli-home/.claude/.credentials.json
  printf "%s" "{\"fixture\":\"fixture-auth\"}" >/tmp/fukurou-cli-home/.codex/auth.json
  chmod 0660 /tmp/fukurou-cli-home/.claude/.credentials.json /tmp/fukurou-cli-home/.codex/auth.json
'; then
    docker exec --user root "$application_container" stat -c '%u:%g:%a %n' /tmp /tmp/fukurou-cli-home 2>/dev/null >&2 || true
    echo "canary failure: provider auth fixture setup" >&2
    exit 1
fi
if ! auth_source_hash_before=$(docker exec --user 10001:10004 "$application_container" sha256sum \
    /tmp/fukurou-cli-home/.claude/.credentials.json /tmp/fukurou-cli-home/.codex/auth.json); then
    docker exec --user root "$application_container" stat -c '%u:%g:%a %n' \
        /tmp/fukurou-cli-home/.claude/.credentials.json /tmp/fukurou-cli-home/.codex/auth.json 2>/dev/null >&2 || true
    echo "canary failure: provider auth fixture hash" >&2
    exit 1
fi
if ! docker exec --user 10001:10004 "$application_container" /bin/sh -ec '
    test -w /tmp
    test -w /run/fukurou/llm-homes
    test -w /run/fukurou/mcp-manifests
'; then
    echo "canary failure: application writable runtime mounts" >&2
    docker exec --user root "$application_container" stat -c '%u:%g:%a %n' \
        /tmp /run/fukurou/llm-homes /run/fukurou/mcp-manifests >&2 || true
    docker logs --tail 40 "$application_container" >&2 || true
    exit 1
fi

if ! docker exec --user 10001:10004 --env FUKUROU_MCP_CANARY_ARTIFACT_GENERATOR=true \
    --env HOME=/tmp/fukurou-cli-home \
    --env FUKUROU_MCP_DB_USER=fukurou_mcp --env FUKUROU_GMO_PUBLIC_BASE_URL=http://127.0.0.1:18080/public \
    "$application_container" /opt/java/openjdk/bin/java -cp /app/app.jar \
    me.matsumo.fukurou.trading.runner.McpIsolationCanaryArtifactsKt PROPOSER CLAUDE \
    >"$artifact_root/proposer-artifacts.txt" 2>"$artifact_root/proposer-artifacts.stderr"; then
    cat "$artifact_root/proposer-artifacts.stderr" >&2
    echo "canary failure: proposer artifact generation command" >&2
    docker exec --user root "$application_container" stat -c '%u:%g:%a %n' \
        /tmp /run/fukurou/llm-homes /run/fukurou/mcp-manifests >&2 || true
    docker logs --tail 40 "$application_container" >&2 || true
    exit 1
fi
proposer_manifest=$(sed -n 's/^MANIFEST_ID=//p' "$artifact_root/proposer-artifacts.txt")
proposer_home=$(sed -n 's/^ARTIFACT=//p' "$artifact_root/proposer-artifacts.txt" | \
    awk '/fukurou-llm-config-/ { value=$0 } END { print value }')
if [ -z "$proposer_manifest" ]; then
    echo "canary failure: proposer artifact generation" >&2
    exit 1
fi
if [ -z "$proposer_home" ]; then
    sed -n 's/^\(MANIFEST_ID\|ARTIFACT\)=.*/\1=<redacted-path>/p' "$artifact_root/proposer-artifacts.txt" >&2
    echo "canary failure: proposer home artifact missing" >&2
    exit 1
fi
docker exec --user 10001:10004 --env HOME="$proposer_home" --env CLAUDE_CONFIG_DIR="$proposer_home" \
    --env XDG_CACHE_HOME="$proposer_home/.cache" \
    --env FUKUROU_INVOCATION_ID=canary-proposer --env FUKUROU_LLM_PROVIDER=claude \
    --env FUKUROU_PROMPT_HASH=canary-prompt-hash --env FUKUROU_SYSTEM_PROMPT_VERSION=canary-system-prompt \
    --env FUKUROU_MARKET_SNAPSHOT_ID=canary-snapshot --env FUKUROU_RUNTIME_CONFIG_VERSION_ID=canary-config \
    --env FUKUROU_RUNTIME_CONFIG_HASH=canary-config-hash \
    --env HOSTILE_LAUNCHER_INPUT=must-not-survive \
    "$application_container" /usr/local/libexec/fukurou-llm-agent-launcher canary "$proposer_manifest" PROPOSER \
    >"$artifact_root/provider-proposer.stdout" 2>"$artifact_root/provider-proposer.stderr" &
proposer_probe_process=$!
attempt=0
until docker exec --user 10002:10004 "$application_container" test -r "$proposer_home/mcp-canary.pid"; do
    if ! kill -0 "$proposer_probe_process" 2>/dev/null; then
        wait "$proposer_probe_process" || true
        sed -n '1,80p' "$artifact_root/provider-proposer.stderr" >&2
        echo "canary failure: proposer launcher exited before MCP readiness" >&2
        exit 1
    fi
    attempt=$((attempt + 1))
    [ "$attempt" -lt 30 ] || {
        wait "$proposer_probe_process" || true
        sed -n '1,80p' "$artifact_root/provider-proposer.stderr" >&2
        sed -n '1,80p' "$artifact_root/provider-proposer.stdout" >&2
        echo "canary failure: MCP process probe readiness" >&2
        exit 1
    }
    sleep 1
done
mcp_process_id=$(docker exec --user 10002:10004 "$application_container" cat "$proposer_home/mcp-canary.pid")
if ! docker exec --user root "$application_container" /bin/sh -ec "
    test -e /proc/$mcp_process_id/environ
    test -d /proc/$mcp_process_id/fd
    test -e /run/secrets/fukurou_mcp_db_password
    test -e /run/fukurou/mcp-manifests/$proposer_manifest.json
    test -d /run/fukurou/mcp-manifests
"; then
    wait "$proposer_probe_process" || true
    sed -n '1,80p' "$artifact_root/provider-proposer.stderr" >&2
    echo "canary failure: live MCP target disappeared before denial probe" >&2
    exit 1
fi
docker exec --user 10002:10004 "$application_container" /bin/sh -ec "
    test ! -r /proc/$mcp_process_id/environ
    test ! -r /proc/$mcp_process_id/fd
    test ! -r /run/secrets/fukurou_mcp_db_password
    test ! -r /run/fukurou/mcp-manifests/$proposer_manifest.json
    test ! -x /run/fukurou/mcp-manifests
" >"$artifact_root/live-proc-probe.stdout" 2>"$artifact_root/live-proc-probe.stderr"
docker exec --user 10002:10004 "$application_container" touch "$proposer_home/mcp-canary.probe-complete"
echo "canary stage: live MCP denial probe complete"
if ! wait "$proposer_probe_process"; then
    sed -n '1,80p' "$artifact_root/provider-proposer.stderr" >&2
    echo "canary failure: proposer real path" >&2
    exit 1
fi
validate_llm_launcher_probe provider-proposer.stdout PROPOSER
grep -q '^MCP_LAUNCHER_PROBE uid=10003 gid=10003 fsuid=10003 fsgid=10003 groups=empty nnp=1 caps=zero capbnd=zero fds=0,1,2,3,4$' "$artifact_root/provider-proposer.stderr"
intent_id=$(sed -n 's/.*"event":"intent","intent_id":"\([^"]*\)".*/\1/p' "$artifact_root/provider-proposer.stdout" | tail -1)
[ -n "$intent_id" ] || { echo "canary failure: proposer intent output missing" >&2; exit 1; }
docker exec --user 10001:10004 --env FUKUROU_MCP_CANARY_ARTIFACT_GENERATOR=true \
    --env HOME=/tmp/fukurou-cli-home \
    --env FUKUROU_MCP_DB_USER=fukurou_mcp --env FUKUROU_GMO_PUBLIC_BASE_URL=http://127.0.0.1:18080/public \
    "$application_container" /opt/java/openjdk/bin/java -cp /app/app.jar \
    me.matsumo.fukurou.trading.runner.McpIsolationCanaryArtifactsKt FALSIFIER CODEX \
    >"$artifact_root/falsifier-artifacts.txt"
falsifier_manifest=$(sed -n 's/^MANIFEST_ID=//p' "$artifact_root/falsifier-artifacts.txt")
falsifier_home=$(sed -n 's/^ARTIFACT=//p' "$artifact_root/falsifier-artifacts.txt" | grep 'fukurou-codex-home-' | tail -1)
[ -n "$falsifier_manifest" ] || { echo "canary failure: falsifier artifact generation" >&2; exit 1; }
if ! docker exec --user 10001:10004 --env HOME="$falsifier_home" --env CODEX_HOME="$falsifier_home" \
    --env XDG_CACHE_HOME="$falsifier_home/.cache" \
    --env FUKUROU_INVOCATION_ID=canary-falsifier --env FUKUROU_LLM_PROVIDER=codex \
    --env FUKUROU_PROMPT_HASH=canary-prompt-hash --env FUKUROU_SYSTEM_PROMPT_VERSION=canary-system-prompt \
    --env FUKUROU_MARKET_SNAPSHOT_ID=canary-snapshot --env FUKUROU_RUNTIME_CONFIG_VERSION_ID=canary-config \
    --env FUKUROU_RUNTIME_CONFIG_HASH=canary-config-hash --env FUKUROU_FALSIFIER_INTENT_ID="$intent_id" \
    --env FUKUROU_CANARY_INTENT_ID="$intent_id" "$application_container" \
    /usr/local/libexec/fukurou-llm-agent-launcher canary "$falsifier_manifest" FALSIFIER \
    >"$artifact_root/provider-falsifier.stdout" 2>"$artifact_root/provider-falsifier.stderr"; then
    sed -n '1,80p' "$artifact_root/provider-falsifier.stderr" >&2
    echo "canary failure: falsifier real path" >&2
    exit 1
fi
validate_llm_launcher_probe provider-falsifier.stdout FALSIFIER
docker exec --user 10002:10004 "$application_container" /bin/sh -ec "
    mkdir -p '$falsifier_home/session/cache'
    printf '%s\n' fixture >'$falsifier_home/session/cache/state.json'
    chmod 0755 '$falsifier_home/session' '$falsifier_home/session/cache'
    chmod 0644 '$falsifier_home/session/cache/state.json'
"
docker logs "$application_container" >"$artifact_root/application.log" 2>&1
docker cp "$application_container":/run/fukurou/mcp-manifests "$artifact_root/per-run-manifests"
docker cp "$application_container":/run/fukurou/llm-homes "$artifact_root/per-run-homes"
[ "$(grep -h -c '"event":"tool_completed"' "$artifact_root"/provider-*.stdout | awk '{ total += $1 } END { print total + 0 }')" -eq 16 ] || {
    echo "canary failure: required-call coverage incomplete" >&2
    exit 1
}
cleanup_paths=$(sed -n 's/^ARTIFACT=//p' "$artifact_root/proposer-artifacts.txt" "$artifact_root/falsifier-artifacts.txt")
docker exec --user 10001:10004 --env FUKUROU_MCP_CANARY_ARTIFACT_GENERATOR=true \
    "$application_container" /opt/java/openjdk/bin/java -cp /app/app.jar \
    me.matsumo.fukurou.trading.runner.McpIsolationCanaryArtifactsKt CLEANUP $cleanup_paths
for generated_path in $cleanup_paths; do
    docker exec --user 10001:10004 "$application_container" test ! -e "$generated_path"
done
docker exec --user 10001:10004 "$application_container" test ! -e /run/fukurou/llm-homes/.cleanup-quarantine
auth_source_hash_after=$(docker exec --user 10001:10004 "$application_container" sha256sum \
    /tmp/fukurou-cli-home/.claude/.credentials.json /tmp/fukurou-cli-home/.codex/auth.json)
[ "$auth_source_hash_before" = "$auth_source_hash_after" ] || { echo "canary failure: persistent auth source mutated" >&2; exit 1; }
docker exec --user 10001:10004 "$application_container" test ! -e "/run/fukurou/mcp-manifests/$proposer_manifest.json"
docker exec --user 10001:10004 "$application_container" test ! -e "/run/fukurou/mcp-manifests/$falsifier_manifest.json"
echo "canary stage: real launcher and MCP required-call matrix complete"

docker exec --env PGPASSWORD="$app_credential" "$database_container" psql -U postgres -d fukurou_canary --no-align --tuples-only \
    -c 'SELECT payload::text FROM command_event_log ORDER BY id' >"$artifact_root/tool-audit-export.txt"
docker exec --env PGPASSWORD="$app_credential" "$database_container" pg_dump -U postgres -d fukurou_canary --data-only \
    >"$artifact_root/database-data-only.sql"
[ -s "$artifact_root/tool-audit-export.txt" ] || { echo "canary failure: tool audit export missing" >&2; exit 1; }
[ -s "$artifact_root/database-data-only.sql" ] || { echo "canary failure: database dump missing" >&2; exit 1; }
echo "canary stage: database exports complete"

printf '%s\n' image-inspect.json application-security.txt offline-reader.stdout offline-reader.stderr llm-launcher.stdout llm-launcher.stderr proposer-artifacts.txt falsifier-artifacts.txt provider-proposer.stdout provider-proposer.stderr provider-falsifier.stdout provider-falsifier.stderr live-proc-probe.stdout live-proc-probe.stderr application.log per-run-manifests per-run-homes tool-audit-export.txt database-data-only.sql >"$artifact_root/coverage.txt"
[ "$(wc -l <"$artifact_root/coverage.txt" | tr -d ' ')" -eq 19 ] || { echo "canary failure: coverage missing" >&2; exit 1; }
while IFS= read -r artifact; do
    [ -r "$artifact_root/$artifact" ] || { echo "canary failure: unreadable artifact category" >&2; exit 1; }
done <"$artifact_root/coverage.txt"

for segment in "$marker" "$segment_one" "$segment_two" "$segment_three"; do
    encoded=$(printf '%s' "$segment" | base64 | tr -d '\n')
    encoded_url=$(printf '%s' "$segment" | base64 | tr '+/' '-_' | tr -d '=\n')
    encoded_hex=$(printf '%s' "$segment" | od -An -tx1 | tr -d ' \n')
    encoded_percent=$(printf '%s' "$segment" | od -An -tx1 | awk '{ for (field_index=1; field_index<=NF; field_index++) printf "%%%s", toupper($field_index) }')
    encoded_json=$(printf '%s' "$segment" | sed 's/\\/\\\\/g; s/"/\\"/g')
    encoded_toml=$encoded_json
    for representation in "$segment" "$encoded" "$encoded_url" "$encoded_hex" "$encoded_percent" "$encoded_json" "$encoded_toml"; do
        set +e
        grep -R -a -F -q -- "$representation" "$artifact_root"
        scan_status=$?
        set -e
        if [ "$scan_status" -eq 0 ]; then
            echo "canary failure: artifact match detected" >&2
            exit 1
        fi
        [ "$scan_status" -eq 1 ] || { echo "canary failure: artifact scanner error" >&2; exit 1; }
    done
done
echo "canary stage: artifact scan complete"

docker run --rm --entrypoint /bin/sh "$image" -ec '
    test "$(stat -c %u:%g:%a /usr/local/libexec/fukurou-llm-agent-launcher)" = "0:0:4755"
    test "$(stat -c %u:%g:%a /usr/local/libexec/fukurou-mcp-launcher)" = "0:0:4755"
    test ! -e /var/run/docker.sock
    test "$(id -u)" = 10001
    test "$(awk "/CapEff/ {print \$2}" /proc/self/status)" = "0000000000000000"
'
docker run --rm --user root --entrypoint /bin/sh "$image" -ec '
    test "$(find / -type f -perm /6000 2>/dev/null | sort)" = "/usr/local/libexec/fukurou-llm-agent-launcher
/usr/local/libexec/fukurou-mcp-launcher"
    test -z "$(find / -type f -perm /2000 ! -perm /4000 2>/dev/null)"
    test -z "$(getcap -r / 2>/dev/null)"
    test ! -S /var/run/docker.sock
    test ! -S /run/containerd/containerd.sock
    test ! -S /run/crio/crio.sock
    ! grep -Eq "(/var/run/docker.sock|/run/docker.sock|/run/containerd|/run/crio)" /proc/mounts
'
docker run --rm --entrypoint /bin/sh "$image" -ec '
    assert_126() {
        set +e
        "$@" >/dev/null 2>&1
        status=$?
        set -e
        test "$status" -eq 126
    }
    assert_126 /usr/local/libexec/fukurou-llm-agent-launcher
    assert_126 /usr/local/libexec/fukurou-llm-agent-launcher unknown
    assert_126 /usr/local/libexec/fukurou-llm-agent-launcher canary invalid PROPOSER
    assert_126 /usr/local/libexec/fukurou-llm-agent-launcher cleanup
    assert_126 /usr/local/libexec/fukurou-llm-agent-launcher cleanup /tmp/fukurou-codex-home-123
    assert_126 /usr/local/libexec/fukurou-llm-agent-launcher cleanup /run/fukurou/llm-homes/not-canonical
    assert_126 /usr/local/libexec/fukurou-mcp-launcher
    assert_126 /usr/local/libexec/fukurou-mcp-launcher invalid
    assert_126 /usr/local/libexec/fukurou-mcp-launcher 0123456789abcdef0123456789abcdef0123456789abcdef extra
'

echo "offline production-image isolation checks passed"
echo "optional pinned real-model probe: NOT RUN (operator credential and disposable DB required)"
