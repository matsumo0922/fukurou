#!/bin/sh
set -eu

reuse_image=false
if [ "${1:-}" = "--reuse-image" ]; then
    reuse_image=true
    shift
fi
image=${1:-fukurou-mcp-isolation:local}
mcp_role_sql=${FUKUROU_MCP_ROLE_SQL:-scripts/deploy/sql/mcp-role.sql}
marker_prefix=FUKUROU_CANARY
artifact_root=$(mktemp -d)
database_container=
application_container=
canary_network=
canary_secrets_volume=
cleanup() {
    if [ -n "$application_container" ]; then docker rm -f "$application_container" >/dev/null 2>&1 || true; fi
    if [ -n "$database_container" ]; then docker rm -f "$database_container" >/dev/null 2>&1 || true; fi
    if [ -n "$canary_network" ]; then docker network rm "$canary_network" >/dev/null 2>&1 || true; fi
    if [ -n "$canary_secrets_volume" ]; then docker volume rm "$canary_secrets_volume" >/dev/null 2>&1 || true; fi
    rm -rf "$artifact_root"
}

assert_runtime_cleanup() {
    if [ -n "$application_container" ] && docker container inspect "$application_container" >/dev/null 2>&1; then
        echo "canary failure: application container cleanup incomplete" >&2
        return 1
    fi
    if [ -n "$database_container" ] && docker container inspect "$database_container" >/dev/null 2>&1; then
        echo "canary failure: database container cleanup incomplete" >&2
        return 1
    fi
    if [ -n "$canary_network" ] && docker network inspect "$canary_network" >/dev/null 2>&1; then
        echo "canary failure: network cleanup incomplete" >&2
        return 1
    fi
    if [ -n "$canary_secrets_volume" ] && docker volume inspect "$canary_secrets_volume" >/dev/null 2>&1; then
        echo "canary failure: volume cleanup incomplete" >&2
        return 1
    fi
}
trap cleanup EXIT HUP INT TERM

validate_llm_launcher_probe() {
    probe_file=$1
    probe_phase=$2
    case "$probe_file:$probe_phase" in
        provider-proposer.stdout:PROPOSER|provider-falsifier.stdout:FALSIFIER|rro/provider-rro-*.stdout:RISK_REDUCTION_ONLY) ;;
        *) echo "canary failure: invalid validator target" >&2; exit 1 ;;
    esac
    docker run --rm \
        --user 0:0 \
        --read-only \
        --network none \
        --cap-drop ALL \
        --cap-add DAC_READ_SEARCH \
        --security-opt no-new-privileges=true \
        --pids-limit 32 \
        --mount "type=bind,src=$artifact_root,dst=/artifacts,readonly" \
        --entrypoint /usr/bin/node \
        "$image" \
        /usr/local/libexec/validate-llm-launcher-probe.mjs "/artifacts/$probe_file" "$probe_phase"
}

segment_one=$(od -An -N12 -tx1 /dev/urandom | tr -d ' \n')
segment_two=$(od -An -N12 -tx1 /dev/urandom | tr -d ' \n')
segment_three=$(od -An -N12 -tx1 /dev/urandom | tr -d ' \n')
marker=${marker_prefix}_${segment_one}_${segment_two}_${segment_three}
app_credential=${segment_one}${segment_two}

if [ "$reuse_image" = false ]; then
    docker build --tag "$image" .
else
    docker image inspect "$image" >/dev/null
fi
docker image inspect "$image" >"$artifact_root/image-inspect.json"
chmod 0700 "$artifact_root"
artifact_root_mode=$(stat -c %a "$artifact_root" 2>/dev/null || stat -f %Lp "$artifact_root")
[ "$artifact_root_mode" = "700" ] || {
    echo "canary failure: artifact root must remain private" >&2
    exit 1
}
docker run --rm \
    --user 0:0 \
    --read-only \
    --network none \
    --cap-drop ALL \
    --cap-add DAC_READ_SEARCH \
    --cap-add SETUID \
    --cap-add SETGID \
    --security-opt no-new-privileges=true \
    --pids-limit 32 \
    --mount "type=bind,src=$artifact_root,dst=/artifacts,readonly" \
    --tmpfs /private:rw,noexec,nosuid,nodev,mode=0700,uid=0,gid=0 \
    --entrypoint /bin/sh \
    "$image" -ec '
        cp /artifacts/image-inspect.json /private/image-inspect.json
        chmod 0400 /private/image-inspect.json
        su -s /bin/sh appuser -c "sh -ec '\''
            test \"\$(awk \"/CapEff/ {print \\\$2}\" /proc/self/status)\" = 0000000000000000
            test ! -r /private/image-inspect.json
        '\''"
    '

docker run --rm --user root --env CANARY="$marker" --entrypoint /bin/sh "$image" -ec '
    umask 077
    printf "%s" "$CANARY" >/run/secrets/fukurou_mcp_db_password
    chown 0:0 /run/secrets/fukurou_mcp_db_password
    chmod 0400 /run/secrets/fukurou_mcp_db_password
    test -e /run/secrets/fukurou_mcp_db_password
    test -e /proc/1/environ
    su -s /bin/sh llm-agent -c "test ! -r /run/secrets/fukurou_mcp_db_password"
    su -s /bin/sh llm-agent -c "test ! -r /proc/1/environ"
    su -s /bin/sh llm-agent -c "test ! -e /var/run/docker.sock"
' >"$artifact_root/offline-reader.stdout" 2>"$artifact_root/offline-reader.stderr"
echo "canary stage: offline reader complete"

if ! docker run --rm --user root --entrypoint /bin/sh "$image" -ec '
    umask 007
    auth_source=/tmp/persistent-auth-source
    install -d -o 10001 -g 10004 -m 0770 "$auth_source" /run/fukurou/llm-homes/fukurou-llm-config-123 /run/fukurou/llm-homes/fukurou-codex-home-123
    printf "%s\n" "fixture-auth-source" >"$auth_source/auth.json"
    chown 10001:10004 "$auth_source/auth.json"
    chmod 0660 "$auth_source/auth.json"
    cp "$auth_source/auth.json" /run/fukurou/llm-homes/fukurou-codex-home-123/auth.json
    printf "%s\n" "model_reasoning_effort = \"low\"" >/run/fukurou/llm-homes/fukurou-codex-home-123/config.toml
    printf "%s\n" "{}" >/run/fukurou/llm-homes/fukurou-llm-config-123/mcp.json
    chown -R 10001:10004 /run/fukurou/llm-homes
    chmod 0660 /run/fukurou/llm-homes/fukurou-codex-home-123/auth.json /run/fukurou/llm-homes/fukurou-codex-home-123/config.toml /run/fukurou/llm-homes/fukurou-llm-config-123/mcp.json
    before=$(sha256sum "$auth_source/auth.json")
    su -s /bin/sh llm-agent -c "test -r /run/fukurou/llm-homes/fukurou-codex-home-123/auth.json && test -w /run/fukurou/llm-homes/fukurou-codex-home-123"
    su -s /bin/sh llm-agent -c "test -r /run/fukurou/llm-homes/fukurou-llm-config-123/mcp.json && test -w /run/fukurou/llm-homes/fukurou-llm-config-123"
    printf scope-outside >/tmp/cleanup-scope-outside
    chown 10002:10004 /tmp/cleanup-scope-outside
    chmod 0400 /tmp/cleanup-scope-outside
    su -s /bin/sh llm-agent -c "mkdir -p /run/fukurou/llm-homes/fukurou-codex-home-123/session/cache/locked /run/fukurou/llm-homes/fukurou-codex-home-123/session/race-parent/target && printf fixture >/run/fukurou/llm-homes/fukurou-codex-home-123/session/cache/locked/state.json && printf race >/run/fukurou/llm-homes/fukurou-codex-home-123/session/race-parent/target/state.json && ln -s /tmp/cleanup-scope-outside /run/fukurou/llm-homes/fukurou-codex-home-123/session/cache/locked/outside-link && chmod 0400 /run/fukurou/llm-homes/fukurou-codex-home-123/session/cache/locked/state.json /run/fukurou/llm-homes/fukurou-codex-home-123/session/race-parent/target/state.json && chmod 0000 /run/fukurou/llm-homes/fukurou-codex-home-123/session/cache/locked /run/fukurou/llm-homes/fukurou-codex-home-123/session/race-parent/target && chmod 0555 /run/fukurou/llm-homes/fukurou-codex-home-123/session/cache && chmod 0770 /run/fukurou/llm-homes/fukurou-codex-home-123/session/race-parent && chmod 0755 /run/fukurou/llm-homes/fukurou-codex-home-123/session"
    su -s /bin/sh llm-agent -c "attempt=0; swapped=0; while [ \$attempt -lt 500 ]; do if mv /run/fukurou/llm-homes/fukurou-codex-home-123/session/race-parent/target /run/fukurou/llm-homes/fukurou-codex-home-123/session/race-parent/target-dir 2>/dev/null; then if ln -s /tmp/cleanup-scope-outside /run/fukurou/llm-homes/fukurou-codex-home-123/session/race-parent/target 2>/dev/null; then swapped=\$((swapped + 1)); rm -f /run/fukurou/llm-homes/fukurou-codex-home-123/session/race-parent/target; fi; mv /run/fukurou/llm-homes/fukurou-codex-home-123/session/race-parent/target-dir /run/fukurou/llm-homes/fukurou-codex-home-123/session/race-parent/target 2>/dev/null || true; fi; attempt=\$((attempt + 1)); done; printf %s \$swapped >/tmp/cleanup-race-count" &
    race_pid=$!
    su -s /bin/sh llm-agent -c "attempt=0; created=0; while [ \$attempt -lt 500 ]; do path=/run/fukurou/llm-homes/fukurou-codex-home-123/home-churn-\$attempt; if mkdir \$path 2>/dev/null; then printf churn >\$path/state 2>/dev/null || true; mv \$path \${path}-renamed 2>/dev/null || true; rm -rf \${path}-renamed \$path 2>/dev/null || true; created=\$((created + 1)); fi; attempt=\$((attempt + 1)); done; printf %s \$created >/tmp/cleanup-home-churn-count" &
    home_churn_pid=$!
    su -s /bin/sh appuser -c "FUKUROU_MCP_CANARY_ARTIFACT_GENERATOR=true /opt/java/openjdk/bin/java -cp /app/app.jar me.matsumo.fukurou.trading.runner.McpIsolationCanaryArtifactsKt CLEANUP /run/fukurou/llm-homes/fukurou-codex-home-123"
    wait "$race_pid" || true
    wait "$home_churn_pid" || true
    test "$(cat /tmp/cleanup-race-count)" -gt 0
    test "$(cat /tmp/cleanup-home-churn-count)" -gt 0
    test ! -e /run/fukurou/llm-homes/fukurou-codex-home-123
    test ! -e /run/fukurou/llm-homes/.cleanup-quarantine
    test -z "$(find /run/fukurou/mcp-manifests -mindepth 1 -print -quit)"
    test "$(stat -c %u:%g:%a /tmp/cleanup-scope-outside)" = 10002:10004:400
    test "$(cat /tmp/cleanup-scope-outside)" = scope-outside
    after=$(sha256sum "$auth_source/auth.json")
    test "$before" = "$after"
    rm -rf /run/fukurou/llm-homes/fukurou-llm-config-123
    test ! -e /run/fukurou/llm-homes/fukurou-llm-config-123
    test ! -e /run/fukurou/llm-homes/fukurou-codex-home-123
' >"$artifact_root/llm-launcher.stdout" 2>"$artifact_root/llm-launcher.stderr"; then
    cat "$artifact_root/llm-launcher.stderr" >&2
    echo "canary failure: LLM launcher artifact cleanup wiring" >&2
    exit 1
fi
echo "canary stage: LLM launcher artifact access complete"

canary_network=fukurou-mcp-canary-${segment_one}
docker network create --internal "$canary_network" >/dev/null
database_container=$(docker run -d --rm --network "$canary_network" --network-alias postgres --env POSTGRES_PASSWORD="$app_credential" --env POSTGRES_DB=fukurou_canary postgres:16-alpine)
attempt=0
until docker exec "$database_container" pg_isready -U postgres -d fukurou_canary >/dev/null 2>&1; do
    attempt=$((attempt + 1))
    [ "$attempt" -lt 30 ] || { echo "canary failure: disposable database readiness" >&2; exit 1; }
    sleep 1
done
echo "canary stage: disposable database ready"
canary_secrets_volume=fukurou-mcp-canary-secrets-${segment_one}
docker volume create "$canary_secrets_volume" >/dev/null
docker run --rm --user 0:0 --read-only --network none --cap-drop ALL --security-opt no-new-privileges=true \
    --mount "type=volume,src=$canary_secrets_volume,dst=/secrets" --entrypoint /bin/sh "$image" -ec '
      umask 077
      printf "%s" "$1" >/secrets/fukurou_mcp_db_password
      printf enabled >/secrets/fukurou_canary_enabled
      chmod 0400 /secrets/fukurou_mcp_db_password /secrets/fukurou_canary_enabled
    ' canary-secret-setup "$marker"
application_container=$(docker run -d --user 0:0 --network "$canary_network" \
    --read-only --pids-limit 512 \
    --cap-drop ALL --cap-add CHOWN --cap-add DAC_READ_SEARCH --cap-add SETGID --cap-add SETUID --cap-add SETPCAP \
    --tmpfs /tmp:rw,noexec,nosuid,nodev,mode=1777 \
    --tmpfs /run/fukurou/control:rw,noexec,nosuid,nodev,mode=0711,uid=0,gid=0 \
    --tmpfs /run/fukurou/llm-homes:rw,noexec,nosuid,nodev,mode=2750,uid=10001,gid=10004 \
    --tmpfs /run/fukurou/mcp-manifests:rw,noexec,nosuid,nodev,mode=0700,uid=10001,gid=10004 \
    --tmpfs /var/lib/fukurou/launch-fence:rw,noexec,nosuid,nodev,mode=0700,uid=0,gid=0 \
    --mount "type=volume,src=$canary_secrets_volume,dst=/run/secrets,readonly" \
    --env DB_URL=jdbc:postgresql://postgres:5432/fukurou_canary --env DB_USER=postgres --env DB_PASSWORD="$app_credential" \
    --env FUKUROU_LLM_IMAGE_DIGEST="$image" \
    --env FUKUROU_CLAUDE_COMMAND_TEMPLATE='/usr/local/libexec/fukurou-llm-agent-launcher claude' \
    --env FUKUROU_CODEX_COMMAND_TEMPLATE='/usr/local/libexec/fukurou-llm-agent-launcher codex' \
    --entrypoint /bin/sh "$image" -ec '
      /usr/local/libexec/fukurou-runtime-supervisor --fence-write ENABLED 0
      exec /usr/local/libexec/fukurou-runtime-supervisor
    ')
docker inspect --format 'user={{.Config.User}} readonly={{.HostConfig.ReadonlyRootfs}} init={{.HostConfig.Init}} pids={{.HostConfig.PidsLimit}} tmp={{index .HostConfig.Tmpfs "/tmp"}} control={{index .HostConfig.Tmpfs "/run/fukurou/control"}} llm={{index .HostConfig.Tmpfs "/run/fukurou/llm-homes"}} manifests={{index .HostConfig.Tmpfs "/run/fukurou/mcp-manifests"}} fence={{index .HostConfig.Tmpfs "/var/lib/fukurou/launch-fence"}} secret={{range .Mounts}}{{if eq .Destination "/run/secrets"}}{{.Type}}:{{.RW}}{{end}}{{end}}' \
    "$application_container" >"$artifact_root/application-security.txt"
grep -q '^user=0:0 readonly=true init=<nil> pids=512 tmp=rw,noexec,nosuid,nodev,mode=1777 control=rw,noexec,nosuid,nodev,mode=0711,uid=0,gid=0 llm=rw,noexec,nosuid,nodev,mode=2750,uid=10001,gid=10004 manifests=rw,noexec,nosuid,nodev,mode=0700,uid=10001,gid=10004 fence=rw,noexec,nosuid,nodev,mode=0700,uid=0,gid=0 secret=volume:false$' \
    "$artifact_root/application-security.txt" || {
    cat "$artifact_root/application-security.txt" >&2
    echo "canary failure: application security profile mismatch" >&2
    exit 1
}
normalize_capabilities() {
    tr '[:lower:]' '[:upper:]' | sed 's/^CAP_//' | sed '/^$/d' | sort -u
}
actual_cap_add=$(docker inspect --format '{{range .HostConfig.CapAdd}}{{println .}}{{end}}' "$application_container" | normalize_capabilities)
expected_cap_add=$(printf '%s\n' CHOWN DAC_READ_SEARCH SETGID SETPCAP SETUID | sort -u)
[ "$actual_cap_add" = "$expected_cap_add" ] || { echo "canary failure: application added capability set mismatch" >&2; exit 1; }
actual_cap_drop=$(docker inspect --format '{{range .HostConfig.CapDrop}}{{println .}}{{end}}' "$application_container" | normalize_capabilities)
[ "$actual_cap_drop" = "ALL" ] || { echo "canary failure: application dropped capability set mismatch" >&2; exit 1; }
attempt=0
until docker exec --env PGPASSWORD="$app_credential" "$database_container" psql -U postgres -d fukurou_canary -Atc \
    "SELECT to_regclass('public.llm_runs') IS NOT NULL AND to_regclass('public.mcp_current_evaluation_scope') IS NOT NULL AND to_regclass('public.mcp_evaluation_epochs') IS NOT NULL" \
    2>/dev/null | grep -q t; do
    attempt=$((attempt + 1))
    [ "$attempt" -lt 45 ] || { docker logs "$application_container" >"$artifact_root/application.log" 2>&1; tail -20 "$artifact_root/application.log" >&2; echo "canary failure: application schema bootstrap" >&2; exit 1; }
    sleep 1
done
set +e
control_response=$(docker exec --user 0:0 "$application_container" \
    /usr/local/libexec/fukurou-runtime-supervisor --control ENABLE 0)
control_status=$?
set -e
[ "$control_status" -eq 0 ] && [ "$control_response" = "ACK ENABLE 0" ] || {
    printf '%s\n' "canary failure: launch control status=$control_status response=$control_response" >&2
    docker logs --tail 40 "$application_container" >&2 || true
    exit 1
}
[ "$(docker exec --user 0:0 "$application_container" awk '{print $1}' /proc/1/stat)" = 1 ]
application_instance=$(docker exec --user 0:0 "$application_container" /bin/sh -c 'printf %s "$HOSTNAME"')
case "$application_instance" in *[!a-zA-Z0-9._-]*|'') echo "canary failure: invalid container instance" >&2; exit 1 ;; esac
insert_launch_fixture() {
    invocation_id=$1
    case "$invocation_id" in *[!a-zA-Z0-9._:-]*|'') echo "canary failure: invalid invocation fixture" >&2; exit 1 ;; esac
    docker exec --env PGPASSWORD="$app_credential" "$database_container" psql -U postgres -d fukurou_canary \
        -v ON_ERROR_STOP=1 -c \
        "INSERT INTO llm_launch_reservations(id,invocation_id,trigger_kind,trigger_key,status,reserved_at)
           VALUES (md5('fukurou-launch-reservation-v1:$invocation_id')::uuid,'$invocation_id','MANUAL','canary:lifecycle','RUNNING',0);
         INSERT INTO llm_pid_registrations(registration_id,invocation_id,reservation_id,role,container_instance_id,state)
           VALUES (md5('fukurou-pid-registration-v1:$invocation_id:PROVIDER')::uuid,'$invocation_id',
             md5('fukurou-launch-reservation-v1:$invocation_id')::uuid,'PROVIDER','$application_instance','SPAWN_RESERVED');" \
        >/dev/null
}
insert_launch_fixture canary-proposer
docker cp "$mcp_role_sql" "$database_container":/tmp/mcp-role.sql
docker exec --env PGPASSWORD="$app_credential" "$database_container" psql -U postgres -d fukurou_canary \
    -v ON_ERROR_STOP=1 -v mcp_role=fukurou_mcp -v mcp_password="$marker" -v database_name=fukurou_canary -v app_role=postgres \
    -f /tmp/mcp-role.sql >"$artifact_root/database-setup.stdout" 2>"$artifact_root/database-setup.stderr"
docker exec --env FUKUROU_FIXTURE_DATABASE=true "$application_container" \
    /opt/java/openjdk/bin/java -cp /app/app.jar \
    me.matsumo.fukurou.trading.runner.PaperMarketRecoveryMainKt FIXTURE_CREATE mcp-canary-run \
    >>"$artifact_root/database-setup.stdout" 2>>"$artifact_root/database-setup.stderr"
fixture_count=$(docker exec --env PGPASSWORD="$app_credential" "$database_container" psql -U postgres -d fukurou_canary -Atc \
    "SELECT COUNT(*) FROM llm_runs WHERE invocation_id='mcp-canary-run' AND birth_sequence > 0")
[ "$fixture_count" = "1" ] || { echo "canary failure: token-aware fixture" >&2; exit 1; }
docker exec --env PGPASSWORD="$app_credential" "$database_container" psql -U postgres -d fukurou_canary -v ON_ERROR_STOP=1 -c \
    "INSERT INTO decision_material_state_manifests(invocation_id,captured_at,schema_version,content_hash,material_projection,manifest_json) VALUES ('mcp-canary-run',0,1,repeat('a',64),'','{\"invocationId\":\"mcp-canary-run\",\"capturedAt\":\"2026-07-02T00:00:00Z\",\"triggerKind\":\"DAEMON\",\"symbol\":\"BTC\",\"riskState\":\"RUNNING\",\"priceMoveThresholdRatio\":\"0.01\",\"freshness\":\"FRESH\",\"openPositionFacts\":[],\"openOrderFacts\":[],\"missingSources\":[],\"schemaVersion\":1,\"canonicalContentHash\":\"aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa\",\"materialProjection\":\"\"}')" \
    >>"$artifact_root/database-setup.stdout" 2>>"$artifact_root/database-setup.stderr"
if docker exec --env PGPASSWORD="$app_credential" "$database_container" psql -U postgres -d fukurou_canary -v ON_ERROR_STOP=1 -c \
    "INSERT INTO llm_runs(invocation_id,mode,symbol,status,started_at) VALUES ('raw-app-canary','PAPER','BTC','RUNNING',0)" \
    >>"$artifact_root/database-setup.stdout" 2>>"$artifact_root/database-setup.stderr"; then
    echo "canary failure: raw app INSERT bypassed lifecycle token" >&2
    exit 1
fi
if docker exec --env PGPASSWORD="$marker" "$database_container" psql -U fukurou_mcp -d fukurou_canary -v ON_ERROR_STOP=1 -c \
    "INSERT INTO llm_runs(invocation_id,mode,symbol,status,started_at) VALUES ('raw-mcp-canary','PAPER','BTC','RUNNING',0)" \
    >>"$artifact_root/database-setup.stdout" 2>>"$artifact_root/database-setup.stderr"; then
    echo "canary failure: MCP role gained llm_runs INSERT" >&2
    exit 1
fi
if docker exec --env PGPASSWORD="$marker" "$database_container" psql -U fukurou_mcp -d fukurou_canary -v ON_ERROR_STOP=1 -c \
    "SELECT acquire_opportunity_episode_gap_population_token('BTC')" \
    >>"$artifact_root/database-setup.stdout" 2>>"$artifact_root/database-setup.stderr"; then
    echo "canary failure: MCP role gained opportunity token execution" >&2
    exit 1
fi
if docker exec --env PGPASSWORD="$marker" "$database_container" psql -U fukurou_mcp -d fukurou_canary -v ON_ERROR_STOP=1 -c \
    "INSERT INTO opportunity_episodes(id,symbol,thesis_id,price_move_threshold_ratio,opened_at,closed_at,close_reason) VALUES (gen_random_uuid(),'BTC','forbidden-canary',0.01,0,NULL,NULL)" \
    >>"$artifact_root/database-setup.stdout" 2>>"$artifact_root/database-setup.stderr"; then
    echo "canary failure: MCP role gained opportunity INSERT" >&2
    exit 1
fi
if docker exec --env PGPASSWORD="$marker" "$database_container" psql -U fukurou_mcp -d fukurou_canary -v ON_ERROR_STOP=1 -c \
    "UPDATE opportunity_episodes SET closed_at=closed_at,close_reason=close_reason" \
    >>"$artifact_root/database-setup.stdout" 2>>"$artifact_root/database-setup.stderr"; then
    echo "canary failure: MCP role gained opportunity close UPDATE" >&2
    exit 1
fi
echo "canary stage: database fixture complete"

docker exec --user 10001:10004 --env FUKUROU_MCP_CANARY_ARTIFACT_GENERATOR=true \
    "$application_container" /opt/java/openjdk/bin/java -cp /app/app.jar \
    me.matsumo.fukurou.trading.runner.McpIsolationCanaryArtifactsKt IDENTITY CODEX \
    >"$artifact_root/cli-identity.txt" 2>"$artifact_root/cli-identity.stderr"
identity_phase=$(sed -n 's/^PHASE_MANIFEST_ID=//p' "$artifact_root/cli-identity.txt")
identity_value=$(sed -n 's/^CLI_IDENTITY=//p' "$artifact_root/cli-identity.txt")
[ "$identity_phase" = "mcp-canary-cli-identity:PRE_FILTER" ] || { echo "canary failure: saved identity phase" >&2; exit 1; }
printf '%s' "$identity_value" | grep -q '^revision=llm-cli-command-v1;template=/usr/local/libexec/fukurou-llm-agent-launcher codex;fingerprint='
saved_identity=$(docker exec --env PGPASSWORD="$app_credential" "$database_container" psql -U postgres -d fukurou_canary -Atc \
