    test ! -e /var/run/docker.sock
    test "$(id -u)" = 10001
    test "$(awk "/CapEff/ {print \$2}" /proc/self/status)" = "0000000000000000"
'
docker run --rm --user root --entrypoint /bin/sh "$image" -ec '
    test "$(find / -type f -perm /6000 2>/dev/null | sort)" = "/usr/local/libexec/fukurou-llm-agent-launcher
/usr/local/libexec/fukurou-mcp-launcher"
    test -z "$(find / -type f -perm /2000 ! -perm /4000 2>/dev/null)"
    test -z "$(getcap -r / 2>/dev/null)"
    test ! -S /var/run/docker.sock
    test ! -S /run/containerd/containerd.sock
    test ! -S /run/crio/crio.sock
    ! grep -Eq "(/var/run/docker.sock|/run/docker.sock|/run/containerd|/run/crio)" /proc/mounts
'
docker run --rm --user 10001:10004 --cap-drop ALL --entrypoint /bin/sh "$image" -ec '
    assert_126() {
        set +e
        "$@" >/dev/null 2>&1
        status=$?
        set -e
        test "$status" -eq 126
    }
    assert_126 /usr/local/libexec/fukurou-llm-agent-launcher
    assert_126 /usr/local/libexec/fukurou-llm-agent-launcher unknown
    assert_126 /usr/local/libexec/fukurou-llm-agent-launcher canary invalid PROPOSER
    assert_126 /usr/local/libexec/fukurou-llm-agent-launcher cleanup
    assert_126 /usr/local/libexec/fukurou-llm-agent-launcher cleanup /tmp/fukurou-codex-home-123
    assert_126 /usr/local/libexec/fukurou-llm-agent-launcher cleanup /run/fukurou/llm-homes/not-canonical
    assert_126 /usr/local/libexec/fukurou-mcp-launcher
    assert_126 /usr/local/libexec/fukurou-mcp-launcher invalid
    assert_126 /usr/local/libexec/fukurou-mcp-launcher 0123456789abcdef0123456789abcdef0123456789abcdef extra
'
docker run --rm --user root --entrypoint /bin/sh "$image" -ec '
    manifest_id=0123456789abcdef0123456789abcdef0123456789abcdef
    install -d -o 10001 -g 10004 -m 0700 /run/fukurou/mcp-manifests
    printf "%s" "{}" >"/run/fukurou/mcp-manifests/$manifest_id.json"
    chown 10001:10004 "/run/fukurou/mcp-manifests/$manifest_id.json"
    chmod 0600 "/run/fukurou/mcp-manifests/$manifest_id.json"
    printf "%s" "fixture" >/run/secrets/fukurou_mcp_db_password
    chown 0:0 /run/secrets/fukurou_mcp_db_password
    chmod 0400 /run/secrets/fukurou_mcp_db_password
    ln -s /tmp/cross-manifest.sock "/run/fukurou/mcp-manifests/$manifest_id.sock"
    set +e
    /usr/local/libexec/fukurou-mcp-launcher "$manifest_id" >/tmp/symlink.stdout 2>/tmp/symlink.stderr
    status=$?
    set -e
    test "$status" -eq 126
    grep -q "submission gateway is not a socket" /tmp/symlink.stderr
'

echo "offline production-image isolation checks passed"
echo "optional pinned real-model probe: NOT RUN (operator credential and disposable DB required)"
cleanup
