# docker-compose 用の環境変数テンプレート。
# ローカル開発用 `.env`、または NAS の `/srv/fukurou/.env` にコピーして設定する。
# Cloudflare Access の Client ID / Secret は NAS `.env` に置かない。

# --- Cloudflare Tunnel ---
# Zero Trust -> Networks -> Tunnels で作成した remotely-managed tunnel の接続トークン。
CLOUDFLARED_TUNNEL_TOKEN=

# --- PostgreSQL ---
# ktor は DB_URL=jdbc:postgresql://postgres:5432/${POSTGRES_DB} で接続する。
POSTGRES_DB=fukurou
POSTGRES_USER=fukurou
POSTGRES_PASSWORD=

# --- Trading runtime config ---
# 既定は BTC 現物 / paper。LIVE は live broker 実装前の予約値で、現時点では起動時に拒否される。
FUKUROU_TRADING_SYMBOL=BTC
FUKUROU_TRADING_MODE=PAPER
FUKUROU_PAPER_INITIAL_CASH_JPY=100000

# paper 約定近似と SafetyFloor の保守的な既定値。SafetyFloor 系は既定より保守側の値だけ許可する。
FUKUROU_MARKET_SLIPPAGE_BPS=5
FUKUROU_MARKET_SLIPPAGE_RESERVE_BPS=5
FUKUROU_FALLBACK_MAKER_FEE_RATE=-0.0001
FUKUROU_FALLBACK_TAKER_FEE_RATE=0.0005
FUKUROU_FALLBACK_SPREAD_BPS=2.0
FUKUROU_MAX_RISK_PER_TRADE_RATIO=0.02
FUKUROU_MAX_DRAWDOWN_RATIO=-0.15
FUKUROU_MAX_TOTAL_EXPOSURE_RATIO=0.80
FUKUROU_MIN_EXPECTED_VALUE_R=0.10
FUKUROU_MIN_EXPECTED_MOVE_TO_COST_RATIO=3.0
FUKUROU_MAX_TAKER_FEE_RATIO=0.0010

# GMO Public REST client。Private API key は live 実発注まで追加しない。
# rate limit は既定 10 req/s 以下だけ許可する。
FUKUROU_GMO_PUBLIC_BASE_URL=https://api.coin.z.com/public
FUKUROU_GMO_PUBLIC_REST_PER_SECOND=10
FUKUROU_GMO_PUBLIC_REST_BURST=10
FUKUROU_GMO_RETRY_MAX_ATTEMPTS=3
FUKUROU_GMO_RETRY_INITIAL_BACKOFF_MS=200
FUKUROU_GMO_RETRY_MAX_BACKOFF_MS=2000
FUKUROU_GMO_RETRY_BACKOFF_MULTIPLIER=2
FUKUROU_GMO_CONNECT_TIMEOUT_MS=5000
FUKUROU_GMO_REQUEST_TIMEOUT_MS=10000
FUKUROU_GMO_SYMBOL_RULES_CACHE_TTL_SECONDS=600

# --- LLM one-shot runner limits ---
# 既定より危険側の override は起動時に拒否される。
FUKUROU_MCP_TOTAL_TOOL_CALL_LIMIT=48
FUKUROU_MCP_ACT_TOOL_CALL_LIMIT=3
FUKUROU_LLM_RUN_TIMEOUT_SECONDS=180
FUKUROU_LLM_MAX_INVOCATIONS_PER_HOUR=1
FUKUROU_LLM_MAX_INVOCATIONS_PER_DAY=10
FUKUROU_MCP_JAR_PATH=mcp/build/libs/fukurou-mcp-all.jar
FUKUROU_MCP_SERVER_NAME=fukurou-mcp
FUKUROU_MCP_SERVER_COMMAND=java
FUKUROU_CLAUDE_COMMAND_TEMPLATE=claude
FUKUROU_CODEX_COMMAND_TEMPLATE=codex

# --- LLM daemon scheduler ---
# production compose は既定で true。ローカルで Ktor だけ起動するときは false を推奨する。
FUKUROU_LLM_DAEMON_ENABLED=false
FUKUROU_LLM_DAEMON_POLL_SECONDS=60
FUKUROU_LLM_FLAT_HEARTBEAT_SECONDS=21600
FUKUROU_LLM_HOLDING_CHECK_SECONDS=10800
# id|name|eventAtUtc|beforeMinutes|afterMinutes を ; 区切りで列挙する。eventAtUtc は Z 付き UTC。
# FUKUROU_ECONOMIC_EVENT_BLACKOUTS_UTC=fomc-20260729|FOMC|2026-07-29T18:00:00Z|60|60;cpi-20260812|CPI|2026-08-12T12:30:00Z|60|60

# --- CLI auth mounts ---
# production では compose の read-only mount 元。CLI の HOME / cache は別 writable volume に分ける。
# Claude は macOS Keychain の `Claude Code-credentials` から Linux `~/.claude/.credentials.json` 形式を抽出して置く。
# Codex は `auth.json` を read-only mount 元へ置く。Falsifier の `--yolo` は container sandbox template と併用する。
# FUKUROU_CLAUDE_CREDENTIALS_FILE=/srv/fukurou/claude/.credentials.json
# FUKUROU_CODEX_AUTH_FILE=/srv/fukurou/codex/auth.json
# 任意。指定した場合だけ renderer が provider CLI に model flag を渡す。
# FUKUROU_CLAUDE_MODEL=
# FUKUROU_CODEX_MODEL=
# 任意。sandbox wrapper や追加 tool allowlist を検証するときだけ指定する。
# FUKUROU_MCP_SERVER_ARGS=-jar mcp/build/libs/fukurou-mcp-all.jar
# FUKUROU_PROPOSER_ALLOWED_TOOLS=
# FUKUROU_FALSIFIER_ALLOWED_TOOLS=
# safety / MCP / sandbox / approval を上書きする common args は起動時に拒否される。
# FUKUROU_CLAUDE_COMMON_ARGS=
# FUKUROU_CODEX_COMMON_ARGS=
# 外部 sandbox で閉じ込めた場合だけ危険側の Falsifier 追加引数を明示する。
# FUKUROU_CODEX_FALSIFIER_ARGS=

# --- Production deploy ---
# 通常は deploy script が引数の commit SHA から export するため、NAS `.env` には設定しない。
# docker compose -f docker-compose.prod.yml config を手元で確認する場合だけ一時的に指定する。
# FUKUROU_IMAGE_TAG=

# --- Local protected API curl credentials ---
# Cloudflare Access の Service Token は手元の password manager や別の未追跡 env file で管理する。
# NAS `.env` には保存しない。
# scripts/prod-curl は exported env、FUKUROU_PROD_CURL_ENV_FILE、.env.local、.env から読み込む。
# CLOUDFLARED_TUNNEL_CLIENT_ID=
# CLOUDFLARED_TUNNEL_CLIENT_SECRET=

# 通常は未設定。scripts/prod-curl の向き先をローカル stub などに差し替える検証時だけ設定する。
# full URL 指定時も、この origin と一致する URL にだけ Service Token を付与する。
# FUKUROU_PROD_BASE_URL=
