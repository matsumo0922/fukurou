# docker-compose 用の環境変数テンプレート。
# ローカル開発用 `.env`、または NAS の `/srv/fukurou/.env` にコピーして設定する。
# Cloudflare Access の Client ID / Secret は NAS `.env` に置かない。

# --- Cloudflare Tunnel ---
# Zero Trust -> Networks -> Tunnels で作成した remotely-managed tunnel の接続トークン。
CLOUDFLARED_TUNNEL_TOKEN=

# --- PostgreSQL ---
# ktor は DB_URL=jdbc:postgresql://postgres:5432/${POSTGRES_DB} で接続する。
POSTGRES_DB=fukurou
POSTGRES_USER=fukurou
POSTGRES_PASSWORD=

# --- Production deploy ---
# 通常は deploy script が引数の commit SHA から export するため、NAS `.env` には設定しない。
# docker compose -f docker-compose.prod.yml config を手元で確認する場合だけ一時的に指定する。
# FUKUROU_IMAGE_TAG=

# --- Local protected API curl credentials ---
# Cloudflare Access の Service Token は手元の password manager や別の未追跡 env file で管理する。
# NAS `.env` には保存しない。
# scripts/prod-curl は exported env、FUKUROU_PROD_CURL_ENV_FILE、.env.local、.env から読み込む。
# CLOUDFLARED_TUNNEL_CLIENT_ID=
# CLOUDFLARED_TUNNEL_CLIENT_SECRET=

# 通常は未設定。scripts/prod-curl の向き先をローカル stub などに差し替える検証時だけ設定する。
# full URL 指定時も、この origin と一致する URL にだけ Service Token を付与する。
# FUKUROU_PROD_BASE_URL=
