# docker-compose 用の環境変数テンプレート。
# ローカル開発用 `.env`、または NAS の `/srv/fukurou/.env` にコピーして設定する。
# Cloudflare Access の Client ID / Secret は NAS `.env` に置かない。

# --- Cloudflare Tunnel ---
# Zero Trust -> Networks -> Tunnels で作成した remotely-managed tunnel の接続トークン。
CLOUDFLARED_TUNNEL_TOKEN=
# current-context WebSocket が許可する browser の単一 public origin。local Vite の既定値。
# production では Cloudflare Tunnel の Public Hostname origin（例: https://fukurou.example.com）へ変更する。
FUKUROU_PUBLIC_ORIGIN=http://localhost:5173

# --- PostgreSQL ---
# ktor は DB_URL=jdbc:postgresql://postgres:5432/${POSTGRES_DB} で接続する。
POSTGRES_DB=fukurou
POSTGRES_USER=fukurou
POSTGRES_PASSWORD=

# --- Trading deployment boundary ---
# 取引対象と mode は deployment 単位で固定する。LIVE は live broker 実装前の予約値で、現時点では起動時に拒否される。
FUKUROU_TRADING_SYMBOL=BTC
FUKUROU_TRADING_MODE=PAPER

# GMO Public REST / WebSocket client。Private API key は live 実発注まで追加しない。
FUKUROU_GMO_PUBLIC_BASE_URL=https://api.coin.z.com/public
FUKUROU_GMO_PUBLIC_WEBSOCKET_URL=wss://api.coin.z.com/ws/public/v1
# WebSocket の connect timeout、message stale timeout、reconnect backoff は
# WebUI `/app/config` の gmoPublic Runtime group で変更する。

# --- LLM / MCP deployment boundary ---
# ローカル checkout では build 出力を使う。production container では /app/fukurou-mcp-all.jar に変更する。
FUKUROU_MCP_JAR_PATH=mcp/build/libs/fukurou-mcp-all.jar
FUKUROU_MCP_SERVER_NAME=fukurou-mcp
FUKUROU_MCP_SERVER_COMMAND=/usr/local/libexec/fukurou-mcp-launcher
FUKUROU_CLAUDE_COMMAND_TEMPLATE=claude
FUKUROU_CODEX_COMMAND_TEMPLATE=codex

# --- Obsidian deployment boundary ---
# container mount と対応する vault path。
FUKUROU_OBSIDIAN_VAULT_PATH=/vault
# production compose の host bind mount 元。appuser UID 10001 が書き込める directory にする。
# FUKUROU_OBSIDIAN_VAULT_PATH_HOST=/srv/fukurou/obsidian-vault

# --- CLI auth ---
# production compose は llm-auth volume を auth source、llm-runs volume を cleanup quarantine を含む per-run artifact 用に使う。
# MCP 専用 role 名。app role や superuser を指定しない。
FUKUROU_MCP_DB_USER=fukurou_mcp
# root:root 0400 の MCP 専用 password file。値そのものを .env に書かない。
FUKUROU_MCP_DB_PASSWORD_FILE=/srv/fukurou/secrets/fukurou_mcp_db_password
# 任意。sandbox wrapper や追加 tool allowlist を検証するときだけ指定する。
# Proposer/Falsifier allowlist は code-owned canonical policy であり、env から変更しない。
# safety / MCP / sandbox / approval を上書きする common args は起動時に拒否される。
# FUKUROU_CLAUDE_COMMON_ARGS=
# FUKUROU_CODEX_COMMON_ARGS=
# 外部 sandbox で閉じ込めた場合だけ危険側の Falsifier 追加引数を明示する。
# FUKUROU_CODEX_FALSIFIER_ARGS=

# --- Production deploy ---
# 通常は deploy script が引数の commit SHA から export するため、NAS `.env` には設定しない。
# docker compose -f docker-compose.prod.yml config を手元で確認する場合だけ一時的に指定する。
# FUKUROU_IMAGE_TAG=

# --- Local protected API curl credentials ---
# Cloudflare Access の Service Token は手元の password manager や別の未追跡 env file で管理する。
# NAS `.env` には保存しない。
# scripts/prod-curl は exported env、FUKUROU_PROD_CURL_ENV_FILE、.env.local、.env から読み込む。
# CLOUDFLARED_TUNNEL_CLIENT_ID=
# CLOUDFLARED_TUNNEL_CLIENT_SECRET=

# 通常は未設定。scripts/prod-curl の向き先をローカル stub などに差し替える検証時だけ設定する。
# full URL 指定時も、この origin と一致する URL にだけ Service Token を付与する。
# FUKUROU_PROD_BASE_URL=
